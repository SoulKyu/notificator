package pages

import (
	"notificator/internal/webui/templates/components"
	"notificator/internal/webui/templates/layouts"
	"notificator/internal/webui/templates/scripts"
)

type StatisticsDashboardData struct {
	User ProfileUser
}

templ StatisticsDashboard(data StatisticsDashboardData) {
	@layouts.Base("Alert Statistics - Notificator", StatisticsDashboardContent(data))
}

templ StatisticsDashboardContent(data StatisticsDashboardData) {
	<!-- Chart.js CDN -->
	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
	<!-- Statistics Views Mixin -->
	@scripts.StatisticsViews()
	<style>
		@keyframes query-pulse {
			0%, 100% {
				transform: scale(1);
				box-shadow:
					0 0 0 0 rgba(59, 130, 246, 0.8),
					0 0 20px 5px rgba(59, 130, 246, 0.4);
			}
			50% {
				transform: scale(1.05);
				box-shadow:
					0 0 0 12px rgba(59, 130, 246, 0),
					0 0 30px 10px rgba(59, 130, 246, 0.6);
			}
		}
		.animate-query-pulse {
			animation: query-pulse 1.2s ease-in-out infinite;
			position: relative;
		}
	</style>
	<div class="min-h-screen bg-slate-50 dark:bg-dark-bg-primary" x-data={ "{ ...statisticsDashboardPage(), ...statisticsViewsMixin(), currentUserId: '" + data.User.ID + "' }" }>
		<!-- Sticky Header Bar -->
		<header class="sticky top-0 z-40 bg-white/95 dark:bg-dark-bg-secondary/95 backdrop-blur-sm border-b border-slate-200 dark:border-slate-700/50">
			<div class="px-6 py-4">
				<div class="flex items-center justify-between">
					<!-- Left: Title & Stats -->
					<div class="flex items-center gap-4 flex-1">
						<div>
							<h1 class="text-xl font-semibold text-slate-900 dark:text-white tracking-tight">Statistics</h1>
							<p class="text-sm text-slate-500 dark:text-slate-400" x-show="hasData">
								<span x-text="formatNumber(statsData?.total_alerts || 0)"></span> alerts
								<span class="text-slate-300 dark:text-slate-600 mx-1">&bull;</span>
								<span x-text="formatTimeRangeDisplay()"></span>
							</p>
						</div>
					</div>

					<!-- Center: Page Navigation -->
					<div class="hidden md:flex items-center justify-center">
						@components.PageNavigator("statistics")
					</div>

					<!-- Right: Actions -->
					<div class="flex items-center gap-2 flex-1 justify-end">
						<!-- Compare Toggle -->
						<button @click="comparisonMode = !comparisonMode; if(comparisonMode && hasData) loadComparisonData()"
							:class="comparisonMode ? 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800'"
							class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
							</svg>
							<span class="hidden sm:inline">Compare</span>
						</button>

						<!-- Export -->
						<button @click="exportData" :disabled="loading || !hasData"
							class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-white bg-slate-900 hover:bg-slate-800 dark:bg-slate-700 dark:hover:bg-slate-600 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
							</svg>
							<span class="hidden sm:inline">Export</span>
						</button>
					</div>
				</div>
			</div>
		</header>

		<!-- Main Content -->
		<div class="px-6 py-6">

			<!-- Query Bar - Compact & Scannable -->
			<div class="mb-6 bg-white dark:bg-dark-bg-secondary rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700/50">
			<!-- Primary Filters Row -->
			<div class="px-5 py-4 flex flex-wrap items-center gap-3 relative">
				<!-- Time Filters Group -->
				<div class="flex items-center gap-2 px-3 py-1.5 bg-blue-50 dark:bg-blue-900/20 rounded-xl border border-blue-100 dark:border-blue-800/30">
					<!-- Time Range Picker -->
					<div class="relative">
						<button
							@click="openTimeRangePicker()"
							type="button"
							class="inline-flex items-center gap-2 px-4 py-2.5 bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-700 rounded-xl text-sm font-medium text-slate-700 dark:text-slate-200 transition-colors border border-blue-200 dark:border-blue-700/50"
						>
							<svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
							</svg>
							<span x-text="formatTimeRangeDisplay()"></span>
							<svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<!-- Dropdown Panel -->
						<div
							x-show="timeRangePickerOpen"
							x-cloak
							x-transition:enter="transition ease-out duration-150"
							x-transition:enter-start="opacity-0 scale-95"
							x-transition:enter-end="opacity-100 scale-100"
							x-transition:leave="transition ease-in duration-100"
							x-transition:leave-start="opacity-100 scale-100"
							x-transition:leave-end="opacity-0 scale-95"
							@click.outside="closeTimeRangePicker(false)"
							@keydown.escape.window="closeTimeRangePicker(false)"
							@keydown.enter.prevent="closeTimeRangePicker(true)"
							class="absolute left-0 z-50 mt-2 w-[540px] bg-white dark:bg-dark-bg-secondary rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-700 overflow-hidden"
						>
							<!-- Quick Presets -->
							<div class="px-5 py-4 bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700">
								<div class="flex flex-wrap gap-2">
									<button @click="setQuickRange('1h')" type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-white dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-600 border border-slate-200 dark:border-slate-600 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">1 hour</button>
									<button @click="setQuickRange('24h')" type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-white dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-600 border border-slate-200 dark:border-slate-600 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">24 hours</button>
									<button @click="setQuickRange('7d')" type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-white dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-600 border border-slate-200 dark:border-slate-600 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">7 days</button>
									<button @click="setQuickRange('30d')" type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-white dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-600 border border-slate-200 dark:border-slate-600 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">30 days</button>
									<button @click="setQuickRange('90d')" type="button" class="px-4 py-2 text-sm font-medium rounded-lg bg-white dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-600 border border-slate-200 dark:border-slate-600 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">90 days</button>
								</div>
							</div>
							<!-- Tab Headers -->
							<div class="flex px-5 pt-4 gap-2">
								<button
									@click="timeRangePickerTab = 'relative'; filters.timeRangeMode = 'relative'"
									:class="timeRangePickerTab === 'relative' ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'"
									class="px-4 py-2 text-sm font-medium rounded-lg transition-colors"
									type="button"
								>
									Relative
								</button>
								<button
									@click="timeRangePickerTab = 'absolute'; filters.timeRangeMode = 'absolute'"
									:class="timeRangePickerTab === 'absolute' ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'"
									class="px-4 py-2 text-sm font-medium rounded-lg transition-colors"
									type="button"
								>
									Absolute
								</button>
							</div>

							<!-- Tab Content Area -->
							<div class="p-5 min-h-[140px]">
								<!-- Relative Tab -->
								<div x-show="timeRangePickerTab === 'relative'">
									<div class="grid grid-cols-2 gap-8">
										<!-- From Section -->
										<div class="min-h-[70px]">
											<div class="flex items-center justify-between mb-3">
												<span class="text-sm font-semibold text-slate-700 dark:text-slate-300">From</span>
												<label class="flex items-center cursor-pointer">
													<input
														type="checkbox"
														x-model="filters.relativeFrom.allTime"
														class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-slate-300 rounded"
													/>
													<span class="ml-2 text-sm text-slate-600 dark:text-slate-400">All Time</span>
												</label>
											</div>
											<div class="flex items-center gap-3" x-show="!filters.relativeFrom.allTime">
												<input
													type="number"
													x-model.number="filters.relativeFrom.value"
													@keydown.up.prevent="incrementValue('from', 1)"
													@keydown.down.prevent="incrementValue('from', -1)"
													min="0"
													:max="getMaxValueForUnit(filters.relativeFrom.unit)"
													class="w-24 text-center px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												/>
												<select
													x-model="filters.relativeFrom.unit"
													class="flex-1 px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												>
													<option value="minutes">Minutes</option>
													<option value="hours">Hours</option>
													<option value="days">Days</option>
													<option value="weeks">Weeks</option>
													<option value="months">Months</option>
													<option value="years">Years</option>
												</select>
												<span class="text-sm text-slate-500 dark:text-slate-400 whitespace-nowrap">ago</span>
											</div>
											<div x-show="filters.relativeFrom.allTime" class="flex items-center h-[42px] px-3 bg-slate-50 dark:bg-slate-800 rounded-lg text-sm text-slate-500 dark:text-slate-400">
												From the beginning of time
											</div>
										</div>

										<!-- Until Section -->
										<div class="min-h-[70px]">
											<div class="flex items-center justify-between mb-3">
												<span class="text-sm font-semibold text-slate-700 dark:text-slate-300">Until</span>
												<label class="flex items-center cursor-pointer">
													<input
														type="checkbox"
														x-model="filters.relativeUntil.now"
														class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-slate-300 rounded"
													/>
													<span class="ml-2 text-sm text-slate-600 dark:text-slate-400">Now</span>
												</label>
											</div>
											<div class="flex items-center gap-3" x-show="!filters.relativeUntil.now">
												<input
													type="number"
													x-model.number="filters.relativeUntil.value"
													@keydown.up.prevent="incrementValue('until', 1)"
													@keydown.down.prevent="incrementValue('until', -1)"
													min="0"
													:max="getMaxValueForUnit(filters.relativeUntil.unit)"
													class="w-24 text-center px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												/>
												<select
													x-model="filters.relativeUntil.unit"
													class="flex-1 px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												>
													<option value="minutes">Minutes</option>
													<option value="hours">Hours</option>
													<option value="days">Days</option>
													<option value="weeks">Weeks</option>
													<option value="months">Months</option>
													<option value="years">Years</option>
												</select>
												<span class="text-sm text-slate-500 dark:text-slate-400 whitespace-nowrap">ago</span>
											</div>
											<div x-show="filters.relativeUntil.now" class="flex items-center h-[42px] px-3 bg-slate-50 dark:bg-slate-800 rounded-lg text-sm text-slate-500 dark:text-slate-400">
												Current time (now)
											</div>
										</div>
									</div>
								</div>

								<!-- Absolute Tab -->
								<div x-show="timeRangePickerTab === 'absolute'">
									<div class="grid grid-cols-2 gap-8">
										<!-- From Section -->
										<div>
											<span class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3">From</span>
											<div class="space-y-3">
												<input
													type="date"
													x-model="filters.startDate"
													class="w-full px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												/>
												<input
													type="time"
													x-model="filters.absoluteFromTime"
													class="w-full px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												/>
											</div>
										</div>

										<!-- Until Section -->
										<div>
											<div class="flex items-center justify-between mb-3">
												<span class="text-sm font-semibold text-slate-700 dark:text-slate-300">Until</span>
												<label class="flex items-center cursor-pointer">
													<input
														type="checkbox"
														x-model="filters.relativeUntil.now"
														class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-slate-300 rounded"
													/>
													<span class="ml-2 text-sm text-slate-600 dark:text-slate-400">Now</span>
												</label>
											</div>
											<div class="space-y-3" x-show="!filters.relativeUntil.now">
												<input
													type="date"
													x-model="filters.endDate"
													class="w-full px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												/>
												<input
													type="time"
													x-model="filters.absoluteUntilTime"
													class="w-full px-3 py-2.5 text-base border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
												/>
											</div>
											<div x-show="filters.relativeUntil.now" class="flex items-center h-[42px] px-3 bg-slate-50 dark:bg-slate-800 rounded-lg text-sm text-slate-500 dark:text-slate-400">
												Current time (now)
											</div>
										</div>
									</div>
								</div>
							</div>

							<!-- Footer with Cancel/Apply -->
							<div class="flex justify-end gap-3 px-5 py-4 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-700">
								<button
									@click="closeTimeRangePicker(false)"
									type="button"
									class="px-5 py-2.5 text-sm font-medium text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
								>
									Cancel
								</button>
								<button
									@click="closeTimeRangePicker(true)"
									type="button"
									class="px-5 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
								>
									Apply
								</button>
							</div>
						</div>
					</div>

					<!-- Time of Day Filter -->
					<div class="relative" x-data="{ timeOfDayOpen: false }" @click.outside="timeOfDayOpen = false">
						<button @click="timeOfDayOpen = !timeOfDayOpen" type="button"
							class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-colors border border-blue-200 dark:border-blue-700/50"
							:class="isTimeFilterActive() ? 'bg-blue-100 dark:bg-blue-800/40 text-blue-700 dark:text-blue-300 hover:bg-blue-200 dark:hover:bg-blue-800/60' : 'bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700'">
							<!-- Clock icon -->
							<svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span x-text="getTimeOfDayButtonText()"></span>
							<svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<!-- Dropdown with time of day settings -->
						<div x-show="timeOfDayOpen" x-transition x-cloak class="absolute left-0 mt-2 w-80 bg-white dark:bg-dark-bg-secondary rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
							<div class="p-4 space-y-4">
								<!-- Time inputs (smart text inputs) -->
								<div class="grid grid-cols-2 gap-3">
									<div>
										<label class="block text-xs text-slate-500 dark:text-slate-400 mb-1">From</label>
										<input
											type="text"
											id="time-input-start"
											x-model="timeOfDayStartRaw"
											@focus="$el.select()"
											@blur="validateAndSetTime('start', timeOfDayStartRaw, 'time-input-start')"
											@keydown.enter="validateAndSetTime('start', timeOfDayStartRaw, 'time-input-start'); $el.blur()"
											placeholder="HH:MM"
											class="time-input w-full"
											x-init="timeOfDayStartRaw = filters.timeOfDayStart"
										/>
									</div>
									<div>
										<label class="block text-xs text-slate-500 dark:text-slate-400 mb-1">To</label>
										<input
											type="text"
											id="time-input-end"
											x-model="timeOfDayEndRaw"
											@focus="$el.select()"
											@blur="validateAndSetTime('end', timeOfDayEndRaw, 'time-input-end')"
											@keydown.enter="validateAndSetTime('end', timeOfDayEndRaw, 'time-input-end'); $el.blur()"
											placeholder="HH:MM"
											class="time-input w-full"
											x-init="timeOfDayEndRaw = filters.timeOfDayEnd"
										/>
									</div>
								</div>

								<!-- Timeline bar visualization -->
								<div class="mt-3">
									<div class="timeline-bar">
										<template x-for="seg in getTimelineSegments()" :key="seg.hour">
											<div
												class="timeline-segment flex-1"
												:class="seg.active ? 'timeline-segment-active' : 'timeline-segment-inactive'"
												:title="seg.hour + ':00'"
											></div>
										</template>
									</div>
									<div class="flex justify-between text-[10px] text-slate-400 dark:text-slate-500 mt-1 px-0.5">
										<span>0</span>
										<span>6</span>
										<span>12</span>
										<span>18</span>
										<span>24</span>
									</div>
								</div>

								<!-- Quick presets -->
								<div>
									<span class="block text-xs text-slate-500 dark:text-slate-400 mb-2">Quick presets</span>
									<div class="flex flex-wrap gap-1.5">
										<button @click="setTimePreset('oncall')" type="button"
											class="flex flex-col items-center px-2.5 py-1.5 text-xs font-medium rounded-lg transition-colors"
											:class="filters.activePreset === 'oncall' ? 'bg-purple-600 text-white' : 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 hover:bg-purple-200'">
											<span>On-Call</span>
											<span class="text-[10px] opacity-75 font-mono" x-text="getOnCallPreset().start + '\u2192' + getOnCallPreset().end"></span>
										</button>
										<button @click="setTimePreset('morning')" type="button"
											class="flex flex-col items-center px-2.5 py-1.5 text-xs font-medium rounded-lg transition-colors"
											:class="filters.activePreset === 'morning' ? 'bg-amber-600 text-white' : 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 hover:bg-amber-200'">
											<span>Morning</span>
											<span class="text-[10px] opacity-75 font-mono" x-text="timePresets.morning.start + '\u2192' + timePresets.morning.end"></span>
										</button>
										<button @click="setTimePreset('noon')" type="button"
											class="flex flex-col items-center px-2.5 py-1.5 text-xs font-medium rounded-lg transition-colors"
											:class="filters.activePreset === 'noon' ? 'bg-teal-600 text-white' : 'bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 hover:bg-teal-200'">
											<span>Noon</span>
											<span class="text-[10px] opacity-75 font-mono" x-text="timePresets.noon.start + '\u2192' + timePresets.noon.end"></span>
										</button>
										<button @click="setTimePreset('business')" type="button"
											class="flex flex-col items-center px-2.5 py-1.5 text-xs font-medium rounded-lg transition-colors"
											:class="filters.activePreset === 'business' ? 'bg-emerald-600 text-white' : 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 hover:bg-emerald-200'">
											<span>Business</span>
											<span class="text-[10px] opacity-75 font-mono" x-text="timePresets.business.start + '\u2192' + timePresets.business.end"></span>
										</button>
										<button @click="setTimePreset('evening')" type="button"
											class="flex flex-col items-center px-2.5 py-1.5 text-xs font-medium rounded-lg transition-colors"
											:class="filters.activePreset === 'evening' ? 'bg-orange-600 text-white' : 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 hover:bg-orange-200'">
											<span>Evening</span>
											<span class="text-[10px] opacity-75 font-mono" x-text="timePresets.evening.start + '\u2192' + timePresets.evening.end"></span>
										</button>
										<button @click="setTimePreset('night')" type="button"
											class="flex flex-col items-center px-2.5 py-1.5 text-xs font-medium rounded-lg transition-colors"
											:class="filters.activePreset === 'night' ? 'bg-indigo-600 text-white' : 'bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 hover:bg-indigo-200'">
											<span>Night</span>
											<span class="text-[10px] opacity-75 font-mono" x-text="timePresets.night.start + '\u2192' + timePresets.night.end"></span>
										</button>
									</div>
								</div>

								<!-- Weekend mode dropdown -->
								<div>
									<label class="block text-xs text-slate-500 dark:text-slate-400 mb-1">Weekends</label>
									<div class="relative">
										<select x-model="filters.weekendMode"
											:disabled="filters.activePreset === 'oncall'"
											class="w-full px-3 py-2 text-sm border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed appearance-none pr-8">
											<option value="exclude">Exclude weekends</option>
											<option value="same_hours">Same hours</option>
											<option value="full_weekends">Full weekends</option>
										</select>
										<svg class="absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
										</svg>
									</div>
									<!-- Tooltip for on-call lock -->
									<p x-show="filters.activePreset === 'oncall'" class="text-xs text-purple-600 dark:text-purple-400 mt-1">
										On-call includes full weekends by design
									</p>
									<!-- Tooltips for each option -->
									<p x-show="filters.activePreset !== 'oncall'" class="text-xs text-slate-400 dark:text-slate-500 mt-1">
										<span x-show="filters.weekendMode === 'exclude'">Saturday and Sunday are excluded</span>
										<span x-show="filters.weekendMode === 'same_hours'">Same time filter applies to weekends</span>
										<span x-show="filters.weekendMode === 'full_weekends'">Include all 24 hours on Sat/Sun</span>
									</p>
								</div>
							</div>

							<!-- Reset button when not default -->
							<div x-show="isTimeFilterActive()" class="border-t border-slate-100 dark:border-slate-700 p-2">
								<button @click="resetTimeFilter()" class="w-full px-3 py-1.5 text-xs text-slate-500 dark:text-slate-300 hover:text-slate-700 dark:hover:text-slate-200 text-center">
									Reset to default
								</button>
							</div>
						</div>
					</div>
				</div>

				<!-- Divider -->
				<div class="w-px h-8 bg-slate-200 dark:bg-slate-700"></div>

				<!-- Data Filters Group -->
				<div class="flex items-center gap-2 px-3 py-1.5 bg-amber-50 dark:bg-amber-900/20 rounded-xl border border-amber-100 dark:border-amber-800/30">
					<!-- Severity Filter -->
					<div class="relative" @click.outside="showSeverityDropdown = false; severitySearch = ''">
						<button @click="showSeverityDropdown = !showSeverityDropdown; if(showSeverityDropdown && availableSeverities.length === 0) loadAvailableSeverities()" type="button"
							class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-colors max-w-xs border border-amber-200 dark:border-amber-700/50"
							:class="filters.severities.length > 0 ? 'bg-amber-100 dark:bg-amber-800/40 text-amber-700 dark:text-amber-300 hover:bg-amber-200 dark:hover:bg-amber-800/60' : 'bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700'">
							<!-- When no filter -->
							<span x-show="filters.severities.length === 0" class="flex items-center gap-1">
								<span class="w-2 h-2 rounded-full bg-amber-400"></span>
								<span>All Severities</span>
							</span>
							<!-- When filtered - show chips -->
							<span x-show="filters.severities.length > 0" class="flex items-center gap-1.5">
								<template x-for="sev in filters.severities.slice(0, 2)" :key="sev">
									<span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium"
										:class="getSeverityChipClass(sev)">
										<span class="w-1.5 h-1.5 rounded-full" :style="'background-color: ' + getSeverityColor(sev)"></span>
										<span x-text="sev.charAt(0).toUpperCase() + sev.slice(1)"></span>
									</span>
								</template>
								<span x-show="filters.severities.length > 2" class="text-xs text-amber-600 dark:text-amber-400" x-text="'+' + (filters.severities.length - 2) + ' more'"></span>
							</span>
							<svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<div x-show="showSeverityDropdown" x-transition x-cloak class="absolute left-0 mt-2 w-56 bg-white dark:bg-dark-bg-secondary rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
							<div x-show="availableSeverities.length === 0" class="p-4 text-center text-sm text-slate-500 dark:text-slate-300">Loading severities...</div>
							<div x-show="availableSeverities.length > 0">
								<!-- Search input -->
								<div class="p-2 border-b border-slate-100 dark:border-slate-700">
									<input type="text" x-model="severitySearch" placeholder="Search..." class="w-full px-3 py-1.5 text-sm border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500"/>
								</div>
								<div class="max-h-48 overflow-y-auto p-2 space-y-1">
									<template x-for="severity in availableSeverities.filter(s => s.toLowerCase().includes(severitySearch.toLowerCase()))" :key="severity">
										<label class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 cursor-pointer">
											<input type="checkbox" :id="'severity-filter-' + severity" :name="'severity-filter-' + severity" :value="severity" x-model="filters.severities" @change="onFilterChange()" class="w-4 h-4 rounded border-slate-300 focus:ring-amber-500" :style="'color: ' + getSeverityColor(severity)"/>
											<span class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-200">
												<span class="w-3 h-3 rounded-full" :style="'background-color: ' + getSeverityColor(severity)"></span>
												<span x-text="severity.charAt(0).toUpperCase() + severity.slice(1)"></span>
											</span>
										</label>
									</template>
									<div x-show="availableSeverities.filter(s => s.toLowerCase().includes(severitySearch.toLowerCase())).length === 0" class="px-3 py-2 text-sm text-slate-400 dark:text-slate-500 text-center">No matches</div>
								</div>
							</div>
							<div x-show="filters.severities.length > 0" class="border-t border-slate-100 dark:border-slate-700 p-2">
								<button @click="filters.severities = []; onFilterChange(); showSeverityDropdown = false" class="w-full px-3 py-1.5 text-xs text-slate-500 dark:text-slate-300 hover:text-slate-700 dark:hover:text-slate-200 text-center">Clear</button>
							</div>
						</div>
					</div>

					<!-- Team Filter -->
					<div class="relative" @click.outside="showTeamDropdown = false; teamSearch = ''">
						<button @click="showTeamDropdown = !showTeamDropdown; if(showTeamDropdown && availableTeams.length === 0) loadAvailableTeams()" type="button"
							class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-colors max-w-xs border border-amber-200 dark:border-amber-700/50"
							:class="filters.teams.length > 0 ? 'bg-amber-100 dark:bg-amber-800/40 text-amber-700 dark:text-amber-300 hover:bg-amber-200 dark:hover:bg-amber-800/60' : 'bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700'">
							<!-- When no filter -->
							<span x-show="filters.teams.length === 0" class="flex items-center gap-1">
								<svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
								</svg>
								<span>All Teams</span>
							</span>
							<!-- When filtered - show team names -->
							<span x-show="filters.teams.length > 0" class="flex items-center gap-1.5">
								<template x-for="(team, idx) in filters.teams.slice(0, 2)" :key="team">
									<span class="inline-flex items-center px-1.5 py-0.5 bg-amber-200 dark:bg-amber-800/50 text-amber-800 dark:text-amber-200 rounded text-xs font-medium" x-text="team"></span>
								</template>
								<span x-show="filters.teams.length > 2" class="text-xs text-amber-600 dark:text-amber-400" x-text="'+' + (filters.teams.length - 2) + ' more'"></span>
							</span>
							<svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<div x-show="showTeamDropdown" x-transition x-cloak class="absolute left-0 mt-2 w-56 bg-white dark:bg-dark-bg-secondary rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
							<div x-show="availableTeams.length === 0" class="p-4 text-center text-sm text-slate-500 dark:text-slate-300">Loading teams...</div>
							<div x-show="availableTeams.length > 0">
								<!-- Search input -->
								<div class="p-2 border-b border-slate-100 dark:border-slate-700">
									<input type="text" x-model="teamSearch" placeholder="Search..." class="w-full px-3 py-1.5 text-sm border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500"/>
								</div>
								<div class="max-h-48 overflow-y-auto p-2 space-y-1">
									<template x-for="team in availableTeams.filter(t => t.toLowerCase().includes(teamSearch.toLowerCase()))" :key="team">
										<label class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 cursor-pointer">
											<input type="checkbox" :id="'team-filter-' + team" :name="'team-filter-' + team" :value="team" x-model="filters.teams" @change="onFilterChange()" class="w-4 h-4 text-amber-600 rounded border-slate-300 focus:ring-amber-500"/>
											<span class="text-sm text-slate-700 dark:text-slate-200" x-text="team"></span>
										</label>
									</template>
									<div x-show="availableTeams.filter(t => t.toLowerCase().includes(teamSearch.toLowerCase())).length === 0" class="px-3 py-2 text-sm text-slate-400 dark:text-slate-500 text-center">No matches</div>
								</div>
							</div>
							<div x-show="filters.teams.length > 0" class="border-t border-slate-100 dark:border-slate-700 p-2">
								<button @click="filters.teams = []; onFilterChange(); showTeamDropdown = false" class="w-full px-3 py-1.5 text-xs text-slate-500 dark:text-slate-300 hover:text-slate-700 dark:hover:text-slate-200 text-center">Clear</button>
							</div>
						</div>
					</div>
				</div>

				<!-- Divider -->
				<div class="w-px h-8 bg-slate-200 dark:bg-slate-700"></div>

				<!-- Analysis Group -->
				<div class="flex items-center gap-2 px-3 py-1.5 bg-emerald-50 dark:bg-emerald-900/20 rounded-xl border border-emerald-100 dark:border-emerald-800/30">
					<!-- Group By -->
					<div class="relative" x-data="{ groupOpen: false }">
						<button @click="groupOpen = !groupOpen" type="button"
							class="inline-flex items-center gap-2 px-4 py-2.5 bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-700 rounded-xl text-sm font-medium text-slate-700 dark:text-slate-200 transition-colors border border-emerald-200 dark:border-emerald-700/50">
							<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
							</svg>
							<span x-text="filters.groupBy ? 'By ' + getFilterGroupByLabel() : 'Overall'"></span>
							<svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<div x-show="groupOpen" @click.outside="groupOpen = false" x-transition x-cloak
							class="absolute left-0 mt-2 w-48 bg-white dark:bg-dark-bg-secondary rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
							<div class="p-1">
								<button @click="filters.groupBy = ''; groupOpen = false" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg" :class="{'bg-slate-100 dark:bg-slate-800': !filters.groupBy}">Overall</button>
								<button @click="filters.groupBy = 'severity'; groupOpen = false" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg" :class="{'bg-slate-100 dark:bg-slate-800': filters.groupBy === 'severity'}">
									<span class="w-2 h-2 rounded-full bg-gradient-to-r from-red-500 to-yellow-500"></span>Severity
								</button>
								<button @click="filters.groupBy = 'team'; groupOpen = false" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg" :class="{'bg-slate-100 dark:bg-slate-800': filters.groupBy === 'team'}">
									<span class="w-2 h-2 rounded-full bg-blue-500"></span>Team
								</button>
								<button @click="filters.groupBy = 'alert_name'; groupOpen = false" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg" :class="{'bg-slate-100 dark:bg-slate-800': filters.groupBy === 'alert_name'}">
									<span class="w-2 h-2 rounded-full bg-emerald-500"></span>Alert Name
								</button>
								<button @click="filters.groupBy = 'period'; groupOpen = false" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg" :class="{'bg-slate-100 dark:bg-slate-800': filters.groupBy === 'period'}">
									<span class="w-2 h-2 rounded-full bg-purple-500"></span>Time Period
								</button>
							</div>
						</div>
					</div>

					<!-- Period Type (when period grouping) -->
					<div x-show="filters.groupBy === 'period'" x-transition class="relative" x-data="{ periodOpen: false }">
						<button @click="periodOpen = !periodOpen" type="button"
							class="inline-flex items-center gap-2 px-4 py-2.5 bg-emerald-100 dark:bg-emerald-800/40 hover:bg-emerald-200 dark:hover:bg-emerald-800/60 rounded-xl text-sm font-medium text-emerald-700 dark:text-emerald-300 transition-colors border border-emerald-200 dark:border-emerald-700/50">
							<span x-text="filters.periodType === 'hour' ? 'Hourly' : filters.periodType === 'day' ? 'Daily' : filters.periodType === 'week' ? 'Weekly' : 'Monthly'"></span>
							<svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<div x-show="periodOpen" @click.outside="periodOpen = false" x-transition x-cloak
							class="absolute left-0 mt-2 w-36 bg-white dark:bg-dark-bg-secondary rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
							<div class="p-1">
								<button @click="filters.periodType = 'hour'; periodOpen = false" class="w-full px-3 py-2 text-sm text-left text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">Hourly</button>
								<button @click="filters.periodType = 'day'; periodOpen = false" class="w-full px-3 py-2 text-sm text-left text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">Daily</button>
								<button @click="filters.periodType = 'week'; periodOpen = false" class="w-full px-3 py-2 text-sm text-left text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">Weekly</button>
								<button @click="filters.periodType = 'month'; periodOpen = false" class="w-full px-3 py-2 text-sm text-left text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg">Monthly</button>
							</div>
						</div>
					</div>

					<!-- Top N (for alert_name) -->
					<div x-show="filters.groupBy === 'alert_name'" x-transition class="flex items-center gap-2">
						<span class="text-sm text-emerald-600 dark:text-emerald-400">Top</span>
						<input type="number" x-model.number="filters.limit" min="5" max="50" step="5"
							class="w-16 px-2 py-1.5 text-sm text-center bg-white dark:bg-slate-800 border border-emerald-200 dark:border-emerald-700/50 rounded-lg text-slate-700 dark:text-slate-200 focus:ring-2 focus:ring-emerald-500"/>
					</div>
				</div>

				<!-- Spacer -->
				<div class="flex-1"></div>

				<!-- Views Group - Next to Query -->
				<div class="flex items-center gap-2 px-3 py-1.5 bg-violet-50 dark:bg-violet-900/20 rounded-xl border border-violet-100 dark:border-violet-800/30">
					<div class="relative" x-data="{ viewsOpen: false }">
						<button @click="viewsOpen = !viewsOpen" type="button"
							class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
							:class="getActiveViewName() ? 'bg-violet-100 dark:bg-violet-800/50 text-violet-700 dark:text-violet-300' : 'bg-white/80 dark:bg-slate-800/80 text-slate-700 dark:text-slate-200 hover:bg-violet-100 dark:hover:bg-violet-800/30'">
							<svg class="w-4 h-4 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
							</svg>
							<span x-text="getActiveViewName() || 'Views'"></span>
							<svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
							</svg>
						</button>
						<!-- Dropdown -->
						<div x-show="viewsOpen" @click.outside="viewsOpen = false; viewSearchQuery = ''"
							x-transition:enter="transition ease-out duration-100"
							x-transition:enter-start="opacity-0 scale-95"
							x-transition:enter-end="opacity-100 scale-100"
							x-cloak
							x-data="{ viewsTab: 'global' }"
							class="absolute right-0 mt-2 w-80 bg-white dark:bg-dark-bg-secondary rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
							<!-- Save buttons row -->
							<div class="flex gap-1 p-2">
								<button @click="openSaveViewModal(null, true); viewsOpen = false; viewSearchQuery = ''"
									class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 text-xs font-medium rounded-lg border transition-colors
									border-emerald-200 dark:border-emerald-700/50 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20">
									<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
									Global
								</button>
								<button @click="openSaveViewModal(null, false); viewsOpen = false; viewSearchQuery = ''"
									class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 text-xs font-medium rounded-lg border transition-colors
									border-violet-200 dark:border-violet-700/50 text-violet-600 dark:text-violet-400 hover:bg-violet-50 dark:hover:bg-violet-900/20">
									<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
									Personal
								</button>
							</div>
							<!-- Tabs -->
							<div class="flex bg-slate-50 dark:bg-dark-bg-primary/50 mx-2 rounded-lg p-0.5 mb-2">
								<button @click="viewsTab = 'global'" type="button"
									class="flex-1 flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-md transition-all"
									:class="viewsTab === 'global' ? 'bg-white dark:bg-dark-bg-secondary shadow-sm text-emerald-600 dark:text-emerald-400' : 'text-slate-500 dark:text-slate-400 hover:text-slate-700'">
									<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
									Global
									<span class="text-[10px] px-1 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700/50" x-text="globalViews().length"></span>
								</button>
								<button @click="viewsTab = 'personal'" type="button"
									class="flex-1 flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-md transition-all"
									:class="viewsTab === 'personal' ? 'bg-white dark:bg-dark-bg-secondary shadow-sm text-violet-600 dark:text-violet-400' : 'text-slate-500 dark:text-slate-400 hover:text-slate-700'">
									<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
									</svg>
									Personal
									<span class="text-[10px] px-1 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700/50" x-text="personalViews().length"></span>
								</button>
							</div>
							<!-- Search -->
							<div class="px-2 pb-2" x-show="views.length > 0">
								<div class="relative">
									<svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
									</svg>
									<input type="text" x-model="viewSearchQuery" placeholder="Search views..."
										class="w-full pl-8 pr-3 py-1.5 text-xs border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-dark-bg-tertiary text-slate-700 dark:text-slate-200 focus:ring-1 focus:ring-violet-500 focus:border-violet-500 placeholder:text-slate-400"/>
								</div>
							</div>
							<div class="border-t border-slate-100 dark:border-slate-700"></div>
							<!-- Global Views tab -->
							<div x-show="viewsTab === 'global'">
								<div class="py-1 max-h-56 overflow-y-auto" x-show="filteredGlobalViews().length > 0">
									<template x-for="view in filteredGlobalViews()" :key="view.id">
										<div class="mx-1.5 mb-1 rounded-lg border transition-colors cursor-pointer"
											:class="isViewActive(view) ? 'border-violet-300 dark:border-violet-600 bg-violet-50/80 dark:bg-violet-900/20' : 'border-transparent hover:bg-slate-50 dark:hover:bg-slate-800/50'"
											@click="applyView(view); viewsOpen = false; viewSearchQuery = ''">
											<!-- Top row: name + active indicator -->
											<div class="flex items-center gap-2 px-3 pt-2.5 pb-1">
												<svg x-show="view.is_default" class="w-3.5 h-3.5 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
													<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
												</svg>
												<span x-text="view.name" class="text-sm font-medium text-slate-800 dark:text-slate-100 truncate flex-1"></span>
												<svg x-show="isViewActive(view)" class="w-4 h-4 text-violet-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
													<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
												</svg>
											</div>
											<!-- Description if present -->
											<div x-show="view.description" class="px-3 pb-1">
												<p x-text="view.description" class="text-[11px] text-slate-500 dark:text-slate-400 truncate"></p>
											</div>
											<!-- Action buttons row — always visible, owned views only for global -->
											<div x-show="view.user_id === currentUserId" class="flex items-center gap-0.5 px-2 pb-2 pt-0.5" @click.stop>
												<button @click="toggleDefaultView(view.id)"
													class="flex items-center gap-1 px-2 py-1 text-[11px] rounded-md transition-colors"
													:class="view.is_default ? 'text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20' : 'text-slate-400 hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-900/20'"
													:title="view.is_default ? 'Remove default' : 'Set as default'">
													<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
													<span x-text="view.is_default ? 'Default' : 'Set default'"></span>
												</button>
												<button @click="openSaveViewModal(view); viewsOpen = false; viewSearchQuery = ''"
													class="flex items-center gap-1 px-2 py-1 text-[11px] text-slate-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors">
													<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
													Edit
												</button>
												<button @click="deleteView(view.id)"
													class="flex items-center gap-1 px-2 py-1 text-[11px] text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-md transition-colors ml-auto">
													<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
													Delete
												</button>
											</div>
										</div>
									</template>
								</div>
								<div x-show="filteredGlobalViews().length === 0 && globalViews().length > 0" class="px-4 py-5 text-center text-xs text-slate-400 dark:text-slate-500">
									No matching views
								</div>
								<div x-show="globalViews().length === 0" class="px-4 py-6 text-center">
									<svg class="w-8 h-8 text-slate-300 dark:text-slate-600 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
									<p class="text-xs text-slate-400 dark:text-slate-500">No global views yet</p>
								</div>
							</div>
							<!-- Personal Views tab -->
							<div x-show="viewsTab === 'personal'">
								<div class="py-1 max-h-56 overflow-y-auto" x-show="filteredPersonalViews().length > 0">
									<template x-for="view in filteredPersonalViews()" :key="view.id">
										<div class="mx-1.5 mb-1 rounded-lg border transition-colors cursor-pointer"
											:class="isViewActive(view) ? 'border-violet-300 dark:border-violet-600 bg-violet-50/80 dark:bg-violet-900/20' : 'border-transparent hover:bg-slate-50 dark:hover:bg-slate-800/50'"
											@click="applyView(view); viewsOpen = false; viewSearchQuery = ''">
											<!-- Top row: name + active indicator -->
											<div class="flex items-center gap-2 px-3 pt-2.5 pb-1">
												<svg x-show="view.is_default" class="w-3.5 h-3.5 text-amber-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
													<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
												</svg>
												<span x-text="view.name" class="text-sm font-medium text-slate-800 dark:text-slate-100 truncate flex-1"></span>
												<svg x-show="isViewActive(view)" class="w-4 h-4 text-violet-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
													<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
												</svg>
											</div>
											<!-- Description if present -->
											<div x-show="view.description" class="px-3 pb-1">
												<p x-text="view.description" class="text-[11px] text-slate-500 dark:text-slate-400 truncate"></p>
											</div>
											<!-- Action buttons row — always visible -->
											<div class="flex items-center gap-0.5 px-2 pb-2 pt-0.5" @click.stop>
												<button @click="toggleDefaultView(view.id)"
													class="flex items-center gap-1 px-2 py-1 text-[11px] rounded-md transition-colors"
													:class="view.is_default ? 'text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20' : 'text-slate-400 hover:text-amber-500 hover:bg-amber-50 dark:hover:bg-amber-900/20'"
													:title="view.is_default ? 'Remove default' : 'Set as default'">
													<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
													<span x-text="view.is_default ? 'Default' : 'Set default'"></span>
												</button>
												<button @click="openSaveViewModal(view); viewsOpen = false; viewSearchQuery = ''"
													class="flex items-center gap-1 px-2 py-1 text-[11px] text-slate-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors">
													<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
													Edit
												</button>
												<button @click="deleteView(view.id)"
													class="flex items-center gap-1 px-2 py-1 text-[11px] text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-md transition-colors ml-auto">
													<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
													Delete
												</button>
											</div>
										</div>
									</template>
								</div>
								<div x-show="filteredPersonalViews().length === 0 && personalViews().length > 0" class="px-4 py-5 text-center text-xs text-slate-400 dark:text-slate-500">
									No matching views
								</div>
								<div x-show="personalViews().length === 0" class="px-4 py-6 text-center">
									<svg class="w-8 h-8 text-slate-300 dark:text-slate-600 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
									</svg>
									<p class="text-xs text-slate-400 dark:text-slate-500">No personal views yet</p>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Run Query Button -->
				<button @click="queryStatistics" :disabled="loading"
					class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 rounded-xl text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-900"
					:class="{ 'animate-query-pulse': needsQuery && !loading }">
					<svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
						<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
					</svg>
					<svg x-show="!loading" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
					</svg>
					<span x-text="loading ? 'Loading...' : 'Query'"></span>
				</button>
			</div>
		</div>

			<!-- Loading State -->
			<div x-show="loading && !hasData" class="flex flex-col items-center justify-center py-20 relative z-10">
				<div class="relative">
					<div class="w-16 h-16 border-4 border-slate-200 dark:border-slate-700 rounded-full"></div>
					<div class="absolute top-0 left-0 w-16 h-16 border-4 border-blue-500 rounded-full animate-spin border-t-transparent"></div>
				</div>
				<p class="mt-6 text-slate-500 dark:text-slate-400 font-medium">Loading statistics...</p>
			</div>

			<!-- Empty State -->
			<div x-show="!loading && !hasData" class="flex flex-col items-center justify-center py-20 bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 relative z-10">
				<div class="w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6">
					<svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
					</svg>
				</div>
				<h3 class="text-lg font-semibold text-slate-900 dark:text-white">No statistics yet</h3>
				<p class="mt-2 text-sm text-slate-500 dark:text-slate-400 text-center max-w-sm">
					Configure your time range and filters above, then click Query to analyze your alert data.
				</p>
			</div>

			<!-- Statistics Content -->
			<div x-show="!loading && hasData" class="relative z-10">
				<!-- Key Metrics Grid - Clean, Data-Forward Design -->
				<div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
					<!-- Total Alerts -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl p-5 border border-slate-200 dark:border-slate-700/50">
						<div class="flex items-center justify-between mb-3">
							<span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Total Alerts</span>
							<div class="w-8 h-8 bg-slate-100 dark:bg-slate-800 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-slate-600 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
								</svg>
							</div>
						</div>
						<div class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight" x-text="formatNumber(statsData?.total_alerts || 0)"></div>
					</div>

					<!-- MTTR -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl p-5 border border-slate-200 dark:border-slate-700/50 group relative">
						<div class="flex items-center justify-between mb-3">
							<span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Avg MTTR</span>
							<div class="w-8 h-8 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
							</div>
						</div>
						<div class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight" x-text="formatDuration(getOverallAvgMTTR())"></div>
						<!-- Tooltip -->
						<div class="absolute left-1/2 -translate-x-1/2 bottom-full mb-2 px-3 py-2 bg-slate-900 dark:bg-slate-700 text-white text-xs rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all whitespace-nowrap z-10">
							<strong>Mean Time To Resolve</strong><br/>Time from alert firing to resolution
							<div class="absolute left-1/2 -translate-x-1/2 top-full w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-slate-900 dark:border-t-slate-700"></div>
						</div>
					</div>

					<!-- MTTA -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl p-5 border border-slate-200 dark:border-slate-700/50 group relative">
						<div class="flex items-center justify-between mb-3">
							<span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Avg MTTA</span>
							<div class="w-8 h-8 bg-emerald-100 dark:bg-emerald-900/30 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
							</div>
						</div>
						<div class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight" x-text="formatTimeOrNA(getOverallAvgMTTA())"></div>
						<!-- Tooltip -->
						<div class="absolute left-1/2 -translate-x-1/2 bottom-full mb-2 px-3 py-2 bg-slate-900 dark:bg-slate-700 text-white text-xs rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all whitespace-nowrap z-10">
							<strong>Mean Time To Acknowledge</strong><br/>Time from firing to acknowledgment
							<div class="absolute left-1/2 -translate-x-1/2 top-full w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-slate-900 dark:border-t-slate-700"></div>
						</div>
					</div>

					<!-- Fix Time -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl p-5 border border-slate-200 dark:border-slate-700/50 group relative">
						<div class="flex items-center justify-between mb-3">
							<span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Avg Fix Time</span>
							<div class="w-8 h-8 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
								</svg>
							</div>
						</div>
						<div class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight" x-text="formatTimeOrNA(getOverallAvgFixTime())"></div>
						<!-- Tooltip -->
						<div class="absolute left-1/2 -translate-x-1/2 bottom-full mb-2 px-3 py-2 bg-slate-900 dark:bg-slate-700 text-white text-xs rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all whitespace-nowrap z-10">
							<strong>Fix Time</strong><br/>Time from acknowledgment to resolution
							<div class="absolute left-1/2 -translate-x-1/2 top-full w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-slate-900 dark:border-t-slate-700"></div>
						</div>
					</div>

					<!-- Time Range -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl p-5 border border-slate-200 dark:border-slate-700/50">
						<div class="flex items-center justify-between mb-3">
							<span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Period</span>
							<div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center">
								<svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
								</svg>
							</div>
						</div>
						<div class="text-sm font-semibold text-slate-900 dark:text-white" x-text="formatDate(statsData?.time_range?.start)"></div>
						<div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">to <span x-text="formatDate(statsData?.time_range?.end)"></span></div>
					</div>
				</div>

				<!-- Charts Section (hidden for period grouping - shows only Statistics by Time Period table instead) -->
				<div class="space-y-6 mb-6" x-show="appliedGroupBy !== 'period'">
					<!-- Alerts Over Time Chart -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden">
						<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50 flex items-center justify-between">
							<div class="flex items-center gap-3">
								<h3 class="text-base font-semibold text-slate-900 dark:text-white">Alerts Over Time</h3>
								<span x-show="appliedGroupBy" class="px-2 py-0.5 text-xs font-medium rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400" x-text="'by ' + getGroupByLabel()"></span>
								<!-- Period Type Selector -->
								<div class="relative" x-data="{ periodSelectorOpen: false }">
									<button @click="periodSelectorOpen = !periodSelectorOpen" type="button"
										class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-lg transition-colors"
										:class="filters.chartPeriodType ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700'">
										<span x-text="getPeriodTypeLabel(determinePeriodType())"></span>
										<svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
										</svg>
									</button>
									<div x-show="periodSelectorOpen" @click.outside="periodSelectorOpen = false" x-transition x-cloak
										class="absolute left-0 mt-1 w-40 bg-white dark:bg-dark-bg-secondary rounded-lg shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden z-50">
										<div class="p-1">
											<button @click="setChartPeriodType(null); periodSelectorOpen = false"
												class="w-full px-3 py-1.5 text-xs text-left rounded-md flex items-center justify-between"
												:class="!filters.chartPeriodType ? 'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-300' : 'text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800'">
												<span>Auto</span>
												<span class="text-[10px] px-1.5 py-0.5 rounded bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400" x-text="getPeriodTypeLabel(getRecommendedPeriodType())"></span>
											</button>
											<div class="h-px bg-slate-100 dark:bg-slate-700 my-1"></div>
											<template x-for="period in ['hour', 'day', 'week', 'month']" :key="period">
												<button @click="setChartPeriodType(period); periodSelectorOpen = false"
													class="w-full px-3 py-1.5 text-xs text-left rounded-md flex items-center justify-between"
													:class="filters.chartPeriodType === period ? 'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-300' : 'text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800'">
													<span x-text="getPeriodTypeLabel(period)"></span>
													<span x-show="period === getRecommendedPeriodType() && filters.chartPeriodType !== period"
														class="text-[10px] px-1.5 py-0.5 rounded bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">Recommended</span>
												</button>
											</template>
										</div>
									</div>
								</div>
							</div>
							<div class="flex items-center gap-3">
								<!-- Line visibility toggles -->
								<div x-show="appliedGroupBy && Object.keys(chartVisibility).length > 0" class="flex flex-wrap gap-1">
									<template x-for="(visible, key) in chartVisibility" :key="key">
										<button @click="toggleChartVisibility(key)"
											class="px-2.5 py-1 text-xs font-medium rounded-lg transition-all"
											:class="visible ? getVisibilityButtonClass(key, true) : 'bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-500'"
											x-text="key"></button>
									</template>
								</div>
								<!-- View toggle -->
								<div class="flex p-0.5 bg-slate-100 dark:bg-slate-800 rounded-lg" x-show="!appliedGroupBy">
									<button @click="timeSeriesView = 'fired'" :class="timeSeriesView === 'fired' ? 'bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-400'" class="px-3 py-1 text-xs font-medium rounded-md transition-all">Fired</button>
									<button @click="timeSeriesView = 'resolved'" :class="timeSeriesView === 'resolved' ? 'bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-400'" class="px-3 py-1 text-xs font-medium rounded-md transition-all">Resolved</button>
									<button @click="timeSeriesView = 'both'" :class="timeSeriesView === 'both' ? 'bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-400'" class="px-3 py-1 text-xs font-medium rounded-md transition-all">Both</button>
								</div>
								<button @click="openFullscreenChart('alertsTime')" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" title="Fullscreen">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
									</svg>
								</button>
							</div>
						</div>
						<div class="h-72 px-6 pb-6">
							<canvas id="alertsTimeChart" x-ref="alertsTimeChart"></canvas>
						</div>
					</div>

					<!-- Secondary Charts Row -->
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
						<!-- Distribution Chart -->
						<div x-show="appliedGroupBy" class="bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden flex flex-col">
							<!-- Header -->
							<div class="px-5 py-3.5 border-b border-slate-100 dark:border-slate-700/50">
								<div class="flex items-center justify-between">
									<!-- Title and count badge -->
									<div class="flex items-center gap-3">
										<h3 class="text-sm font-semibold text-slate-900 dark:text-white" x-text="getGroupByLabel() + ' Distribution'"></h3>
										<span x-show="distributionAllItems.length > 0"
											class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300"
											x-text="distributionAllItems.length + ' items'"></span>
									</div>
									<!-- Actions -->
									<div class="flex items-center gap-1.5">
										<!-- View toggle - segmented control -->
										<div x-show="distributionAllItems.length > 0" class="flex p-0.5 bg-slate-100 dark:bg-slate-800 rounded-lg">
											<button @click="showDistributionList = false"
												class="flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-md transition-all"
												:class="!showDistributionList ? 'bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'"
												title="Chart view">
												<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
												</svg>
												<span class="hidden sm:inline">Chart</span>
											</button>
											<button @click="showDistributionList = true"
												class="flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-md transition-all"
												:class="showDistributionList ? 'bg-white dark:bg-slate-700 shadow-sm text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300'"
												title="List view">
												<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
												</svg>
												<span class="hidden sm:inline">List</span>
											</button>
										</div>
										<!-- Fullscreen button -->
										<button @click="openFullscreenChart('distribution')" class="p-1.5 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" title="Fullscreen">
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
											</svg>
										</button>
									</div>
								</div>
							</div>

							<!-- Chart view -->
							<div x-show="!showDistributionList" class="h-64 p-4 flex items-center justify-center relative">
								<!-- Empty state -->
								<div x-show="distributionAllItems.length === 0" class="text-center py-8">
									<svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
									</svg>
									<p class="text-sm text-slate-500 dark:text-slate-400">No distribution data</p>
								</div>
								<!-- Chart canvas -->
								<div x-show="distributionAllItems.length > 0" class="w-full max-w-[200px]">
									<canvas id="distributionChart" x-ref="distributionChart"></canvas>
								</div>
								<!-- Click hint overlay (shows briefly on first load) -->
								<div x-show="distributionAllItems.length > 0" class="absolute bottom-3 left-0 right-0 text-center pointer-events-none">
									<span class="inline-flex items-center gap-1 px-2 py-1 text-xs text-slate-500 dark:text-slate-400 bg-white/80 dark:bg-slate-800/80 rounded-full backdrop-blur-sm">
										<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/>
										</svg>
										Click segments to filter
									</span>
								</div>
							</div>

							<!-- List view (scrollable) -->
							<div x-show="showDistributionList" class="flex-1 overflow-hidden">
								<!-- List header hint -->
								<div class="px-4 py-2 bg-slate-50 dark:bg-slate-800/50 border-b border-slate-100 dark:border-slate-700/30 flex items-center justify-between">
									<span class="text-xs text-slate-500 dark:text-slate-400 flex items-center gap-1.5">
										<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/>
										</svg>
										Click items to toggle visibility in charts
									</span>
									<span x-show="Object.values(chartVisibility).some(v => v === false)"
										class="text-xs text-indigo-600 dark:text-indigo-400 font-medium">
										<span x-text="Object.values(chartVisibility).filter(v => v === false).length"></span> hidden
									</span>
								</div>
								<div class="h-56 overflow-y-auto">
									<!-- Top N items section -->
									<div class="px-3 py-2">
										<template x-for="(item, index) in distributionAllItems.slice(0, distributionTopN)" :key="item.label">
											<div
												@click="toggleChartVisibility(item.label)"
												class="flex items-center gap-3 py-2 px-2.5 rounded-lg cursor-pointer transition-all group"
												:class="chartVisibility[item.label] === false
													? 'bg-slate-50 dark:bg-slate-800/30 opacity-60'
													: 'hover:bg-slate-50 dark:hover:bg-slate-800/50'"
											>
												<!-- Color indicator with checkbox-like visual -->
												<div class="relative flex-shrink-0">
													<div class="w-3.5 h-3.5 rounded"
														:style="'background-color: ' + getDistributionItemColor(item.label, index)"
														:class="chartVisibility[item.label] === false ? 'opacity-40' : ''"></div>
													<!-- Strikethrough when hidden -->
													<div x-show="chartVisibility[item.label] === false"
														class="absolute inset-0 flex items-center justify-center">
														<div class="w-full h-0.5 bg-slate-400 dark:bg-slate-500 rotate-45"></div>
													</div>
												</div>
												<!-- Label -->
												<span class="flex-1 text-sm truncate"
													:class="chartVisibility[item.label] === false
														? 'text-slate-400 dark:text-slate-500 line-through'
														: 'text-slate-700 dark:text-slate-300'"
													x-text="item.label.charAt(0).toUpperCase() + item.label.slice(1)"></span>
												<!-- Count and percentage bar -->
												<div class="flex items-center gap-2 flex-shrink-0">
													<!-- Mini bar chart -->
													<div class="w-16 h-1.5 bg-slate-100 dark:bg-slate-700 rounded-full overflow-hidden hidden sm:block">
														<div class="h-full rounded-full transition-all"
															:style="'width: ' + (distributionAllItems[0]?.count > 0 ? (item.count / distributionAllItems[0].count * 100) : 0) + '%; background-color: ' + getDistributionItemColor(item.label, index)"
															:class="chartVisibility[item.label] === false ? 'opacity-40' : ''"></div>
													</div>
													<span class="text-sm font-medium tabular-nums w-14 text-right"
														:class="chartVisibility[item.label] === false
															? 'text-slate-400 dark:text-slate-500'
															: 'text-slate-900 dark:text-white'"
														x-text="item.count.toLocaleString()"></span>
													<span class="text-xs tabular-nums w-11 text-right"
														:class="chartVisibility[item.label] === false
															? 'text-slate-300 dark:text-slate-600'
															: 'text-slate-500 dark:text-slate-400'"
														x-text="(distributionTotal > 0 ? (item.count / distributionTotal * 100).toFixed(1) : '0.0') + '%'"></span>
												</div>
											</div>
										</template>
									</div>

									<!-- "Others" section separator -->
									<template x-if="distributionAllItems.length > distributionTopN">
										<div>
											<div class="mx-3 my-2 flex items-center gap-2">
												<div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
												<span class="text-xs font-medium text-slate-400 dark:text-slate-500 uppercase tracking-wider">
													Others (<span x-text="distributionAllItems.length - distributionTopN"></span> more)
												</span>
												<div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
											</div>
											<div class="px-3 pb-2">
												<template x-for="(item, index) in distributionAllItems.slice(distributionTopN)" :key="item.label">
													<div
														@click="toggleChartVisibility(item.label)"
														class="flex items-center gap-3 py-1.5 px-2.5 rounded-lg cursor-pointer transition-all group"
														:class="chartVisibility[item.label] === false
															? 'bg-slate-50 dark:bg-slate-800/30 opacity-60'
															: 'hover:bg-slate-50 dark:hover:bg-slate-800/50'"
													>
														<!-- Gray color indicator for "others" -->
														<div class="relative flex-shrink-0">
															<div class="w-2.5 h-2.5 rounded bg-slate-300 dark:bg-slate-600"
																:class="chartVisibility[item.label] === false ? 'opacity-40' : ''"></div>
															<div x-show="chartVisibility[item.label] === false"
																class="absolute inset-0 flex items-center justify-center">
																<div class="w-full h-0.5 bg-slate-400 dark:bg-slate-500 rotate-45"></div>
															</div>
														</div>
														<!-- Label (smaller for "others") -->
														<span class="flex-1 text-xs truncate"
															:class="chartVisibility[item.label] === false
																? 'text-slate-400 dark:text-slate-500 line-through'
																: 'text-slate-600 dark:text-slate-400'"
															x-text="item.label.charAt(0).toUpperCase() + item.label.slice(1)"></span>
														<!-- Count only for "others" (more compact) -->
														<div class="flex items-center gap-2 flex-shrink-0">
															<span class="text-xs font-medium tabular-nums"
																:class="chartVisibility[item.label] === false
																	? 'text-slate-400 dark:text-slate-500'
																	: 'text-slate-700 dark:text-slate-300'"
																x-text="item.count.toLocaleString()"></span>
															<span class="text-xs tabular-nums w-10 text-right"
																:class="chartVisibility[item.label] === false
																	? 'text-slate-300 dark:text-slate-600'
																	: 'text-slate-400 dark:text-slate-500'"
																x-text="(distributionTotal > 0 ? (item.count / distributionTotal * 100).toFixed(1) : '0.0') + '%'"></span>
														</div>
													</div>
												</template>
											</div>
										</div>
									</template>
								</div>
							</div>
						</div>

						<!-- Top Items Chart -->
						<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden">
							<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50 flex items-center justify-between">
								<h3 class="text-base font-semibold text-slate-900 dark:text-white" x-text="'Top 10 ' + (appliedGroupBy ? getGroupByLabel() : 'Alerts')"></h3>
								<div class="flex items-center gap-2">
									<span class="text-xs text-slate-500 dark:text-slate-300">Click to filter</span>
									<button @click="openFullscreenChart('topItems')" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" title="Fullscreen">
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
										</svg>
									</button>
								</div>
							</div>
							<div class="h-64 p-6">
								<canvas id="topItemsChart" x-ref="topItemsChart"></canvas>
							</div>
						</div>
					</div>

					<!-- Resolution Times Chart -->
					<div x-show="appliedGroupBy && Object.keys(statsData?.statistics || {}).length > 0" class="bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden">
						<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50 flex items-center justify-between">
							<div class="flex items-center gap-3">
								<h3 class="text-base font-semibold text-slate-900 dark:text-white">Resolution Times by <span x-text="getGroupByLabel()"></span></h3>
							</div>
							<div class="flex items-center gap-2">
								<span class="px-2 py-1 text-xs font-medium rounded-md bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300">MTTR</span>
								<span class="px-2 py-1 text-xs font-medium rounded-md bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300">MTTA</span>
								<span class="px-2 py-1 text-xs font-medium rounded-md bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300">Fix</span>
								<button @click="openFullscreenChart('timeMetrics')" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500" title="Fullscreen">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
									</svg>
								</button>
							</div>
						</div>
						<div class="h-80 p-6">
							<canvas id="timeMetricsChart"></canvas>
						</div>
					</div>
				</div>

				<!-- Comparison Panel -->
				<div x-show="comparisonMode && comparisonData" x-collapse class="mb-6">
					<div class="bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-50 dark:from-indigo-900/20 dark:via-purple-900/20 dark:to-pink-900/20 rounded-2xl border border-indigo-200/50 dark:border-indigo-800/50 p-6">
						<h3 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
							<svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
							</svg>
							Period Comparison
						</h3>
						<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
							<div class="bg-white/80 dark:bg-slate-800/50 backdrop-blur-sm rounded-xl p-4">
								<div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-1">Total Alerts</div>
								<div class="flex items-baseline gap-2">
									<span class="text-2xl font-bold text-slate-900 dark:text-white" x-text="formatNumber(statsData?.total_alerts || 0)"></span>
									<span class="text-sm font-medium" :class="getDeltaClass(comparisonData?.delta_alerts)" x-text="getDeltaText(comparisonData?.delta_alerts)"></span>
								</div>
								<div class="text-xs text-slate-400 mt-1" x-text="'vs ' + formatNumber(comparisonData?.previous_total || 0)"></div>
							</div>
							<div class="bg-white/80 dark:bg-slate-800/50 backdrop-blur-sm rounded-xl p-4">
								<div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-1">Avg MTTR</div>
								<div class="flex items-baseline gap-2">
									<span class="text-2xl font-bold text-slate-900 dark:text-white" x-text="formatDuration(getOverallAvgMTTR())"></span>
									<span class="text-sm font-medium" :class="getDeltaClass(comparisonData?.delta_mttr, true)" x-text="getDeltaText(comparisonData?.delta_mttr)"></span>
								</div>
							</div>
							<div class="bg-white/80 dark:bg-slate-800/50 backdrop-blur-sm rounded-xl p-4">
								<div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-1">Avg MTTA</div>
								<div class="flex items-baseline gap-2">
									<span class="text-2xl font-bold text-slate-900 dark:text-white" x-text="formatTimeOrNA(getOverallAvgMTTA())"></span>
									<span class="text-sm font-medium" :class="getDeltaClass(comparisonData?.delta_mtta, true)" x-text="getDeltaText(comparisonData?.delta_mtta)"></span>
								</div>
							</div>
							<div x-show="appliedGroupBy === 'severity' || appliedGroupBy === 'overall'" class="bg-white/80 dark:bg-slate-800/50 backdrop-blur-sm rounded-xl p-4">
								<div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-1">Critical</div>
								<div class="flex items-baseline gap-2">
									<span class="text-2xl font-bold text-red-600 dark:text-red-400" x-text="formatNumber(getCriticalCount())"></span>
									<span class="text-sm font-medium" :class="getDeltaClass(comparisonData?.delta_critical)" x-text="getDeltaText(comparisonData?.delta_critical)"></span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Data Tables -->
				<div class="space-y-6">
					<!-- Statistics by Group Table -->
					<div x-show="appliedGroupBy && appliedGroupBy !== 'period' && Object.keys(statsData?.statistics || {}).length > 0">
						<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden">
							<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50">
								<h3 class="text-base font-semibold text-slate-900 dark:text-white" x-text="getGroupByTitle()"></h3>
							</div>
							<div class="overflow-x-auto">
								<table class="min-w-full">
									<thead>
										<tr class="bg-slate-50 dark:bg-slate-800/50">
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												<button @click="sortBy('name')" class="flex items-center gap-1 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
													<span x-text="appliedGroupBy || 'Category'"></span>
													<span x-html="getSortIcon('name')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												<button @click="sortBy('count')" class="flex items-center gap-1 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
													<span>Count</span>
													<span x-html="getSortIcon('count')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												%
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												<button @click="sortBy('avg_mttr')" class="flex items-center gap-1 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
													<span>MTTR</span>
													<span x-html="getSortIcon('avg_mttr')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												<button @click="sortBy('total_mttr')" class="flex items-center gap-1 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
													<span>Total MTTR</span>
													<span x-html="getSortIcon('total_mttr')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												<button @click="sortBy('avg_mtta')" class="flex items-center gap-1 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
													<span>MTTA</span>
													<span x-html="getSortIcon('avg_mtta')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">
												<button @click="sortBy('avg_fix_time')" class="flex items-center gap-1 hover:text-slate-700 dark:hover:text-slate-200 transition-colors">
													<span>Fix</span>
													<span x-html="getSortIcon('avg_fix_time')"></span>
												</button>
											</th>
										</tr>
									</thead>
									<tbody class="divide-y divide-slate-100 dark:divide-slate-700/50">
										<template x-for="[key, stat] in getSortedStatistics()" :key="key">
											<tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors"
												:class="appliedGroupBy === 'alert_name' ? 'cursor-pointer' : ''"
												@click="appliedGroupBy === 'alert_name' && openAlertDetailsModal(key)">
												<td class="px-6 py-4 whitespace-nowrap">
													<div class="flex items-center gap-2">
														<span class="text-sm font-medium text-slate-900 dark:text-white" x-text="key" :class="getSeverityClass(key)"></span>
														<svg x-show="appliedGroupBy === 'alert_name'" class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
															<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
														</svg>
													</div>
												</td>
												<td class="px-6 py-4 whitespace-nowrap">
													<div class="flex items-center gap-3">
														<span class="text-sm font-semibold text-slate-900 dark:text-white tabular-nums" x-text="formatNumber(stat.count)"></span>
														<div class="w-24 h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
															<div class="h-full bg-blue-500 rounded-full transition-all duration-300" :style="`width: ${(stat.count / getMaxCount() * 100)}%`"></div>
														</div>
													</div>
												</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="getPercentage(stat.count) + '%'"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-300 font-medium" x-text="formatDuration(stat.avg_mttr_seconds)"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="formatDuration(stat.total_mttr_seconds)"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="formatTimeOrNA(stat.avg_mtta_seconds)"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="formatTimeOrNA(stat.avg_fix_time_seconds)"></td>
											</tr>
										</template>
									</tbody>
								</table>
							</div>
						</div>
					</div>

					<!-- Period Breakdown -->
					<div x-show="appliedGroupBy === 'period' && (statsData?.breakdown || []).length > 0">
						<div class="bg-white dark:bg-dark-bg-secondary rounded-2xl border border-slate-200 dark:border-slate-700/50 overflow-hidden">
							<div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50">
								<h3 class="text-base font-semibold text-slate-900 dark:text-white">Statistics by Time Period</h3>
							</div>
							<div class="p-6">
								<div class="space-y-3">
									<template x-for="(item, index) in (statsData?.breakdown || [])" :key="index">
										<div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 border-l-4 border-blue-500">
											<div class="flex items-center justify-between mb-2">
												<div>
													<div class="text-sm font-semibold text-slate-900 dark:text-white" x-text="item.period"></div>
													<div class="text-xs text-slate-500 dark:text-slate-400" x-text="formatDate(item.start_time) + ' - ' + formatDate(item.end_time)"></div>
												</div>
												<div class="text-right">
													<div class="text-xl font-bold text-slate-900 dark:text-white" x-text="formatNumber(item.total_count)"></div>
													<div class="text-xs text-slate-500 dark:text-slate-300">alerts</div>
												</div>
											</div>
											<div x-show="item.statistics && Object.keys(item.statistics).length > 0" class="mt-3 flex flex-wrap gap-2">
												<template x-for="(stat, severity) in item.statistics" :key="severity">
													<span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium" :class="getSeverityBadgeClass(severity)">
														<span x-text="severity + ': ' + stat.count"></span>
													</span>
												</template>
											</div>
										</div>
									</template>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</div>

		<!-- Alert Details Modal -->
		<div
			x-show="showAlertDetailsModal"
			x-cloak
			class="fixed inset-0 z-50 overflow-y-auto"
			@keydown.escape.window="closeAlertDetailsModal()"
		>
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<!-- Background overlay -->
				<div
					x-show="showAlertDetailsModal"
					x-transition:enter="ease-out duration-300"
					x-transition:enter-start="opacity-0"
					x-transition:enter-end="opacity-100"
					x-transition:leave="ease-in duration-200"
					x-transition:leave-start="opacity-100"
					x-transition:leave-end="opacity-0"
					class="fixed inset-0 transition-opacity bg-slate-500 bg-opacity-75 dark:bg-slate-900 dark:bg-opacity-75"
					aria-hidden="true"
				></div>

				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>

				<!-- Modal panel -->
				<div
					x-show="showAlertDetailsModal"
					x-transition:enter="ease-out duration-300"
					x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
					x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
					x-transition:leave="ease-in duration-200"
					x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
					x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
					class="inline-block w-full max-w-5xl px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6 relative z-10"
					@click.stop
				>
					<!-- Header -->
					<div class="flex items-center justify-between mb-6">
						<div>
							<h3 class="text-lg font-medium text-slate-900 dark:text-white">Alert Occurrences</h3>
							<p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
								<span x-text="selectedAlertName"></span>
								<span class="mx-2">•</span>
								<span x-text="alertDetailsData?.length || 0"></span> occurrences
							</p>
						</div>
						<button @click="closeAlertDetailsModal()" class="text-slate-400 hover:text-slate-500 dark:hover:text-slate-300">
							<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
					</div>

					<!-- Loading State -->
					<div x-show="alertDetailsLoading" class="text-center py-12">
						<svg class="animate-spin h-8 w-8 text-blue-600 mx-auto" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Loading alert details...</p>
					</div>

					<!-- Alert List -->
					<div x-show="!alertDetailsLoading && alertDetailsData?.length > 0" class="max-h-[60vh] overflow-y-auto">
						<table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
							<thead class="bg-slate-50 dark:bg-dark-bg-tertiary sticky top-0">
								<tr>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Severity</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Fired At</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Resolved At</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">MTTR</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">MTTA</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Fix Time</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Labels</th>
								</tr>
							</thead>
							<tbody class="bg-white dark:bg-dark-bg-secondary divide-y divide-slate-200 dark:divide-slate-700">
								<template x-for="alert in alertDetailsData" :key="alert.id">
									<tr class="hover:bg-slate-50 dark:hover:bg-dark-bg-tertiary cursor-pointer transition-colors"
										@click.stop="openIndividualAlertDetails(alert)"
										title="Click to view full alert details">
										<td class="px-4 py-3 whitespace-nowrap">
											<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
												:class="{
													'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400': alert.severity === 'critical',
													'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400': alert.severity === 'warning',
													'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400': alert.severity === 'info'
												}"
												x-text="alert.severity">
											</span>
										</td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="formatDateTime(alert.fired_at)"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="alert.resolved_at ? formatDateTime(alert.resolved_at) : '—'"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="formatDuration(alert.mttr_seconds)"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="alert.mtta_seconds ? formatDuration(alert.mtta_seconds) : '—'"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400" x-text="alert.fix_time_seconds ? formatDuration(alert.fix_time_seconds) : '—'"></td>
										<td class="px-4 py-3 text-sm text-slate-500 dark:text-slate-400">
											<div class="flex flex-wrap gap-1 max-w-xs">
												<template x-for="(value, key) in getAlertLabels(alert)" :key="key">
													<span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
														<span x-text="key + '=' + value"></span>
													</span>
												</template>
											</div>
										</td>
									</tr>
								</template>
							</tbody>
						</table>
					</div>

					<!-- Empty State -->
					<div x-show="!alertDetailsLoading && (!alertDetailsData || alertDetailsData.length === 0)" class="text-center py-12">
						<svg class="mx-auto h-12 w-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
						</svg>
						<p class="mt-2 text-sm text-slate-500 dark:text-slate-400">No alert occurrences found</p>
					</div>

					<!-- Footer -->
					<div class="mt-6 flex justify-end">
						<button
							@click="closeAlertDetailsModal()"
							class="px-4 py-2 border border-slate-300 dark:border-slate-600 shadow-sm text-sm font-medium rounded-md text-slate-700 dark:text-slate-200 bg-white dark:bg-dark-bg-tertiary hover:bg-slate-50 dark:hover:bg-dark-bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
						>
							Close
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Save View Modal -->
		<div x-show="showSaveViewModal" class="fixed inset-0 z-50 overflow-y-auto" x-cloak>
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<!-- Background overlay -->
				<div x-show="showSaveViewModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 transition-opacity bg-slate-500 bg-opacity-75 dark:bg-slate-900 dark:bg-opacity-75" @click="closeSaveViewModal()"></div>
				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
				<!-- Modal panel -->
				<div x-show="showSaveViewModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative z-10 inline-block w-full max-w-md px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6" @click.stop>
					<div class="mb-4">
						<h3 class="text-lg font-medium text-slate-900 dark:text-white" x-text="viewForm.isEditing ? 'Edit View' : (viewForm.isShared ? 'Save as Global View' : 'Save as Personal View')"></h3>
						<p class="mt-1 text-sm text-slate-500 dark:text-slate-400" x-text="viewForm.isShared ? 'This view will be visible to all users.' : 'Save your current filter configuration for quick access later.'"></p>
					</div>
					<div class="space-y-4">
						<div>
							<label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Name</label>
							<input type="text" x-model="viewForm.name" placeholder="e.g., Weekly Critical Alerts" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"/>
						</div>
						<div>
							<label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Description (optional)</label>
							<textarea x-model="viewForm.description" rows="2" placeholder="Brief description of this view..." class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"></textarea>
						</div>
					</div>
					<div class="mt-6 flex justify-end space-x-3">
						<button @click="closeSaveViewModal()" type="button" class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-200 bg-white dark:bg-dark-bg-tertiary border border-slate-300 dark:border-slate-600 rounded-md shadow-sm hover:bg-slate-50 dark:hover:bg-dark-bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
							Cancel
						</button>
						<button @click="saveView()" type="button" :disabled="!viewForm.name.trim()" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed">
							<span x-text="viewForm.isEditing ? 'Update View' : 'Save View'"></span>
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Individual Alert Details Modal (using shared component) -->
		@components.AlertModalReadonly("showAlertModal", "individualAlertLoading", "individualAlertData", "individualAlertOccurrences", "closeAlertModal()", "z-[60]")

		<!-- Fullscreen Chart Modal -->
		<div
			x-show="fullscreenChart"
			x-cloak
			class="fixed inset-0 z-50 overflow-hidden"
			@keydown.escape.window="closeFullscreenChart()"
		>
			<!-- Backdrop with blur -->
			<div
				x-show="fullscreenChart"
				x-transition:enter="transition ease-out duration-200"
				x-transition:enter-start="opacity-0"
				x-transition:enter-end="opacity-100"
				x-transition:leave="transition ease-in duration-150"
				x-transition:leave-start="opacity-100"
				x-transition:leave-end="opacity-0"
				class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm"
				@click="closeFullscreenChart()"
			></div>

			<!-- Modal Content -->
			<div
				x-show="fullscreenChart"
				x-transition:enter="transition ease-out duration-200"
				x-transition:enter-start="opacity-0 scale-95"
				x-transition:enter-end="opacity-100 scale-100"
				x-transition:leave="transition ease-in duration-150"
				x-transition:leave-start="opacity-100 scale-100"
				x-transition:leave-end="opacity-0 scale-95"
				class="relative h-full w-full flex flex-col"
			>
				<!-- Header -->
				<div class="flex items-center justify-between px-6 py-4 bg-white dark:bg-dark-bg-secondary border-b border-slate-200 dark:border-dark-border-subtle shadow-lg">
					<div class="flex items-center space-x-4">
						<h3 class="text-xl font-semibold text-slate-900 dark:text-white" x-text="getFullscreenChartTitle()"></h3>
						<!-- Legend badges for time metrics chart -->
						<template x-if="fullscreenChart === 'timeMetrics'">
							<div class="flex items-center space-x-2">
								<span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">MTTR</span>
								<span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">MTTA</span>
								<span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400">Fix Time</span>
							</div>
						</template>
					</div>
					<button @click="closeFullscreenChart()" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-dark-bg-tertiary" title="Close (Esc)">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
						</svg>
					</button>
				</div>
				<!-- Chart Container -->
				<div class="flex-1 min-h-0 p-8 bg-white dark:bg-dark-bg-secondary overflow-hidden">
					<canvas id="fullscreenChartCanvas" class="w-full h-full"></canvas>
				</div>
			</div>
		</div>
	</div>

	<script>
		function statisticsDashboardPage() {
			return {
				loading: false,
				hasData: false,
				needsQuery: true, // Show pulse effect when query button should be clicked
				statsData: null,
				sortColumn: 'count',
				sortDirection: 'desc',

				// Chart instances
				alertsTimeChart: null,
				distributionChart: null,
				topItemsChart: null,
				timeMetricsChart: null,

				// Chart state
				timeSeriesView: 'fired',
				timeSeriesData: null,
				topItemsData: null,
				distributionData: null,

				// Chart visibility toggles (for multi-line filtering)
				chartVisibility: {},

				// Stable color mapping for keys (ensures same key = same color across all charts)
				keyColorMap: {},

				// Applied filters (updated only when query runs)
				appliedGroupBy: '',

				// Comparison mode
				comparisonMode: false,
				comparisonData: null,

				// Fullscreen chart modal
				fullscreenChart: null,
				fullscreenChartInstance: null,

				// Alert details modal (by alert name)
				showAlertDetailsModal: false,
				alertDetailsLoading: false,
				alertDetailsData: null,
				selectedAlertName: '',

				// Individual alert details modal (simple modal)
				showAlertModal: false,
				individualAlertData: null,
				individualAlertLoading: false,
				individualAlertOccurrences: [],

				filters: {
					startDate: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0], // Last 7 days
					endDate: new Date().toISOString().split('T')[0], // Today
					groupBy: 'team',
					periodType: 'day',
					chartPeriodType: null, // null = auto, or 'hour'/'day'/'week'/'month' for manual override
					limit: 20,
					timeOfDayStart: '18:00',
					timeOfDayEnd: '08:00',
					timeOfDayStartRaw: '18:00',
					timeOfDayEndRaw: '08:00',
					weekendMode: 'full_weekends', // 'exclude' | 'same_hours' | 'full_weekends'
					activePreset: 'oncall', // null | 'oncall' | 'noon' | 'night' | 'business' | 'morning' | 'evening'
					severities: ['critical', 'critical-daytime'], // Multi-select: ['critical', 'warning', 'info']
					teams: [],       // Multi-select: ['team1', 'team2', ...]

					// New - time range picker UI state
					timeRangeMode: 'relative', // 'relative' | 'absolute'
					relativeFrom: { value: 7, unit: 'days', allTime: false },
					relativeUntil: { value: 0, unit: 'minutes', now: true },
					absoluteFromTime: '00:00',
					absoluteUntilTime: '23:59'
				},

				// Available options (loaded dynamically)
				availableTeams: [],
				availableSeverities: [],
				showSeverityDropdown: false,
				showTeamDropdown: false,
				severitySearch: '',
				teamSearch: '',

				// Time range picker state
				timeRangePickerOpen: false,
				timeRangePickerTab: 'relative', // 'relative' | 'absolute'
				// Temporary state while editing (applied on "Apply")
				tempFilters: null,

				// Group-by color coding for visual connection
				groupByColors: {
					'severity': { border: 'border-l-red-500', bg: 'bg-red-50/50 dark:bg-red-900/10', label: 'text-red-700 dark:text-red-400', ring: 'ring-red-500' },
					'team': { border: 'border-l-blue-500', bg: 'bg-blue-50/50 dark:bg-blue-900/10', label: 'text-blue-700 dark:text-blue-400', ring: 'ring-blue-500' },
					'alert_name': { border: 'border-l-green-500', bg: 'bg-green-50/50 dark:bg-green-900/10', label: 'text-green-700 dark:text-green-400', ring: 'ring-green-500' },
					'period': { border: 'border-l-purple-500', bg: 'bg-purple-50/50 dark:bg-purple-900/10', label: 'text-purple-700 dark:text-purple-400', ring: 'ring-purple-500' },
					'': { border: 'border-l-gray-300 dark:border-l-gray-600', bg: 'bg-white dark:bg-dark-bg-secondary', label: 'text-slate-700 dark:text-slate-300', ring: 'ring-slate-300' }
				},

				// Preset definitions with times for display (oncall is dynamic, others are static)
				timePresets: {
					night: { start: '22:00', end: '06:00', label: 'Night' },
					business: { start: '09:00', end: '18:00', label: 'Business' },
					morning: { start: '06:00', end: '12:00', label: 'Morning' },
					noon: { start: '12:00', end: '14:00', label: 'Noon' },
					evening: { start: '18:00', end: '22:00', label: 'Evening' }
				},

				// Get On-Call preset times dynamically from settings
				getOnCallPreset() {
					const schedule = this.getOnCallSchedule();
					return { start: schedule.weekdayStart, end: schedule.weekdayEnd, label: 'On-Call' };
				},

				getGroupByStyle(part) {
					const colors = this.groupByColors[this.appliedGroupBy] || this.groupByColors[''];
					return colors[part] || '';
				},

				getGroupByLabel() {
					const labels = { 'severity': 'Severity', 'team': 'Team', 'alert_name': 'Alert Name', 'period': 'Time Period' };
					return labels[this.appliedGroupBy] || 'Overall';
				},

				// For the filter button - uses current selection, not applied value
				getFilterGroupByLabel() {
					const labels = { 'severity': 'Severity', 'team': 'Team', 'alert_name': 'Alert Name', 'period': 'Time Period' };
					return labels[this.filters.groupBy] || 'Overall';
				},

				// Quick time range presets for the new UI
				setQuickRange(preset) {
					const now = new Date();
					this.filters.timeRangeMode = 'relative';
					this.filters.relativeUntil = { value: 0, unit: 'minutes', now: true };

					switch(preset) {
						case '1h':
							this.filters.relativeFrom = { value: 1, unit: 'hours', allTime: false };
							break;
						case '24h':
							this.filters.relativeFrom = { value: 24, unit: 'hours', allTime: false };
							break;
						case '7d':
							this.filters.relativeFrom = { value: 7, unit: 'days', allTime: false };
							break;
						case '30d':
							this.filters.relativeFrom = { value: 30, unit: 'days', allTime: false };
							break;
						case '90d':
							this.filters.relativeFrom = { value: 90, unit: 'days', allTime: false };
							break;
					}

					// For sub-day presets, auto-set time-of-day filter to match the window
					// For day+ presets, clear time-of-day filter back to full day
					if (preset === '1h' || preset === '24h') {
						const hours = preset === '1h' ? 1 : 24;
						const tz = window.__USER_TIMEZONE__ || 'UTC';
						if (typeof dayjs !== 'undefined' && dayjs.tz) {
							const nowTz = dayjs().tz(tz);
							const fromTz = nowTz.subtract(hours, 'hour');
							this.filters.timeOfDayStart = fromTz.format('HH:mm');
							this.filters.timeOfDayEnd = nowTz.format('HH:mm');
						} else {
							const fromTime = new Date(now.getTime() - hours * 60 * 60 * 1000);
							this.filters.timeOfDayStart = String(fromTime.getHours()).padStart(2, '0') + ':' + String(fromTime.getMinutes()).padStart(2, '0');
							this.filters.timeOfDayEnd = String(now.getHours()).padStart(2, '0') + ':' + String(now.getMinutes()).padStart(2, '0');
						}
						this.filters.activePreset = null;
						this.timeOfDayStartRaw = this.filters.timeOfDayStart;
						this.timeOfDayEndRaw = this.filters.timeOfDayEnd;
					} else {
						this.filters.timeOfDayStart = '00:00';
						this.filters.timeOfDayEnd = '23:59';
						this.filters.activePreset = null;
						this.timeOfDayStartRaw = '00:00';
						this.timeOfDayEndRaw = '23:59';
					}

					// Apply the time range and close picker
					this.applyTimeRangeFromRelative();
					this.closeTimeRangePicker(true);
				},

				// Convert relative time settings to actual start/end dates
				applyTimeRangeFromRelative() {
					const now = new Date();

					// Validate and clamp values before applying
					if (!this.filters.relativeFrom.allTime) {
						const maxFrom = this.getMaxValueForUnit(this.filters.relativeFrom.unit);
						this.filters.relativeFrom.value = Math.min(Math.max(0, this.filters.relativeFrom.value || 0), maxFrom);
					}
					if (!this.filters.relativeUntil.now) {
						const maxUntil = this.getMaxValueForUnit(this.filters.relativeUntil.unit);
						this.filters.relativeUntil.value = Math.min(Math.max(0, this.filters.relativeUntil.value || 0), maxUntil);
					}

					// Calculate "From" date
					if (this.filters.relativeFrom.allTime) {
						// All time - set to a very old date
						this.filters.startDate = '2000-01-01';
					} else {
						const fromDate = new Date(now);
						const value = this.filters.relativeFrom.value || 0;
						const unit = this.filters.relativeFrom.unit || 'days';

						switch(unit) {
							case 'minutes':
								fromDate.setMinutes(fromDate.getMinutes() - value);
								break;
							case 'hours':
								fromDate.setHours(fromDate.getHours() - value);
								break;
							case 'days':
								fromDate.setDate(fromDate.getDate() - value);
								break;
							case 'weeks':
								fromDate.setDate(fromDate.getDate() - (value * 7));
								break;
							case 'months':
								fromDate.setMonth(fromDate.getMonth() - value);
								break;
						}
						this.filters.startDate = fromDate.toISOString().split('T')[0];
					}

					// Calculate "Until" date
					if (this.filters.relativeUntil.now) {
						this.filters.endDate = now.toISOString().split('T')[0];
					} else {
						const untilDate = new Date(now);
						const value = this.filters.relativeUntil.value || 0;
						const unit = this.filters.relativeUntil.unit || 'days';

						switch(unit) {
							case 'minutes':
								untilDate.setMinutes(untilDate.getMinutes() - value);
								break;
							case 'hours':
								untilDate.setHours(untilDate.getHours() - value);
								break;
							case 'days':
								untilDate.setDate(untilDate.getDate() - value);
								break;
							case 'weeks':
								untilDate.setDate(untilDate.getDate() - (value * 7));
								break;
							case 'months':
								untilDate.setMonth(untilDate.getMonth() - value);
								break;
						}
						this.filters.endDate = untilDate.toISOString().split('T')[0];
					}
				},

				// Format number with K/M suffix for large numbers
				formatNumber(num) {
					if (num === null || num === undefined) return '0';
					if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
					if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
					return num.toLocaleString();
				},

				initPage() {
					// Apply on-call preset from user's localStorage settings (overrides hardcoded 18:00/08:00)
					this.setTimePreset('oncall');

					// Watch for timeSeriesView changes
					this.$watch('timeSeriesView', () => {
						if (this.timeSeriesData) {
							this.updateTimeSeriesChart();
						}
					});
				},

				async queryStatistics() {
					this.loading = true;
					this.needsQuery = false; // Hide pulse effect

					try {
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							group_by: this.filters.groupBy,
							period_type: this.filters.periodType,
							limit: this.filters.groupBy === 'alert_name' ? this.filters.limit : 0,
							filter_by_time_of_day: this.isTimeFilterActive(),
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							weekend_mode: this.filters.weekendMode,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json'
							},
							body: JSON.stringify(payload)
						});

						if (!response.ok) {
							throw new Error('Failed to query statistics');
						}

						const data = await response.json();
						this.statsData = data.data;
						this.hasData = true;

						// Update applied groupBy (controls layout)
						this.appliedGroupBy = this.filters.groupBy;

						// Load additional chart data in parallel
						await Promise.all([
							this.loadTimeSeriesData(),
							this.loadTopItemsData(),
							this.loadDistributionData()
						]);

						// Build stable color mapping from all unique keys
						this.buildKeyColorMap();

						// Initialize chart visibility based on loaded data
						this.initChartVisibility();

						// Load comparison data if comparison mode is active
						if (this.comparisonMode) {
							await this.loadComparisonData();
						}
					} catch (error) {
						console.error('Error querying statistics:', error);
						alert('Failed to load statistics: ' + error.message);
						this.hasData = false;
					} finally {
						this.loading = false;
						// Update all charts after loading is complete and elements are visible
						// Use requestAnimationFrame to ensure DOM is ready for rendering
						if (this.hasData) {
							requestAnimationFrame(() => {
								requestAnimationFrame(() => {
									this.updateAllCharts();
								});
							});
						}
					}
				},

				setDateRange(preset) {
					const now = new Date();
					const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

					switch(preset) {
						case 'today':
							this.filters.startDate = today.toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'week':
							this.filters.startDate = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'month':
							this.filters.startDate = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'quarter':
							this.filters.startDate = new Date(today.getTime() - 90 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'past_month':
							// Get first and last day of previous month
							const firstOfCurrentMonth = new Date(today.getFullYear(), today.getMonth(), 1);
							const lastOfPrevMonth = new Date(firstOfCurrentMonth.getTime() - 1);
							const firstOfPrevMonth = new Date(lastOfPrevMonth.getFullYear(), lastOfPrevMonth.getMonth(), 1);
							this.filters.startDate = firstOfPrevMonth.toISOString().split('T')[0];
							this.filters.endDate = lastOfPrevMonth.toISOString().split('T')[0];
							break;
					}
				},

				setTimePreset(preset) {
					this.filters.activePreset = preset;

					switch(preset) {
						case 'oncall':
							const schedule = this.getOnCallSchedule();
							this.filters.timeOfDayStart = schedule.weekdayStart;
							this.filters.timeOfDayEnd = schedule.weekdayEnd;
							this.filters.weekendMode = 'full_weekends'; // Forced for on-call
							break;
						case 'night':
							this.filters.timeOfDayStart = '22:00';
							this.filters.timeOfDayEnd = '06:00';
							break;
						case 'business':
							this.filters.timeOfDayStart = '09:00';
							this.filters.timeOfDayEnd = '18:00';
							break;
						case 'morning':
							this.filters.timeOfDayStart = '06:00';
							this.filters.timeOfDayEnd = '12:00';
							break;
						case 'noon':
							this.filters.timeOfDayStart = '12:00';
							this.filters.timeOfDayEnd = '14:00';
							break;
						case 'evening':
							this.filters.timeOfDayStart = '18:00';
							this.filters.timeOfDayEnd = '22:00';
							break;
					}

					// Sync raw values
					this.timeOfDayStartRaw = this.filters.timeOfDayStart;
					this.timeOfDayEndRaw = this.filters.timeOfDayEnd;
				},

				getTimeOfDayButtonText() {
					const start = this.filters.timeOfDayStart;
					const end = this.filters.timeOfDayEnd;

					if (this.filters.activePreset) {
						const presetNames = {
							oncall: 'On-Call',
							night: 'Night',
							business: 'Business',
							morning: 'Morning',
							noon: 'Noon',
							evening: 'Evening'
						};
						return `${presetNames[this.filters.activePreset]} (${start} - ${end})`;
					}
					return `${start} - ${end}`;
				},

				isTimeFilterActive() {
					return this.filters.timeOfDayStart !== '00:00' ||
						   this.filters.timeOfDayEnd !== '23:59' ||
						   this.filters.weekendMode !== 'same_hours';
				},

				resetTimeFilter() {
					this.filters.timeOfDayStart = '00:00';
					this.filters.timeOfDayEnd = '23:59';
					this.filters.weekendMode = 'same_hours';
					this.filters.activePreset = null;
					// Sync raw values
					this.timeOfDayStartRaw = '00:00';
					this.timeOfDayEndRaw = '23:59';
				},

				// Time range picker helper functions
				formatTimeRangeDisplay() {
					let fromText, untilText;

					if (this.filters.timeRangeMode === 'relative') {
						if (this.filters.relativeFrom.allTime) {
							fromText = 'All Time';
						} else {
							const v = this.filters.relativeFrom.value;
							const u = this.filters.relativeFrom.unit;
							fromText = `${v} ${u} ago`;
						}

						if (this.filters.relativeUntil.now) {
							untilText = 'Now';
						} else {
							const v = this.filters.relativeUntil.value;
							const u = this.filters.relativeUntil.unit;
							untilText = `${v} ${u} ago`;
						}
					} else {
						// Absolute mode
						fromText = this.formatDateForDisplay(this.filters.startDate, this.filters.absoluteFromTime);
						if (this.filters.relativeUntil.now) {
							untilText = 'Now';
						} else {
							untilText = this.formatDateForDisplay(this.filters.endDate, this.filters.absoluteUntilTime);
						}
					}

					let display = `From: ${fromText}    Until: ${untilText}`;

					if (this.isTimeFilterActive()) {
						display += ` (${this.filters.timeOfDayStart}-${this.filters.timeOfDayEnd})`;
						if (this.filters.weekendMode === 'exclude') {
							display += ' [weekdays only]';
						} else if (this.filters.weekendMode === 'full_weekends') {
							display += ' [full weekends]';
						}
					}

					return display;
				},

				formatDateForDisplay(dateStr, timeStr) {
					const date = new Date(dateStr + 'T' + timeStr);
					const options = { month: 'short', day: 'numeric', year: 'numeric' };
					let result = date.toLocaleDateString('en-US', options);
					if (timeStr && timeStr !== '00:00') {
						result += ' ' + timeStr;
					}
					return result;
				},

				applyRelativeToAbsolute() {
					const now = new Date();

					// Validate and clamp values before applying
					if (!this.filters.relativeFrom.allTime) {
						const maxFrom = this.getMaxValueForUnit(this.filters.relativeFrom.unit);
						this.filters.relativeFrom.value = Math.min(Math.max(0, this.filters.relativeFrom.value || 0), maxFrom);
					}
					if (!this.filters.relativeUntil.now) {
						const maxUntil = this.getMaxValueForUnit(this.filters.relativeUntil.unit);
						this.filters.relativeUntil.value = Math.min(Math.max(0, this.filters.relativeUntil.value || 0), maxUntil);
					}

					// Calculate start date
					if (this.filters.relativeFrom.allTime) {
						// Set to a far past date
						this.filters.startDate = '2000-01-01';
					} else {
						const startDate = this.subtractTime(now, this.filters.relativeFrom.value, this.filters.relativeFrom.unit);
						this.filters.startDate = startDate.toISOString().split('T')[0];
					}

					// Calculate end date
					if (this.filters.relativeUntil.now) {
						this.filters.endDate = now.toISOString().split('T')[0];
					} else {
						const endDate = this.subtractTime(now, this.filters.relativeUntil.value, this.filters.relativeUntil.unit);
						this.filters.endDate = endDate.toISOString().split('T')[0];
					}
				},

				subtractTime(date, value, unit) {
					const result = new Date(date);
					switch(unit) {
						case 'minutes':
							result.setMinutes(result.getMinutes() - value);
							break;
						case 'hours':
							result.setHours(result.getHours() - value);
							break;
						case 'days':
							result.setDate(result.getDate() - value);
							break;
						case 'weeks':
							result.setDate(result.getDate() - (value * 7));
							break;
						case 'months':
							result.setMonth(result.getMonth() - value);
							break;
						case 'years':
							result.setFullYear(result.getFullYear() - value);
							break;
					}
					return result;
				},

				openTimeRangePicker() {
					// Save current state for cancel
					this.tempFilters = JSON.parse(JSON.stringify(this.filters));
					this.timeRangePickerOpen = true;
				},

				closeTimeRangePicker(apply = false) {
					if (apply) {
						if (this.filters.timeRangeMode === 'relative') {
							// If duration unit is days or more, reset hours filter to full day
							const unit = this.filters.relativeFrom.unit;
							const isDayOrMore = ['days', 'weeks', 'months', 'years'].includes(unit);
							if (isDayOrMore) {
								this.filters.timeOfDayStart = '00:00';
								this.filters.timeOfDayEnd = '23:59';
								this.filters.activePreset = null;
								this.filters.weekendMode = 'same_hours';
								this.timeOfDayStartRaw = '00:00';
								this.timeOfDayEndRaw = '23:59';
							}
							this.applyRelativeToAbsolute();
						} else {
							// Absolute mode - update endDate if "Now" is checked
							if (this.filters.relativeUntil.now) {
								this.filters.endDate = new Date().toISOString().split('T')[0];
							}
						}
					} else {
						if (this.tempFilters) {
							Object.assign(this.filters, this.tempFilters);
						}
					}
					this.tempFilters = null;
					this.timeRangePickerOpen = false;
				},

				incrementValue(field, delta) {
					const target = field === 'from' ? this.filters.relativeFrom : this.filters.relativeUntil;
					const maxVal = this.getMaxValueForUnit(target.unit);
					target.value = Math.min(Math.max(0, target.value + delta), maxVal);
				},

				// Get maximum allowed value based on time unit to prevent unreasonable date ranges
				getMaxValueForUnit(unit) {
					switch(unit) {
						case 'minutes': return 10080;  // 7 days in minutes
						case 'hours': return 8760;     // 1 year in hours
						case 'days': return 365;       // 1 year in days
						case 'weeks': return 104;      // 2 years in weeks
						case 'months': return 60;      // 5 years in months
						case 'years': return 10;       // 10 years max
						default: return 365;
					}
				},

				// On-Call Schedule helpers
				getOnCallSchedule() {
					const saved = localStorage.getItem('dashboardSettings');
					if (saved) {
						try {
							const settings = JSON.parse(saved);
							if (settings.onCallSchedule) {
								return {
									weekdayStart: settings.onCallSchedule.weekdayStart || '18:00',
									weekdayEnd: settings.onCallSchedule.weekdayEnd || '08:00',
									includeWeekends: settings.onCallSchedule.includeWeekends !== false
								};
							}
						} catch (e) {
							console.error('Error parsing on-call schedule:', e);
						}
					}
					// Default on-call schedule
					return { weekdayStart: '18:00', weekdayEnd: '08:00', includeWeekends: true };
				},

				getOnCallDescription() {
					const schedule = this.getOnCallSchedule();
					let desc = `${schedule.weekdayStart} - ${schedule.weekdayEnd} weekdays`;
					if (schedule.includeWeekends) {
						desc += ' + full weekends';
					}
					return desc;
				},

				// Parse flexible time input formats to HH:MM
				parseTimeInput(input) {
					if (!input || typeof input !== 'string') return null;

					const cleaned = input.replace(/[^0-9]/g, '');
					if (cleaned.length === 0) return null;

					let hours, minutes;

					if (cleaned.length <= 2) {
						// "9" → 09:00, "14" → 14:00
						hours = parseInt(cleaned, 10);
						minutes = 0;
					} else if (cleaned.length === 3) {
						// "902" → 09:02
						hours = parseInt(cleaned[0], 10);
						minutes = parseInt(cleaned.slice(1), 10);
					} else {
						// "0902" or "1430" → HH:MM
						hours = parseInt(cleaned.slice(0, 2), 10);
						minutes = parseInt(cleaned.slice(2, 4), 10);
					}

					// Validation
					if (isNaN(hours) || hours < 0 || hours > 23) return null;
					if (isNaN(minutes) || minutes < 0 || minutes > 59) return null;

					return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
				},

				// Validate input and update filter, show error if invalid
				validateAndSetTime(field, rawValue, inputId) {
					const parsed = this.parseTimeInput(rawValue);
					const inputEl = document.getElementById(inputId);

					if (parsed) {
						// Valid: update the filter and sync raw display value
						if (field === 'start') {
							this.filters.timeOfDayStart = parsed;
							this.timeOfDayStartRaw = parsed;
						} else {
							this.filters.timeOfDayEnd = parsed;
							this.timeOfDayEndRaw = parsed;
						}
						this.filters.activePreset = null;
						if (inputEl) inputEl.classList.remove('time-input-error');
					} else {
						// Invalid: show error animation, revert to last valid
						if (inputEl) {
							inputEl.classList.remove('time-input-error');
							// Force reflow to restart animation
							void inputEl.offsetWidth;
							inputEl.classList.add('time-input-error');
						}
						// Revert to last valid value after animation
						setTimeout(() => {
							if (field === 'start') {
								this.timeOfDayStartRaw = this.filters.timeOfDayStart;
							} else {
								this.timeOfDayEndRaw = this.filters.timeOfDayEnd;
							}
							if (inputEl) inputEl.classList.remove('time-input-error');
						}, 300);
					}
				},

				// Get timeline segments for visualization (24 segments, one per hour)
				getTimelineSegments() {
					const startTime = this.filters.timeOfDayStart || '00:00';
					const endTime = this.filters.timeOfDayEnd || '23:59';

					const startHour = parseInt(startTime.split(':')[0], 10);
					const endHour = parseInt(endTime.split(':')[0], 10);
					const endMinute = parseInt(endTime.split(':')[1], 10);

					// Effective end hour (if minutes > 0, that hour is active)
					const effectiveEndHour = endMinute > 0 ? endHour : endHour - 1;

					const segments = [];
					for (let h = 0; h < 24; h++) {
						let active = false;

						if (startHour <= effectiveEndHour) {
							// Normal range (e.g., 09:00 - 18:00)
							active = h >= startHour && h <= effectiveEndHour;
						} else {
							// Overnight range (e.g., 22:00 - 06:00)
							active = h >= startHour || h <= effectiveEndHour;
						}

						segments.push({ hour: h, active });
					}
					return segments;
				},

				getGroupByTitle() {
					const titles = {
						'severity': 'Statistics by Severity',
						'team': 'Statistics by Team',
						'alert_name': 'Statistics by Alert Name',
						'': 'Overall Statistics'
					};
					return titles[this.appliedGroupBy] || 'Statistics';
				},

				getOverallAvgMTTR() {
					if (!this.statsData?.statistics) return 0;
					const stats = Object.values(this.statsData.statistics);
					if (stats.length === 0) return 0;
					const total = stats.reduce((sum, s) => sum + (s.avg_mttr_seconds || 0), 0);
					return total / stats.length;
				},

				getOverallAvgMTTA() {
					if (!this.statsData?.statistics) return 0;
					const stats = Object.values(this.statsData.statistics);
					if (stats.length === 0) return 0;
					const total = stats.reduce((sum, s) => sum + (s.avg_mtta_seconds || 0), 0);
					return total / stats.length;
				},

				getOverallAvgFixTime() {
					if (!this.statsData?.statistics) return 0;
					const stats = Object.values(this.statsData.statistics);
					if (stats.length === 0) return 0;
					const total = stats.reduce((sum, s) => sum + (s.avg_fix_time_seconds || 0), 0);
					return total / stats.length;
				},

				getSeverityClass(severity) {
					if (this.appliedGroupBy !== 'severity') return '';

					const classes = {
						'critical': 'px-2 py-1 rounded text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
						'warning': 'px-2 py-1 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
						'info': 'px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400'
					};
					return classes[severity.toLowerCase()] || '';
				},

				getSeverityBadgeClass(severity) {
					const classes = {
						'critical': 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
						'warning': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
						'info': 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400'
					};
					return classes[severity.toLowerCase()] || 'bg-slate-100 text-slate-800 dark:bg-slate-800 dark:text-slate-300';
				},

				sortBy(column) {
					if (this.sortColumn === column) {
						// Toggle direction if same column
						this.sortDirection = this.sortDirection === 'asc' ? 'desc' : 'asc';
					} else {
						// New column, default to descending for numeric columns, ascending for text
						this.sortColumn = column;
						this.sortDirection = column === 'name' ? 'asc' : 'desc';
					}
				},

				getSortedStatistics() {
					if (!this.statsData?.statistics) return [];

					const entries = Object.entries(this.statsData.statistics);

					return entries.sort((a, b) => {
						const [keyA, statA] = a;
						const [keyB, statB] = b;

						let valueA, valueB;

						switch(this.sortColumn) {
							case 'name':
								valueA = keyA.toLowerCase();
								valueB = keyB.toLowerCase();
								break;
							case 'count':
								valueA = statA.count || 0;
								valueB = statB.count || 0;
								break;
							case 'avg_mttr':
								valueA = statA.avg_mttr_seconds || 0;
								valueB = statB.avg_mttr_seconds || 0;
								break;
							case 'total_mttr':
								valueA = statA.total_mttr_seconds || 0;
								valueB = statB.total_mttr_seconds || 0;
								break;
							case 'avg_mtta':
								valueA = statA.avg_mtta_seconds || 0;
								valueB = statB.avg_mtta_seconds || 0;
								break;
							case 'avg_fix_time':
								valueA = statA.avg_fix_time_seconds || 0;
								valueB = statB.avg_fix_time_seconds || 0;
								break;
							default:
								valueA = statA.count || 0;
								valueB = statB.count || 0;
						}

						if (valueA < valueB) return this.sortDirection === 'asc' ? -1 : 1;
						if (valueA > valueB) return this.sortDirection === 'asc' ? 1 : -1;
						return 0;
					});
				},

				getSortIcon(column) {
					if (this.sortColumn !== column) {
						return '<svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>';
					}

					if (this.sortDirection === 'asc') {
						return '<svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>';
					}

					return '<svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';
				},

				// Truncate label with ellipsis for chart display
				truncateLabel(text, maxLength) {
					if (!text) return '';
					if (text.length <= maxLength) return text;
					return text.substring(0, maxLength - 3) + '...';
				},

				formatDuration(seconds) {
					if (!seconds || seconds === 0) return '0s';

					const hours = Math.floor(seconds / 3600);
					const minutes = Math.floor((seconds % 3600) / 60);
					const secs = Math.floor(seconds % 60);

					const parts = [];
					if (hours > 0) parts.push(`${hours}h`);
					if (minutes > 0) parts.push(`${minutes}m`);
					if (secs > 0 || parts.length === 0) parts.push(`${secs}s`);

					return parts.join(' ');
				},

				formatMTTR(seconds) {
					if (!seconds || seconds === 0) return 'N/A';
					return this.formatDuration(seconds);
				},

				formatTimeOrNA(seconds) {
					if (!seconds || seconds === 0) return 'N/A';
					return this.formatDuration(seconds);
				},

				getPercentage(count) {
					if (!this.statsData?.total_alerts || this.statsData.total_alerts === 0) return 0;
					return (count / this.statsData.total_alerts * 100).toFixed(1);
				},

				getMaxCount() {
					if (!this.statsData?.statistics) return 0;
					const counts = Object.values(this.statsData.statistics).map(s => s.count || 0);
					return Math.max(...counts, 1);
				},

				formatDate(dateStr) {
					if (!dateStr) return '';
					const date = new Date(dateStr);
					return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
				},

				// ==================== Chart Methods ====================

				// Color palettes for different groupings
				chartColors: {
					severity: {
						// Standard severity levels
						'critical': { bg: '#dc2626', border: '#b91c1c' },  // Red
						'high': { bg: '#ea580c', border: '#c2410c' },     // Orange-red
						'error': { bg: '#ef4444', border: '#dc2626' },    // Lighter red
						'warning': { bg: '#f59e0b', border: '#d97706' },  // Amber
						'medium': { bg: '#eab308', border: '#ca8a04' },   // Yellow
						'low': { bg: '#22c55e', border: '#16a34a' },      // Green
						'info': { bg: '#3b82f6', border: '#2563eb' },     // Blue
						'debug': { bg: '#6b7280', border: '#4b5563' },    // Gray
						'notice': { bg: '#8b5cf6', border: '#7c3aed' }    // Purple
					},
					team: [
						{ bg: '#8b5cf6', border: '#7c3aed' },
						{ bg: '#06b6d4', border: '#0891b2' },
						{ bg: '#10b981', border: '#059669' },
						{ bg: '#f59e0b', border: '#d97706' },
						{ bg: '#ef4444', border: '#dc2626' },
						{ bg: '#ec4899', border: '#db2777' },
						{ bg: '#6366f1', border: '#4f46e5' },
						{ bg: '#14b8a6', border: '#0d9488' },
						{ bg: '#f97316', border: '#ea580c' },
						{ bg: '#84cc16', border: '#65a30d' }
					],
					default: [
						{ bg: '#3b82f6', border: '#2563eb' },
						{ bg: '#10b981', border: '#059669' },
						{ bg: '#f59e0b', border: '#d97706' },
						{ bg: '#ef4444', border: '#dc2626' },
						{ bg: '#8b5cf6', border: '#7c3aed' },
						{ bg: '#06b6d4', border: '#0891b2' },
						{ bg: '#ec4899', border: '#db2777' },
						{ bg: '#14b8a6', border: '#0d9488' },
						{ bg: '#f97316', border: '#ea580c' },
						{ bg: '#84cc16', border: '#65a30d' }
					]
				},

				// Build a stable color map from all unique keys across data sources
				// This ensures the same key always gets the same color in all charts
				buildKeyColorMap() {
					const allKeys = new Set();

					// Collect keys from distribution data
					if (this.distributionData) {
						Object.keys(this.distributionData).forEach(k => allKeys.add(k));
					}

					// Collect keys from top items data
					if (this.topItemsData) {
						Object.keys(this.topItemsData).forEach(k => allKeys.add(k));
					}

					// Collect keys from time series data (within each period's statistics)
					if (this.timeSeriesData) {
						this.timeSeriesData.forEach(item => {
							if (item.statistics) {
								Object.keys(item.statistics).forEach(k => allKeys.add(k));
							}
						});
					}

					// Sort keys alphabetically for stable ordering
					const sortedKeys = Array.from(allKeys).sort();

					// Build the color map
					this.keyColorMap = {};
					sortedKeys.forEach((key, index) => {
						this.keyColorMap[key] = index;
					});
				},

				getColorForKey(key, fallbackIndex = 0) {
					// For severity, use fixed semantic colors
					if (this.appliedGroupBy === 'severity') {
						return this.chartColors.severity[key.toLowerCase()] || this.chartColors.default[fallbackIndex % 10];
					}

					// For team and alert_name, use the stable color map
					const colorIndex = this.keyColorMap.hasOwnProperty(key)
						? this.keyColorMap[key]
						: fallbackIndex;

					if (this.appliedGroupBy === 'team') {
						return this.chartColors.team[colorIndex % 10];
					}
					return this.chartColors.default[colorIndex % 10];
				},

				async loadTimeSeriesData() {
					try {
						// Load period-based data with current groupBy for multi-line support
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							group_by: 'period',
							secondary_group_by: this.filters.groupBy || 'severity', // Break down by severity/team/alert_name within each period
							period_type: this.determinePeriodType(),
							filter_by_time_of_day: this.isTimeFilterActive(),
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							weekend_mode: this.filters.weekendMode,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.timeSeriesData = data.data?.breakdown || [];
						}
					} catch (error) {
						console.error('Failed to load time series data:', error);
					}
				},

				async loadTopItemsData() {
					try {
						// Load top items based on current groupBy (or alert_name if no groupBy)
						const groupBy = this.filters.groupBy || 'alert_name';
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							group_by: groupBy,
							limit: 10,
							filter_by_time_of_day: this.isTimeFilterActive(),
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							weekend_mode: this.filters.weekendMode,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.topItemsData = data.data?.statistics || {};
						}
					} catch (error) {
						console.error('Failed to load top items data:', error);
					}
				},

				async loadDistributionData() {
					try {
						// Only load if groupBy is set
						if (!this.filters.groupBy) {
							this.distributionData = null;
							return;
						}

						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							group_by: this.filters.groupBy,
							filter_by_time_of_day: this.isTimeFilterActive(),
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							weekend_mode: this.filters.weekendMode,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.distributionData = data.data?.statistics || {};
						}
					} catch (error) {
						console.error('Failed to load distribution data:', error);
					}
				},

				async loadAvailableTeams() {
					try {
						// Query team grouping to get list of available teams
						const payload = {
							start_date: new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString(), // Last 90 days
							end_date: new Date().toISOString(),
							group_by: 'team'
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							const teams = Object.keys(data.data?.statistics || {});
							this.availableTeams = teams.filter(t => t !== 'unknown').sort();
						}
					} catch (error) {
						console.error('Failed to load available teams:', error);
					}
				},

				async loadAvailableSeverities() {
					try {
						// Query severity grouping to get list of available severities
						const payload = {
							start_date: new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString(), // Last 90 days
							end_date: new Date().toISOString(),
							group_by: 'severity'
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							const severities = Object.keys(data.data?.statistics || {});
							this.availableSeverities = severities.filter(s => s !== 'unknown').sort();
						}
					} catch (error) {
						console.error('Failed to load available severities:', error);
					}
				},

				// Dynamic severity color mapping
				getSeverityColor(severity) {
					const colorMap = {
						'critical': '#ef4444',      // red-500
						'critical-daytime': '#f97316', // orange-500
						'warning': '#f59e0b',       // amber-500
						'info': '#3b82f6',          // blue-500
						'low': '#22c55e',           // green-500
						'debug': '#6b7280',         // gray-500
					};
					// Return mapped color or generate one based on string hash for unknown severities
					if (colorMap[severity.toLowerCase()]) {
						return colorMap[severity.toLowerCase()];
					}
					// Generate consistent color from string hash
					let hash = 0;
					for (let i = 0; i < severity.length; i++) {
						hash = severity.charCodeAt(i) + ((hash << 5) - hash);
					}
					const hue = Math.abs(hash % 360);
					return `hsl(${hue}, 70%, 50%)`;
				},

				getSeverityChipClass(severity) {
					const classMap = {
						'critical': 'bg-red-200 dark:bg-red-800/50 text-red-800 dark:text-red-200',
						'critical-daytime': 'bg-orange-200 dark:bg-orange-800/50 text-orange-800 dark:text-orange-200',
						'warning': 'bg-amber-200 dark:bg-amber-800/50 text-amber-800 dark:text-amber-200',
						'info': 'bg-blue-200 dark:bg-blue-800/50 text-blue-800 dark:text-blue-200',
						'low': 'bg-green-200 dark:bg-green-800/50 text-green-800 dark:text-green-200',
						'debug': 'bg-gray-200 dark:bg-gray-800/50 text-gray-800 dark:text-gray-200',
					};
					return classMap[severity.toLowerCase()] || 'bg-slate-200 dark:bg-slate-800/50 text-slate-800 dark:text-slate-200';
				},

				// Returns the recommended period type based on date range (used for auto-detection)
				getRecommendedPeriodType() {
					const start = new Date(this.filters.startDate);
					const end = new Date(this.filters.endDate);
					const days = (end - start) / (1000 * 60 * 60 * 24);

					if (days <= 1) return 'hour';
					if (days <= 14) return 'day';
					if (days <= 90) return 'week';
					return 'month';
				},

				// Returns the period type to use (user override or auto-detected)
				determinePeriodType() {
					if (this.filters.chartPeriodType) {
						return this.filters.chartPeriodType;
					}
					return this.getRecommendedPeriodType();
				},

				// Get label for period type
				getPeriodTypeLabel(type) {
					const labels = { hour: 'Hourly', day: 'Daily', week: 'Weekly', month: 'Monthly' };
					return labels[type] || type;
				},

				// Set chart period type and reload data
				setChartPeriodType(type) {
					this.filters.chartPeriodType = type;
					this.loadTrendData();
				},

				// Generate complete date range for chart display
				generateCompleteDateRange(startDate, endDate, periodType) {
					const periods = [];
					const start = new Date(startDate);
					const end = new Date(endDate);

					// Adjust start date based on period type
					let current = new Date(start);

					if (periodType === 'hour') {
						current.setMinutes(0, 0, 0);
					} else if (periodType === 'day') {
						current.setHours(0, 0, 0, 0);
					} else if (periodType === 'week') {
						// Start from beginning of the week (Monday)
						const day = current.getDay();
						const diff = current.getDate() - day + (day === 0 ? -6 : 1);
						current.setDate(diff);
						current.setHours(0, 0, 0, 0);
					} else if (periodType === 'month') {
						current.setDate(1);
						current.setHours(0, 0, 0, 0);
					}

					while (current <= end) {
						periods.push(this.formatPeriodKey(new Date(current), periodType));

						// Increment based on period type
						if (periodType === 'hour') {
							current.setHours(current.getHours() + 1);
						} else if (periodType === 'day') {
							current.setDate(current.getDate() + 1);
						} else if (periodType === 'week') {
							current.setDate(current.getDate() + 7);
						} else if (periodType === 'month') {
							current.setMonth(current.getMonth() + 1);
						}
					}

					return periods;
				},

				// Format date to match backend period format
				formatPeriodKey(date, periodType) {
					const year = date.getFullYear();
					const month = String(date.getMonth() + 1).padStart(2, '0');
					const day = String(date.getDate()).padStart(2, '0');
					const hour = String(date.getHours()).padStart(2, '0');

					if (periodType === 'hour') {
						return `${year}-${month}-${day}T${hour}:00`;
					} else if (periodType === 'day') {
						return `${year}-${month}-${day}`;
					} else if (periodType === 'week') {
						// Week format: YYYY-Www (ISO 8601)
						// ISO 8601: Week 1 is the week containing January 4th
						// (or equivalently, the week containing the first Thursday of the year)
						const target = new Date(date.valueOf());
						// Set to nearest Thursday: current date + 4 - current day number
						// Make Sunday day 7 instead of 0
						const dayNum = target.getDay() || 7;
						target.setDate(target.getDate() + 4 - dayNum);
						// Get first day of year
						const yearStart = new Date(target.getFullYear(), 0, 1);
						// Calculate full weeks to nearest Thursday
						const weekNum = Math.ceil((((target - yearStart) / 86400000) + 1) / 7);
						// The year for ISO week may differ from calendar year
						const isoYear = target.getFullYear();
						return `${isoYear}-W${String(weekNum).padStart(2, '0')}`;
					} else if (periodType === 'month') {
						return `${year}-${month}`;
					}
					return `${year}-${month}-${day}`;
				},

				// Fill missing periods with zero values
				fillMissingPeriods(timeData, startDate, endDate, periodType) {
					if (!startDate || !endDate) {
						return timeData || [];
					}

					const completePeriods = this.generateCompleteDateRange(startDate, endDate, periodType);
					const dataMap = new Map();

					// Create lookup map from existing data
					(timeData || []).forEach(item => {
						dataMap.set(item.period, item);
					});

					// Build complete dataset with zeros for missing periods
					return completePeriods.map(period => {
						if (dataMap.has(period)) {
							return dataMap.get(period);
						}
						// Return empty entry for missing period
						return {
							period: period,
							total_count: 0,
							resolved_count: 0,
							statistics: {}
						};
					});
				},

				// Initialize visibility toggles based on current data
				initChartVisibility() {
					if (!this.appliedGroupBy) {
						this.chartVisibility = {};
						return;
					}

					const data = this.distributionData || this.statsData?.statistics || {};
					const keys = Object.keys(data);
					this.chartVisibility = {};
					keys.forEach(key => {
						this.chartVisibility[key] = true;
					});
					if (keys.length > 1) {
						this.chartVisibility['Total'] = true;
					}
				},

				// Toggle visibility of a line in the chart
				toggleChartVisibility(key) {
					this.chartVisibility[key] = !this.chartVisibility[key];
					this.updateTimeSeriesChart();
				},

				// Get button class for visibility toggle
				getVisibilityButtonClass(key, active) {
					if (!active) return '';
					const index = Object.keys(this.chartVisibility).indexOf(key);
					const color = this.getColorForKey(key, index);
					return `border-2`;
				},

				updateAllCharts() {
					this.updateTimeSeriesChart();
					this.updateDistributionChart();
					this.updateTopItemsChart();
					this.updateTimeMetricsChart();
				},

				// Maximum items to show in doughnut chart before aggregating to "Others"
				distributionTopN: 10,
				// Store all distribution items for the list view
				distributionAllItems: [],
				// Cached total count for percentage calculations (computed in updateDistributionChart)
				distributionTotal: 0,
				// Show/hide the full distribution list
				showDistributionList: false,

				updateDistributionChart() {
					const canvas = document.getElementById('distributionChart');
					if (!canvas) return;

					const ctx = canvas.getContext('2d');
					if (!ctx) return;

					if (this.distributionChart) {
						this.distributionChart.destroy();
						this.distributionChart = null;
					}

					// Only show if groupBy is set
					if (!this.appliedGroupBy || !this.distributionData) return;

					const data = this.distributionData;
					const allLabels = Object.keys(data);

					// Handle empty data case
					if (allLabels.length === 0) {
						this.distributionAllItems = [];
						this.distributionTotal = 0;
						return;
					}

					// Sort all items by count (descending)
					const sortedItems = allLabels
						.map(label => ({
							label: label,
							count: data[label]?.count || 0
						}))
						.sort((a, b) => b.count - a.count);

					// Store all items for the list view
					this.distributionAllItems = sortedItems;

					const totalCount = sortedItems.reduce((sum, item) => sum + item.count, 0);
					// Cache total for percentage display in list view
					this.distributionTotal = totalCount;
					if (totalCount === 0) return;

					const isDark = document.documentElement.classList.contains('dark');

					// Prepare chart data with Top N + Others aggregation
					let chartLabels = [];
					let chartCounts = [];
					let chartColors = [];
					let originalLabels = []; // For click handling

					const topN = this.distributionTopN;

					if (sortedItems.length <= topN) {
						// No aggregation needed - show all items
						chartLabels = sortedItems.map(item => item.label.charAt(0).toUpperCase() + item.label.slice(1));
						chartCounts = sortedItems.map(item => item.count);
						chartColors = sortedItems.map((item, i) => this.getColorForKey(item.label, i).bg);
						originalLabels = sortedItems.map(item => item.label);
					} else {
						// Show top N items + aggregate the rest as "Others"
						const topItems = sortedItems.slice(0, topN);
						const otherItems = sortedItems.slice(topN);
						const othersCount = otherItems.reduce((sum, item) => sum + item.count, 0);
						const othersItemCount = otherItems.length;

						chartLabels = topItems.map(item => item.label.charAt(0).toUpperCase() + item.label.slice(1));
						chartLabels.push(`Others (${othersItemCount} items)`);

						chartCounts = topItems.map(item => item.count);
						chartCounts.push(othersCount);

						chartColors = topItems.map((item, i) => this.getColorForKey(item.label, i).bg);
						// Use gray color for "Others"
						chartColors.push('#9ca3af');

						originalLabels = topItems.map(item => item.label);
						originalLabels.push('__others__'); // Special marker for Others
					}

					this.distributionChart = new Chart(canvas, {
						type: 'doughnut',
						data: {
							labels: chartLabels,
							datasets: [{
								data: chartCounts,
								backgroundColor: chartColors,
								borderColor: isDark ? '#1f2937' : '#ffffff',
								borderWidth: 2
							}]
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							plugins: {
								legend: {
									display: false // Hide default legend, we'll show items in a list
								},
								tooltip: {
									callbacks: {
										label: (ctx) => {
											const value = ctx.raw || 0;
											const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
											const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
											if (originalLabels[ctx.dataIndex] === '__others__') {
												const othersItemCount = sortedItems.length - topN;
												return [`Others: ${value.toLocaleString()} (${percentage}%)`, `Aggregated from ${othersItemCount} items`];
											}
											return `${ctx.label}: ${value.toLocaleString()} (${percentage}%)`;
										}
									}
								}
							},
							onClick: (event, elements) => {
								if (elements.length > 0) {
									const index = elements[0].index;
									const key = originalLabels[index];
									if (key === '__others__') {
										// Show full list when clicking "Others"
										this.showDistributionList = true;
									} else {
										this.toggleChartVisibility(key);
									}
								}
							}
						}
					});
				},

				// Get color for distribution list item
				getDistributionItemColor(label, index) {
					if (index < this.distributionTopN) {
						return this.getColorForKey(label, index).bg;
					}
					return '#9ca3af'; // Gray for items beyond top N
				},

				// Toggle distribution list visibility
				toggleDistributionList() {
					this.showDistributionList = !this.showDistributionList;
				},

				updateTopItemsChart() {
					const canvas = document.getElementById('topItemsChart');
					if (!canvas) return;

					const ctx = canvas.getContext('2d');
					if (!ctx) return;

					if (this.topItemsChart) {
						this.topItemsChart.destroy();
						this.topItemsChart = null;
					}

					const itemData = this.topItemsData || {};
					const sortedItems = Object.entries(itemData)
						.sort((a, b) => (b[1]?.count || 0) - (a[1]?.count || 0))
						.slice(0, 10);

					// Handle empty data case
					if (sortedItems.length === 0) {
						return;
					}

					const labels = sortedItems.map(([name]) => this.truncateLabel(name, 30));
					const fullNames = sortedItems.map(([name]) => name);
					const counts = sortedItems.map(([, stat]) => stat?.count || 0);
					const backgroundColors = sortedItems.map(([name], i) => this.getColorForKey(name, i).bg);

					const isDark = document.documentElement.classList.contains('dark');

					this.topItemsChart = new Chart(canvas, {
						type: 'bar',
						data: {
							labels: labels,
							datasets: [{
								label: 'Count',
								data: counts,
								backgroundColor: backgroundColors,
								borderRadius: 4
							}]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							plugins: {
								legend: { display: false },
								tooltip: {
									callbacks: {
										title: (items) => fullNames[items[0].dataIndex]
									}
								}
							},
							scales: {
								x: {
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
								},
								y: {
									grid: { display: false },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
								}
							},
							onClick: (event, elements) => {
								if (elements.length > 0) {
									const index = elements[0].index;
									const itemName = fullNames[index];
									// Toggle visibility in time series if grouped
									if (this.appliedGroupBy && this.chartVisibility.hasOwnProperty(itemName)) {
										this.toggleChartVisibility(itemName);
									} else if (this.appliedGroupBy === 'alert_name' || !this.appliedGroupBy) {
										// Open alert details modal
										this.openAlertDetailsModal(itemName);
									}
								}
							}
						}
					});
				},

				updateTimeMetricsChart() {
					const canvas = document.getElementById('timeMetricsChart');
					if (!canvas) return;

					if (this.timeMetricsChart) {
						this.timeMetricsChart.destroy();
						this.timeMetricsChart = null;
					}

					// Only show when groupBy is set and not period
					if (!this.appliedGroupBy || this.appliedGroupBy === 'period' || !this.statsData?.statistics) {
						return;
					}

					const stats = this.statsData.statistics;
					const entries = Object.entries(stats)
						.sort((a, b) => (b[1].count || 0) - (a[1].count || 0))
						.slice(0, 10);

					if (entries.length === 0) return;

					const labels = entries.map(([k]) => this.truncateLabel(k, 25));
					const fullLabels = entries.map(([k]) => k);

					const mttrData = entries.map(([, v]) => v.avg_mttr_seconds || 0);
					const mttaData = entries.map(([, v]) => v.avg_mtta_seconds || 0);
					const fixTimeData = entries.map(([, v]) => v.avg_fix_time_seconds || 0);

					const isDark = document.documentElement.classList.contains('dark');
					const self = this;

					this.timeMetricsChart = new Chart(canvas, {
						type: 'bar',
						data: {
							labels: labels,
							datasets: [
								{
									label: 'MTTR',
									data: mttrData,
									backgroundColor: 'rgba(234, 179, 8, 0.8)',
									borderColor: '#eab308',
									borderWidth: 1
								},
								{
									label: 'MTTA',
									data: mttaData,
									backgroundColor: 'rgba(34, 197, 94, 0.8)',
									borderColor: '#22c55e',
									borderWidth: 1
								},
								{
									label: 'Fix Time',
									data: fixTimeData,
									backgroundColor: 'rgba(99, 102, 241, 0.8)',
									borderColor: '#6366f1',
									borderWidth: 1
								}
							]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							plugins: {
								legend: {
									position: 'top',
									labels: { color: isDark ? '#d1d5db' : '#374151' }
								},
								tooltip: {
									callbacks: {
										title: function(items) {
											return fullLabels[items[0].dataIndex];
										},
										label: function(ctx) {
											return ctx.dataset.label + ': ' + self.formatDuration(ctx.raw);
										}
									}
								}
							},
							scales: {
								x: {
									title: {
										display: true,
										text: 'Time (seconds)',
										color: isDark ? '#9ca3af' : '#6b7280'
									},
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								},
								y: {
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								}
							}
						}
					});
				},

				updateTimeSeriesChart() {
					const canvas = document.getElementById('alertsTimeChart');
					if (!canvas) return;

					const ctx = canvas.getContext('2d');
					if (!ctx) return;

					if (this.alertsTimeChart) {
						this.alertsTimeChart.destroy();
						this.alertsTimeChart = null;
					}

					const periodType = this.determinePeriodType();
					const filledData = this.fillMissingPeriods(
						this.timeSeriesData,
						this.filters.startDate,
						this.filters.endDate,
						periodType
					);

					// Handle empty data case
					if (!filledData || filledData.length === 0) return;

					const labels = filledData.map(item => this.formatPeriodLabel(item.period));
					const isDark = document.documentElement.classList.contains('dark');

					let datasets = [];

					if (this.appliedGroupBy && Object.keys(this.chartVisibility).length > 0) {
						// Multi-line mode: one line per groupBy value
						const keys = Object.keys(this.chartVisibility).filter(k => this.chartVisibility[k] && k !== 'Total');

						keys.forEach((key, index) => {
							const color = this.getColorForKey(key, Object.keys(this.chartVisibility).indexOf(key));
							datasets.push({
								label: key,
								data: filledData.map(item => {
									const stats = item.statistics || {};
									return stats[key]?.count || 0;
								}),
								borderColor: color.bg,
								backgroundColor: color.bg + '20',
								fill: false,
								tension: 0.3,
								borderWidth: 2,
								pointRadius: 3,
								pointHoverRadius: 5
							});
						});

						// Add Total line - sum of all visible series
						if (keys.length > 1 && this.chartVisibility['Total'] !== false) {
							const totalData = filledData.map(item => {
								const stats = item.statistics || {};
								return keys.reduce((sum, key) => sum + (stats[key]?.count || 0), 0);
							});
							datasets.push({
								label: 'Total',
								data: totalData,
								borderColor: isDark ? '#e5e7eb' : '#9ca3af',
								backgroundColor: 'transparent',
								fill: false,
								tension: 0.3,
								borderWidth: 3,
								pointRadius: 4,
								pointHoverRadius: 6,
								borderDash: [6, 3],
								order: -1 // Render on top of other lines
							});
						}
					} else {
						// Single line mode (Overall)
						if (this.timeSeriesView === 'fired' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Fired',
								data: filledData.map(item => item.total_count),
								borderColor: '#3b82f6',
								backgroundColor: 'rgba(59, 130, 246, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2
							});
						}

						if (this.timeSeriesView === 'resolved' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Resolved',
								data: filledData.map(item => {
									const stats = item.statistics || {};
									return Object.values(stats).reduce((sum, s) => sum + (s.count || 0), 0);
								}),
								borderColor: '#10b981',
								backgroundColor: 'rgba(16, 185, 129, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2,
								borderDash: this.timeSeriesView === 'both' ? [5, 5] : []
							});
						}
					}

					// Don't create chart if no datasets
					if (datasets.length === 0) return;

					this.alertsTimeChart = new Chart(canvas, {
						type: 'line',
						data: { labels, datasets },
						options: {
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							interaction: {
								intersect: false,
								mode: 'index'
							},
							plugins: {
								legend: {
									display: datasets.length > 1,
									position: 'top',
									labels: {
										color: isDark ? '#e5e7eb' : '#374151',
										usePointStyle: true,
										padding: 15
									},
									onClick: (e, legendItem, legend) => {
										if (this.appliedGroupBy) {
											const key = legendItem.text;
											this.toggleChartVisibility(key);
										} else {
											// Default Chart.js legend click behavior
											Chart.defaults.plugins.legend.onClick.call(this, e, legendItem, legend);
										}
									}
								},
								tooltip: {
									mode: 'index',
									intersect: false
								}
							},
							scales: {
								x: {
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									ticks: {
										color: isDark ? '#9ca3af' : '#6b7280',
										maxRotation: 45,
										minRotation: 0,
										maxTicksLimit: 15,
										autoSkip: true,
										autoSkipPadding: 10
									}
								},
								y: {
									beginAtZero: true,
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
								}
							}
						}
					});
				},

				formatPeriodLabel(period) {
					if (!period) return '';

					// Handle ISO week format (e.g., "2024-W05")
					const weekMatch = period.match(/^(\d{4})-W(\d{2})$/);
					if (weekMatch) {
						const year = parseInt(weekMatch[1], 10);
						const week = parseInt(weekMatch[2], 10);
						// Convert ISO week to a date (Monday of that week)
						const jan4 = new Date(year, 0, 4);
						const dayOfWeek = jan4.getDay() || 7;
						const firstMonday = new Date(jan4);
						firstMonday.setDate(jan4.getDate() - dayOfWeek + 1);
						const weekStart = new Date(firstMonday);
						weekStart.setDate(firstMonday.getDate() + (week - 1) * 7);
						return 'Week ' + week + ' (' + weekStart.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + ')';
					}

					// Handle month format (e.g., "2024-01")
					const monthMatch = period.match(/^(\d{4})-(\d{2})$/);
					if (monthMatch) {
						const year = parseInt(monthMatch[1], 10);
						const month = parseInt(monthMatch[2], 10) - 1; // JS months are 0-indexed
						const date = new Date(year, month, 1);
						return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
					}

					// Handle hour format (e.g., "2024-01-15T10:00") and day format (e.g., "2024-01-15")
					const date = new Date(period);
					if (isNaN(date.getTime())) {
						// Fallback: return the period as-is if parsing fails
						return period;
					}

					const days = (new Date(this.filters.endDate) - new Date(this.filters.startDate)) / (1000 * 60 * 60 * 24);

					if (days <= 1) {
						return date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
					} else {
						return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
					}
				},

				// ==================== Comparison Mode ====================

				async loadComparisonData() {
					if (!this.hasData) return;

					try {
						// Calculate previous period (same duration, shifted back)
						const start = new Date(this.filters.startDate);
						const end = new Date(this.filters.endDate);
						const duration = end - start;

						const prevEnd = new Date(start.getTime() - 1); // Day before current start
						const prevStart = new Date(prevEnd.getTime() - duration);

						const payload = {
							start_date: prevStart.toISOString(),
							end_date: prevEnd.toISOString(),
							group_by: 'severity',
							filter_by_time_of_day: this.isTimeFilterActive(),
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							weekend_mode: this.filters.weekendMode,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							const prevData = data.data;

							// Calculate deltas
							const currentTotal = this.statsData?.total_alerts || 0;
							const prevTotal = prevData?.total_alerts || 0;

							const currentMTTR = this.getOverallAvgMTTR();
							const prevMTTR = this.calculateMTTRFromStats(prevData?.statistics);

							const currentMTTA = this.getOverallAvgMTTA();
							const prevMTTA = this.calculateMTTAFromStats(prevData?.statistics);

							const currentCritical = this.getCriticalCount();
							const prevCritical = prevData?.statistics?.critical?.count || 0;

							this.comparisonData = {
								previous_total: prevTotal,
								delta_alerts: prevTotal > 0 ? ((currentTotal - prevTotal) / prevTotal * 100).toFixed(1) : 0,
								delta_mttr: prevMTTR > 0 ? ((currentMTTR - prevMTTR) / prevMTTR * 100).toFixed(1) : 0,
								delta_mtta: prevMTTA > 0 ? ((currentMTTA - prevMTTA) / prevMTTA * 100).toFixed(1) : 0,
								delta_critical: prevCritical > 0 ? ((currentCritical - prevCritical) / prevCritical * 100).toFixed(1) : 0
							};
						}
					} catch (error) {
						console.error('Failed to load comparison data:', error);
					}
				},

				calculateMTTRFromStats(stats) {
					if (!stats) return 0;
					const values = Object.values(stats);
					if (values.length === 0) return 0;
					return values.reduce((sum, s) => sum + (s.avg_mttr_seconds || 0), 0) / values.length;
				},

				calculateMTTAFromStats(stats) {
					if (!stats) return 0;
					const values = Object.values(stats);
					if (values.length === 0) return 0;
					return values.reduce((sum, s) => sum + (s.avg_mtta_seconds || 0), 0) / values.length;
				},

				getCriticalCount() {
					return this.statsData?.statistics?.critical?.count || 0;
				},

				getDeltaClass(delta, inverted = false) {
					const numDelta = parseFloat(delta);
					if (isNaN(numDelta) || numDelta === 0) return 'text-slate-500';

					// For inverted metrics (like duration/mttr), decrease is good
					const isGood = inverted ? numDelta < 0 : numDelta < 0;

					if (isGood) return 'text-green-600 dark:text-green-400';
					return 'text-red-600 dark:text-red-400';
				},

				getDeltaText(delta) {
					const numDelta = parseFloat(delta);
					if (isNaN(numDelta) || numDelta === 0) return '—';
					const sign = numDelta > 0 ? '↑' : '↓';
					return `${sign} ${Math.abs(numDelta)}%`;
				},

				// ==================== Alert Details Modal ====================

				async openAlertDetailsModal(alertName) {
					this.selectedAlertName = alertName;
					this.showAlertDetailsModal = true;
					this.alertDetailsLoading = true;
					this.alertDetailsData = null;

					try {
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							alert_name: alertName,
							filter_by_time_of_day: this.isTimeFilterActive(),
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							weekend_mode: this.filters.weekendMode,
							severities: this.filters.severities,
							teams: this.filters.teams,
							limit: 100
						};

						const response = await fetch('/api/v1/statistics/alerts-by-name', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.alertDetailsData = data.data?.alerts || [];
						} else {
							console.error('Failed to load alert details');
							this.alertDetailsData = [];
						}
					} catch (error) {
						console.error('Error loading alert details:', error);
						this.alertDetailsData = [];
					} finally {
						this.alertDetailsLoading = false;
					}
				},

				closeAlertDetailsModal() {
					this.showAlertDetailsModal = false;
					this.alertDetailsData = null;
					this.selectedAlertName = '';
				},

				// Fullscreen chart methods
				getFullscreenChartTitle() {
					const titles = {
						'alertsTime': 'Alerts Over Time' + (this.appliedGroupBy ? ' by ' + this.getGroupByLabel() : ''),
						'distribution': this.getGroupByLabel() + ' Distribution',
						'topItems': 'Top 10 ' + (this.appliedGroupBy ? this.getGroupByLabel() : 'Alerts'),
						'timeMetrics': 'Resolution Times by ' + this.getGroupByLabel()
					};
					return titles[this.fullscreenChart] || 'Chart';
				},

				openFullscreenChart(chartType) {
					this.fullscreenChart = chartType;
					// Wait for DOM to update and CSS transitions to complete, then render the chart
					this.$nextTick(() => {
						// First timeout to wait for modal transition to start
						setTimeout(() => {
							this.renderFullscreenChart();
							// Force resize after render to ensure proper canvas dimensions
							if (this.fullscreenChartInstance) {
								this.fullscreenChartInstance.resize();
								// Use requestAnimationFrame for additional resize after paint
								requestAnimationFrame(() => {
									if (this.fullscreenChartInstance) {
										this.fullscreenChartInstance.resize();
										this.fullscreenChartInstance.update('none');
									}
								});
							}
						}, 300);
					});
				},

				closeFullscreenChart() {
					if (this.fullscreenChartInstance) {
						this.fullscreenChartInstance.destroy();
						this.fullscreenChartInstance = null;
					}
					this.fullscreenChart = null;
				},

				renderFullscreenChart() {
					const canvas = document.getElementById('fullscreenChartCanvas');
					if (!canvas) return;

					if (this.fullscreenChartInstance) {
						this.fullscreenChartInstance.destroy();
					}

					const isDark = document.documentElement.classList.contains('dark');
					const self = this;

					switch (this.fullscreenChart) {
						case 'alertsTime':
							this.renderFullscreenTimeSeriesChart(canvas, isDark);
							break;
						case 'distribution':
							this.renderFullscreenDistributionChart(canvas, isDark);
							break;
						case 'topItems':
							this.renderFullscreenTopItemsChart(canvas, isDark);
							break;
						case 'timeMetrics':
							this.renderFullscreenTimeMetricsChart(canvas, isDark);
							break;
					}
				},

				renderFullscreenTimeSeriesChart(canvas, isDark) {
					const periodType = this.determinePeriodType();
					const filledData = this.fillMissingPeriods(
						this.timeSeriesData,
						this.filters.startDate,
						this.filters.endDate,
						periodType
					);

					// Handle empty data case
					if (!filledData || filledData.length === 0) return;

					const labels = filledData.map(item => this.formatPeriodLabel(item.period));
					let datasets = [];

					if (this.appliedGroupBy && Object.keys(this.chartVisibility).length > 0) {
						const keys = Object.keys(this.chartVisibility).filter(k => this.chartVisibility[k] && k !== 'Total');
						keys.forEach((key, index) => {
							const color = this.getColorForKey(key, Object.keys(this.chartVisibility).indexOf(key));
							datasets.push({
								label: key,
								data: filledData.map(item => (item.statistics || {})[key]?.count || 0),
								borderColor: color.bg,
								backgroundColor: color.bg + '20',
								fill: false,
								tension: 0.3,
								borderWidth: 2
							});
						});

						// Add Total line - sum of all visible series
						if (keys.length > 1 && this.chartVisibility['Total'] !== false) {
							const totalData = filledData.map(item => {
								const stats = item.statistics || {};
								return keys.reduce((sum, key) => sum + (stats[key]?.count || 0), 0);
							});
							datasets.push({
								label: 'Total',
								data: totalData,
								borderColor: isDark ? '#e5e7eb' : '#9ca3af',
								backgroundColor: 'transparent',
								fill: false,
								tension: 0.3,
								borderWidth: 3,
								pointRadius: 4,
								pointHoverRadius: 6,
								borderDash: [6, 3],
								order: -1 // Render on top of other lines
							});
						}
					} else {
						if (this.timeSeriesView === 'fired' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Fired',
								data: filledData.map(item => item.total_count),
								borderColor: '#3b82f6',
								backgroundColor: 'rgba(59, 130, 246, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2
							});
						}
						if (this.timeSeriesView === 'resolved' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Resolved',
								data: filledData.map(item => {
									const stats = item.statistics || {};
									return Object.values(stats).reduce((sum, s) => sum + (s.count || 0), 0);
								}),
								borderColor: '#22c55e',
								backgroundColor: 'rgba(34, 197, 94, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2
							});
						}
					}

					// Don't create chart if no datasets
					if (datasets.length === 0) return;

					// Calculate max value from all datasets for dynamic Y-axis scaling
					const allValues = datasets.flatMap(ds => ds.data || []);
					const maxValue = Math.max(...allValues.filter(v => typeof v === 'number' && !isNaN(v)), 0);
					// Add 10% padding to max value for better visualization
					const suggestedMax = maxValue > 0 ? Math.ceil(maxValue * 1.1) : undefined;

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'line',
						data: { labels, datasets },
						options: {
							responsive: true,
							maintainAspectRatio: false,
							interaction: {
								intersect: false,
								mode: 'index'
							},
							plugins: {
								legend: {
									position: 'top',
									labels: {
										color: isDark ? '#d1d5db' : '#374151',
										usePointStyle: true,
										padding: 15
									}
								},
								tooltip: {
									mode: 'index',
									intersect: false
								}
							},
							scales: {
								x: {
									ticks: {
										color: isDark ? '#9ca3af' : '#6b7280',
										maxTicksLimit: 20,
										autoSkip: true,
										maxRotation: 45
									},
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								},
								y: {
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									beginAtZero: true,
									suggestedMax: suggestedMax
								}
							}
						}
					});
				},

				renderFullscreenDistributionChart(canvas, isDark) {
					// Use distributionData if available, fallback to statsData.statistics
					const stats = this.distributionData || this.statsData?.statistics || {};
					const entries = Object.entries(stats).sort((a, b) => ((b[1]?.count || b[1] || 0)) - ((a[1]?.count || a[1] || 0)));

					if (entries.length === 0) return;

					// For fullscreen, show more items (top 20) with "Others" aggregation
					const fullscreenTopN = 20;
					let chartLabels = [];
					let chartData = [];
					let chartColors = [];
					let originalKeys = [];

					if (entries.length <= fullscreenTopN) {
						// No aggregation needed
						chartLabels = entries.map(([k]) => k.charAt(0).toUpperCase() + k.slice(1));
						chartData = entries.map(([, v]) => v?.count || v || 0);
						chartColors = entries.map(([k], i) => this.getColorForKey(k, i).bg);
						originalKeys = entries.map(([k]) => k);
					} else {
						// Show top N + aggregate the rest
						const topItems = entries.slice(0, fullscreenTopN);
						const otherItems = entries.slice(fullscreenTopN);
						const othersCount = otherItems.reduce((sum, [, v]) => sum + (v?.count || v || 0), 0);
						const othersItemCount = otherItems.length;

						chartLabels = topItems.map(([k]) => k.charAt(0).toUpperCase() + k.slice(1));
						chartLabels.push(`Others (${othersItemCount} items)`);

						chartData = topItems.map(([, v]) => v?.count || v || 0);
						chartData.push(othersCount);

						chartColors = topItems.map(([k], i) => this.getColorForKey(k, i).bg);
						chartColors.push('#9ca3af'); // Gray for Others

						originalKeys = topItems.map(([k]) => k);
						originalKeys.push('__others__');
					}

					const totalCount = chartData.reduce((a, b) => a + b, 0);
					const self = this;

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'doughnut',
						data: {
							labels: chartLabels,
							datasets: [{
								data: chartData,
								backgroundColor: chartColors,
								borderColor: isDark ? '#1f2937' : '#ffffff',
								borderWidth: 2
							}]
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: {
									position: 'right',
									labels: {
										color: isDark ? '#d1d5db' : '#374151',
										padding: 10,
										font: { size: 11 },
										// Custom label generation to handle many items
										generateLabels: (chart) => {
											const chartData = chart.data;
											return chartData.labels.map((label, i) => ({
												text: label.length > 25 ? label.substring(0, 25) + '...' : label,
												fillStyle: chartData.datasets[0].backgroundColor[i],
												hidden: false,
												index: i
											}));
										}
									}
								},
								tooltip: {
									callbacks: {
										label: (ctx) => {
											const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
											const percentage = total > 0 ? ((ctx.raw / total) * 100).toFixed(1) : 0;
											const key = originalKeys[ctx.dataIndex];
											if (key === '__others__') {
												const othersItemCount = entries.length - fullscreenTopN;
												return [`Others: ${ctx.raw.toLocaleString()} (${percentage}%)`, `Aggregated from ${othersItemCount} items`];
											}
											return `${ctx.label}: ${ctx.raw.toLocaleString()} (${percentage}%)`;
										}
									}
								}
							},
							onClick: (event, elements) => {
								if (elements.length > 0) {
									const index = elements[0].index;
									const key = originalKeys[index];
									if (key !== '__others__') {
										self.toggleChartVisibility(key);
									}
								}
							}
						}
					});
				},

				renderFullscreenTopItemsChart(canvas, isDark) {
					const stats = this.topItemsData || this.statsData?.statistics || {};
					const entries = Object.entries(stats).sort((a, b) => (b[1].count || 0) - (a[1].count || 0)).slice(0, 20);

					if (entries.length === 0) return;

					const fullNames = entries.map(([k]) => k);
					const labels = entries.map(([k]) => this.truncateLabel(k, 40));
					const data = entries.map(([, v]) => v.count || 0);
					const colors = entries.map(([k], i) => this.getColorForKey(k, i));
					const self = this;

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'bar',
						data: {
							labels,
							datasets: [{
								label: 'Count',
								data,
								backgroundColor: colors.map(c => c.bg + 'cc'),
								borderColor: colors.map(c => c.border),
								borderWidth: 1,
								borderRadius: 4
							}]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { display: false },
								tooltip: {
									callbacks: {
										title: (items) => fullNames[items[0].dataIndex],
										label: (ctx) => 'Count: ' + ctx.raw.toLocaleString()
									}
								}
							},
							scales: {
								x: {
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								},
								y: {
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { display: false }
								}
							},
							onClick: (event, elements) => {
								if (elements.length > 0) {
									const index = elements[0].index;
									const itemName = fullNames[index];
									if (self.appliedGroupBy === 'alert_name' || !self.appliedGroupBy) {
										self.closeFullscreenChart();
										self.openAlertDetailsModal(itemName);
									}
								}
							}
						}
					});
				},

				renderFullscreenTimeMetricsChart(canvas, isDark) {
					const stats = this.statsData?.statistics || {};
					const entries = Object.entries(stats).sort((a, b) => (b[1].count || 0) - (a[1].count || 0)).slice(0, 20);

					if (entries.length === 0) return;

					const fullLabels = entries.map(([k]) => k);
					const labels = entries.map(([k]) => this.truncateLabel(k, 35));
					const self = this;

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'bar',
						data: {
							labels,
							datasets: [
								{
									label: 'MTTR',
									data: entries.map(([, v]) => v.avg_mttr_seconds || 0),
									backgroundColor: 'rgba(234, 179, 8, 0.8)',
									borderColor: '#eab308',
									borderWidth: 1
								},
								{
									label: 'MTTA',
									data: entries.map(([, v]) => v.avg_mtta_seconds || 0),
									backgroundColor: 'rgba(34, 197, 94, 0.8)',
									borderColor: '#22c55e',
									borderWidth: 1
								},
								{
									label: 'Fix Time',
									data: entries.map(([, v]) => v.avg_fix_time_seconds || 0),
									backgroundColor: 'rgba(99, 102, 241, 0.8)',
									borderColor: '#6366f1',
									borderWidth: 1
								}
							]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { position: 'top', labels: { color: isDark ? '#d1d5db' : '#374151' } },
								tooltip: {
									callbacks: {
										title: (items) => fullLabels[items[0].dataIndex],
										label: function(ctx) {
											return ctx.dataset.label + ': ' + self.formatDuration(ctx.raw);
										}
									}
								}
							},
							scales: {
								x: {
									title: { display: true, text: 'Time (seconds)', color: isDark ? '#9ca3af' : '#6b7280' },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								},
								y: {
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { display: false }
								}
							}
						}
					});
				},

				// Open individual alert details modal
				async openIndividualAlertDetails(alert) {
					console.log('Opening alert details for:', alert);
					this.individualAlertLoading = true;
					this.showAlertModal = true;
					this.individualAlertData = null;
					this.individualAlertOccurrences = [];

					const fingerprint = alert.fingerprint;

					try {
						// Fetch statistics data for this alert
						const response = await fetch(`/api/v1/statistics/alert/${fingerprint}`, {
							credentials: 'include'
						});

						const result = await response.json();

						if (result.success && result.data) {
							this.individualAlertData = result.data.details;
							this.individualAlertOccurrences = result.data.occurrences || [];
						} else {
							console.error('Failed to load alert details:', result.error || 'Unknown error');
							this.closeAlertModal();
						}
					} catch (error) {
						console.error('Error loading alert details:', error);
						this.closeAlertModal();
					} finally {
						this.individualAlertLoading = false;
					}
				},

				// Close individual alert details modal
				closeAlertModal() {
					this.showAlertModal = false;
					this.individualAlertData = null;
					this.individualAlertOccurrences = [];
				},

	
				// Copy to clipboard
				copyToClipboard(text) {
					if (!text) return;
					navigator.clipboard.writeText(text).then(() => {
						// Success
					}).catch(err => {
						console.error('Failed to copy:', err);
					});
				},

				// Format alert date, handling Go zero dates
				formatAlertDate(dateStr) {
					if (!dateStr) return '—';
					const date = new Date(dateStr);
					// Check for Go zero time (0001-01-01T00:00:00Z) or invalid date
					if (isNaN(date.getTime()) || date.getFullYear() < 1970) {
						return '—';
					}
					return date.toLocaleString();
				},

				getAlertLabels(alert) {
					if (!alert.metadata) return {};
					try {
						const metadata = typeof alert.metadata === 'string' ? JSON.parse(alert.metadata) : alert.metadata;
						return metadata.labels || {};
					} catch (e) {
						return {};
					}
				},

				formatDateTime(dateStr) {
					if (!dateStr) return '';
					const date = new Date(dateStr);
					return date.toLocaleString('en-US', {
						month: 'short',
						day: 'numeric',
						year: 'numeric',
						hour: '2-digit',
						minute: '2-digit'
					});
				},

				exportData() {
					if (!this.statsData) return;

					// Generate CSV
					let csv = '';

					if (this.appliedGroupBy === 'period') {
						// Export period breakdown
						csv = 'Period,Start Time,End Time,Total Count,Severities\n';
						this.statsData.breakdown.forEach(item => {
							const severities = Object.entries(item.statistics || {})
								.map(([sev, stat]) => `${sev}:${stat.count}`)
								.join(';');
							csv += `"${item.period}","${item.start_time}","${item.end_time}",${item.total_count},"${severities}"\n`;
						});
					} else {
						// Export grouped statistics
						csv = 'Category,Count,Avg MTTR (s),Total MTTR (s),Avg MTTA (s),Avg Fix Time (s)\n';
						Object.entries(this.statsData.statistics || {}).forEach(([key, stat]) => {
							csv += `"${key}",${stat.count},${stat.avg_mttr_seconds},${stat.total_mttr_seconds},${stat.avg_mtta_seconds},${stat.avg_fix_time_seconds}\n`;
						});
					}

					// Download CSV
					const blob = new Blob([csv], { type: 'text/csv' });
					const url = window.URL.createObjectURL(blob);
					const a = document.createElement('a');
					a.href = url;
					const filename = `alert-statistics-${this.filters.startDate}-to-${this.filters.endDate}.csv`;
					a.download = filename;
					document.body.appendChild(a);
					a.click();
					document.body.removeChild(a);
					window.URL.revokeObjectURL(url);

					// Show export success feedback
					this.showExportSuccess(filename);
				},

				showExportSuccess(filename) {
					// Create toast notification
					const toast = document.createElement('div');
					toast.className = 'fixed bottom-4 right-4 bg-emerald-600 text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-2 z-50 animate-fade-in';
					toast.innerHTML = `
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
						</svg>
						<span>Exported: ${filename}</span>
					`;
					document.body.appendChild(toast);

					// Remove after 3 seconds
					setTimeout(() => {
						toast.style.opacity = '0';
						toast.style.transition = 'opacity 0.3s ease-out';
						setTimeout(() => toast.remove(), 300);
					}, 3000);
				}
			};
		}
	</script>
}
