package pages

import (
	"notificator/internal/webui/templates/components"
	"notificator/internal/webui/templates/layouts"
	"notificator/internal/webui/templates/scripts"
)

type StatisticsDashboardData struct {
	User ProfileUser
}

templ StatisticsDashboard(data StatisticsDashboardData) {
	@layouts.Base("Alert Statistics - Notificator", StatisticsDashboardContent(data))
}

templ StatisticsDashboardContent(data StatisticsDashboardData) {
	<!-- Chart.js CDN -->
	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
	<!-- Statistics Views Mixin -->
	@scripts.StatisticsViews()
	<div class="min-h-screen bg-gray-50 dark:bg-dark-bg-primary py-8" x-data="{ ...statisticsDashboardPage(), ...statisticsViewsMixin() }" x-init="init(); initViews()">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Header -->
			<div class="mb-8">
				<nav class="flex" aria-label="Breadcrumb">
					<ol class="flex items-center space-x-4">
						<li>
							<a href="/dashboard" class="text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400">
								<svg class="flex-shrink-0 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
									<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
								</svg>
								<span class="sr-only">Dashboard</span>
							</a>
						</li>
						<li>
							<div class="flex items-center">
								<svg class="flex-shrink-0 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
									<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
								</svg>
								<span class="ml-4 text-sm font-medium text-gray-500 dark:text-gray-400">Statistics</span>
							</div>
						</li>
					</ol>
				</nav>
				<div class="mt-4 flex items-center justify-between">
					<div>
						<h1 class="text-3xl font-bold text-gray-900 dark:text-white">Alert Statistics</h1>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
							View and analyze alert metrics over time
						</p>
					</div>
					<div class="flex items-center space-x-3">
						<!-- Saved Views Dropdown -->
						<div class="relative" x-data="{ viewsOpen: false }">
							<button @click="viewsOpen = !viewsOpen" type="button" class="inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-dark-bg-tertiary hover:bg-gray-50 dark:hover:bg-dark-bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
								<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
								</svg>
								<span x-text="getActiveViewName() || 'Saved Views'"></span>
								<svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
								</svg>
							</button>
							<!-- Dropdown menu -->
							<div x-show="viewsOpen" @click.outside="viewsOpen = false" x-transition class="absolute right-0 mt-2 w-64 bg-white dark:bg-dark-bg-secondary rounded-md shadow-lg border border-gray-200 dark:border-dark-border-subtle z-50">
								<div class="py-1">
									<!-- Save current view -->
									<button @click="openSaveViewModal(); viewsOpen = false" class="w-full text-left px-4 py-2 text-sm text-blue-600 dark:text-blue-400 hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary flex items-center">
										<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
										</svg>
										Save Current View
									</button>
									<div class="border-t border-gray-200 dark:border-gray-700 my-1" x-show="views.length > 0"></div>
									<!-- Saved views list -->
									<template x-for="view in views" :key="view.id">
										<div class="group relative">
											<button @click="applyView(view); viewsOpen = false" class="w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary flex items-center justify-between" :class="{ 'bg-blue-50 dark:bg-blue-900/20': isViewActive(view) }">
												<span class="flex items-center">
													<svg x-show="view.isDefault" class="mr-2 h-4 w-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
														<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
													</svg>
													<span x-text="view.name"></span>
												</span>
												<svg x-show="isViewActive(view)" class="h-4 w-4 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
													<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
												</svg>
											</button>
											<!-- View actions (shown on hover) -->
											<div class="absolute right-2 top-1/2 -translate-y-1/2 hidden group-hover:flex items-center space-x-1">
												<button @click.stop="openSaveViewModal(view); viewsOpen = false" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" title="Edit">
													<svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
													</svg>
												</button>
												<button @click.stop="setDefaultView(view.id)" class="p-1 text-gray-400 hover:text-yellow-500" :title="view.isDefault ? 'Remove default' : 'Set as default'">
													<svg class="h-3 w-3" :class="view.isDefault ? 'text-yellow-500' : ''" fill="currentColor" viewBox="0 0 20 20">
														<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
													</svg>
												</button>
												<button @click.stop="deleteView(view.id)" class="p-1 text-gray-400 hover:text-red-500" title="Delete">
													<svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
													</svg>
												</button>
											</div>
										</div>
									</template>
									<!-- Empty state -->
									<div x-show="views.length === 0" class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400 text-center">
										No saved views yet
									</div>
								</div>
							</div>
						</div>

						<!-- Comparison Mode Toggle -->
						<div class="flex items-center">
							<label class="relative inline-flex items-center cursor-pointer">
								<input type="checkbox" x-model="comparisonMode" class="sr-only peer" @change="if(comparisonMode && hasData) loadComparisonData()"/>
								<div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600"></div>
								<span class="ms-2 text-sm font-medium text-gray-700 dark:text-gray-300">Compare</span>
							</label>
						</div>
						<button @click="openRulesModal()" class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-dark-bg-tertiary hover:bg-gray-50 dark:hover:bg-dark-bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
							<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
							</svg>
							Manage Rules
						</button>
						<button @click="exportData" :disabled="loading || !hasData" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
							<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
							</svg>
							Export CSV
						</button>
					</div>
				</div>
			</div>

			<!-- Filters Panel -->
			<div class="mb-6 bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6">
				<div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-4">
					<!-- Date Range Selector -->
					<div class="xl:col-span-2">
						<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Time Range
						</label>
						<div class="flex space-x-2">
							<div class="flex-1">
								<input
									type="date"
									x-model="filters.startDate"
									class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"
								/>
							</div>
							<span class="flex items-center text-gray-500 dark:text-gray-400">to</span>
							<div class="flex-1">
								<input
									type="date"
									x-model="filters.endDate"
									class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"
								/>
							</div>
						</div>
						<!-- Quick Date Presets -->
						<div class="mt-2 flex flex-wrap gap-2">
							<button @click="setDateRange('today')" class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600">Today</button>
							<button @click="setDateRange('week')" class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600">Last 7 Days</button>
							<button @click="setDateRange('month')" class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600">Last 30 Days</button>
							<button @click="setDateRange('quarter')" class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600">Last 90 Days</button>
							<button @click="setDateRange('past_month')" class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 dark:hover:bg-gray-600">Past Month</button>
						</div>
					</div>

					<!-- Time of Day Filter -->
					<div class="xl:col-span-2">
						<div class="flex items-center mb-2">
							<label class="flex items-center cursor-pointer">
								<input
									type="checkbox"
									x-model="filters.filterByTimeOfDay"
									class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
								/>
								<span class="ml-2 text-sm font-medium text-gray-700 dark:text-gray-300">
									Filter by Time of Day
								</span>
							</label>
						</div>
						<div x-show="filters.filterByTimeOfDay" x-collapse>
							<div class="flex space-x-2 mb-2">
								<div class="flex-1">
									<label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">From</label>
									<input
										type="time"
										x-model="filters.timeOfDayStart"
										class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"
									/>
								</div>
								<div class="flex-1">
									<label class="block text-xs text-gray-500 dark:text-gray-400 mb-1">To</label>
									<input
										type="time"
										x-model="filters.timeOfDayEnd"
										class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"
									/>
								</div>
							</div>
							<!-- Time Presets -->
							<div class="flex flex-wrap gap-2">
								<button @click="setTimePreset('night')" class="text-xs px-2 py-1 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 rounded hover:bg-indigo-200 dark:hover:bg-indigo-800/40">
									Night (22:00-06:00)
								</button>
								<button @click="setTimePreset('business')" class="text-xs px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded hover:bg-green-200 dark:hover:bg-green-800/40">
									Business (09:00-18:00)
								</button>
								<button @click="setTimePreset('morning')" class="text-xs px-2 py-1 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 rounded hover:bg-yellow-200 dark:hover:bg-yellow-800/40">
									Morning (06:00-12:00)
								</button>
								<button @click="setTimePreset('evening')" class="text-xs px-2 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 rounded hover:bg-orange-200 dark:hover:bg-orange-800/40">
									Evening (18:00-22:00)
								</button>
								<button @click="applyOnCallFilter()" class="text-xs px-2 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded hover:bg-purple-200 dark:hover:bg-purple-800/40 font-medium" :title="getOnCallDescription()">
									<svg class="w-3 h-3 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
										<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
									</svg>
									On-Call
								</button>
							</div>
							<!-- Weekend Filter -->
							<div class="mt-2">
								<label class="flex items-center cursor-pointer">
									<input
										type="checkbox"
										x-model="filters.includeWeekends"
										class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
									/>
									<span class="ml-2 text-xs text-gray-600 dark:text-gray-400">
										Include weekends (Sat/Sun)
									</span>
								</label>
							</div>
							<p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
								<span x-show="filters.timeOfDayStart > filters.timeOfDayEnd" class="text-indigo-600 dark:text-indigo-400">
									Cross-midnight range: alerts from <span x-text="filters.timeOfDayStart"></span> to midnight and midnight to <span x-text="filters.timeOfDayEnd"></span>
								</span>
								<span x-show="filters.timeOfDayStart <= filters.timeOfDayEnd">
									Alerts fired between <span x-text="filters.timeOfDayStart"></span> and <span x-text="filters.timeOfDayEnd"></span>
								</span>
							</p>
						</div>
					</div>

					<!-- Group By Selector -->
					<div class="p-3 rounded-lg border-l-4 transition-colors" :class="getGroupByStyle('border') + ' ' + getGroupByStyle('bg')">
						<label class="block text-sm font-medium mb-2 transition-colors" :class="getGroupByStyle('label')">
							Group By
						</label>
						<select
							x-model="filters.groupBy"
							class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 dark:bg-dark-bg-tertiary dark:text-white text-sm transition-shadow"
							:class="getGroupByStyle('ring')"
						>
							<option value="">Overall</option>
							<option value="severity">Severity</option>
							<option value="team">Team</option>
							<option value="alert_name">Alert Name</option>
							<option value="period">Time Period</option>
						</select>
					</div>

					<!-- Period Type (shown when groupBy is "period") -->
					<div x-show="filters.groupBy === 'period'">
						<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Period Type
						</label>
						<select
							x-model="filters.periodType"
							class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"
						>
							<option value="hour">Hourly</option>
							<option value="day">Daily</option>
							<option value="week">Weekly</option>
							<option value="month">Monthly</option>
						</select>
					</div>
				</div>

				<!-- Severity and Team Filters Row -->
				<div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
					<!-- Severity Multi-Select -->
					<div class="relative" @click.outside="showSeverityDropdown = false">
						<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Severity Filter
						</label>
						<button
							@click="showSeverityDropdown = !showSeverityDropdown"
							type="button"
							class="w-full px-3 py-2 text-left border border-gray-300 dark:border-gray-600 rounded-md shadow-sm bg-white dark:bg-dark-bg-tertiary text-sm flex items-center justify-between focus:outline-none focus:ring-2 focus:ring-blue-500"
						>
							<span x-text="filters.severities.length === 0 ? 'All Severities' : filters.severities.join(', ')" class="truncate text-gray-700 dark:text-gray-300"></span>
							<svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
							</svg>
						</button>
						<div x-show="showSeverityDropdown" x-transition class="absolute z-20 mt-1 w-full bg-white dark:bg-dark-bg-secondary border border-gray-300 dark:border-gray-600 rounded-md shadow-lg">
							<div class="p-2 space-y-1">
								<label class="flex items-center px-2 py-1.5 rounded hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary cursor-pointer">
									<input type="checkbox" value="critical" x-model="filters.severities" class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"/>
									<span class="ml-2 text-sm text-gray-700 dark:text-gray-300 flex items-center">
										<span class="w-2 h-2 bg-red-500 rounded-full mr-2"></span>
										Critical
									</span>
								</label>
								<label class="flex items-center px-2 py-1.5 rounded hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary cursor-pointer">
									<input type="checkbox" value="warning" x-model="filters.severities" class="h-4 w-4 text-yellow-600 focus:ring-yellow-500 border-gray-300 rounded"/>
									<span class="ml-2 text-sm text-gray-700 dark:text-gray-300 flex items-center">
										<span class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></span>
										Warning
									</span>
								</label>
								<label class="flex items-center px-2 py-1.5 rounded hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary cursor-pointer">
									<input type="checkbox" value="info" x-model="filters.severities" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"/>
									<span class="ml-2 text-sm text-gray-700 dark:text-gray-300 flex items-center">
										<span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>
										Info
									</span>
								</label>
							</div>
							<div class="border-t border-gray-200 dark:border-gray-600 p-2">
								<button @click="filters.severities = []; showSeverityDropdown = false" class="w-full text-xs text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
									Clear Selection
								</button>
							</div>
						</div>
					</div>

					<!-- Team Multi-Select -->
					<div class="relative" @click.outside="showTeamDropdown = false">
						<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Team Filter
						</label>
						<button
							@click="showTeamDropdown = !showTeamDropdown; if(showTeamDropdown && availableTeams.length === 0) loadAvailableTeams()"
							type="button"
							class="w-full px-3 py-2 text-left border border-gray-300 dark:border-gray-600 rounded-md shadow-sm bg-white dark:bg-dark-bg-tertiary text-sm flex items-center justify-between focus:outline-none focus:ring-2 focus:ring-blue-500"
						>
							<span x-text="filters.teams.length === 0 ? 'All Teams' : filters.teams.join(', ')" class="truncate text-gray-700 dark:text-gray-300"></span>
							<svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
							</svg>
						</button>
						<div x-show="showTeamDropdown" x-transition class="absolute z-20 mt-1 w-full bg-white dark:bg-dark-bg-secondary border border-gray-300 dark:border-gray-600 rounded-md shadow-lg max-h-60 overflow-y-auto">
							<div x-show="availableTeams.length === 0" class="p-4 text-center text-sm text-gray-500 dark:text-gray-400">
								Loading teams...
							</div>
							<div x-show="availableTeams.length > 0" class="p-2 space-y-1">
								<template x-for="team in availableTeams" :key="team">
									<label class="flex items-center px-2 py-1.5 rounded hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary cursor-pointer">
										<input type="checkbox" :value="team" x-model="filters.teams" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"/>
										<span class="ml-2 text-sm text-gray-700 dark:text-gray-300" x-text="team"></span>
									</label>
								</template>
							</div>
							<div x-show="availableTeams.length > 0" class="border-t border-gray-200 dark:border-gray-600 p-2">
								<button @click="filters.teams = []; showTeamDropdown = false" class="w-full text-xs text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
									Clear Selection
								</button>
							</div>
						</div>
					</div>
				</div>

				<!-- Additional Options Row -->
				<div class="mt-4 flex items-center justify-between">
					<div class="flex items-center space-x-4">
						<!-- Apply On-Call Rules Toggle -->
						<label class="flex items-center cursor-pointer">
							<input
								type="checkbox"
								x-model="filters.applyRules"
								class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
							/>
							<span class="ml-2 text-sm text-gray-700 dark:text-gray-300">
								Apply On-Call Rules
								<span class="text-xs text-gray-500 dark:text-gray-400">(filter by your configured rules)</span>
							</span>
						</label>

						<!-- Limit (for alert_name grouping) -->
						<div x-show="filters.groupBy === 'alert_name'" class="flex items-center space-x-2">
							<label class="text-sm text-gray-700 dark:text-gray-300">Top</label>
							<input
								type="number"
								x-model.number="filters.limit"
								min="5"
								max="50"
								step="5"
								class="w-16 px-2 py-1 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"
							/>
							<span class="text-sm text-gray-700 dark:text-gray-300">alerts</span>
						</div>
					</div>

					<!-- Query Button -->
					<button
						@click="queryStatistics"
						:disabled="loading"
						class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
					>
						<svg x-show="loading" class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<span x-text="loading ? 'Loading...' : 'Run Query'"></span>
					</button>
				</div>
			</div>

			<!-- Loading State -->
			<div x-show="loading && !hasData" class="text-center py-12">
				<div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
				<p class="mt-4 text-gray-500 dark:text-gray-400">Loading statistics...</p>
			</div>

			<!-- Empty State -->
			<div x-show="!loading && !hasData" class="text-center py-12 bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle">
				<svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
				</svg>
				<h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No Data</h3>
				<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
					Select a time range and click "Run Query" to view statistics.
				</p>
			</div>

			<!-- Statistics Content -->
			<div x-show="!loading && hasData">
				<!-- Summary Cards -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
					<!-- Total Alerts Card -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6">
						<div class="flex items-center">
							<div class="flex-shrink-0 bg-blue-100 dark:bg-blue-900/30 rounded-md p-3">
								<svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
								</svg>
							</div>
							<div class="ml-5 w-0 flex-1">
								<dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
									Total Alerts
								</dt>
								<dd class="flex items-baseline">
									<div class="text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatNumber(statsData?.total_alerts || 0)"></div>
								</dd>
							</div>
						</div>
					</div>

					<!-- Average MTTR Card (Mean Time To Resolve) -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 relative">
						<div class="absolute top-2 right-2 group">
							<div class="w-4 h-4 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center cursor-help text-xs text-gray-500 dark:text-gray-400 hover:bg-gray-300 dark:hover:bg-gray-600">?</div>
							<div class="absolute right-0 top-6 w-48 p-2 bg-gray-900 dark:bg-gray-800 text-white text-xs rounded shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<span class="font-semibold">Mean Time To Resolve</span><br/>
								<span class="text-gray-300">ResolvedAt - FiredAt</span><br/>
								<span class="text-gray-400 text-[10px]">Total time from alert firing to resolution</span>
							</div>
						</div>
						<div class="flex items-center">
							<div class="flex-shrink-0 bg-yellow-100 dark:bg-yellow-900/30 rounded-md p-3">
								<svg class="h-6 w-6 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div class="ml-5 w-0 flex-1">
								<dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
									Avg MTTR
								</dt>
								<dd class="flex items-baseline">
									<div class="text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatDuration(getOverallAvgMTTR())"></div>
								</dd>
							</div>
						</div>
					</div>

					<!-- Average MTTA Card (Mean Time To Acknowledge) -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 relative">
						<div class="absolute top-2 right-2 group">
							<div class="w-4 h-4 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center cursor-help text-xs text-gray-500 dark:text-gray-400 hover:bg-gray-300 dark:hover:bg-gray-600">?</div>
							<div class="absolute right-0 top-6 w-48 p-2 bg-gray-900 dark:bg-gray-800 text-white text-xs rounded shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<span class="font-semibold">Mean Time To Acknowledge</span><br/>
								<span class="text-gray-300">AcknowledgedAt - FiredAt</span><br/>
								<span class="text-gray-400 text-[10px]">Time from alert firing to acknowledgment</span>
							</div>
						</div>
						<div class="flex items-center">
							<div class="flex-shrink-0 bg-green-100 dark:bg-green-900/30 rounded-md p-3">
								<svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div class="ml-5 w-0 flex-1">
								<dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
									Avg MTTA
								</dt>
								<dd class="flex items-baseline">
									<div class="text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatTimeOrNA(getOverallAvgMTTA())"></div>
								</dd>
							</div>
						</div>
					</div>

					<!-- Average Fix Time Card -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 relative">
						<div class="absolute top-2 right-2 group">
							<div class="w-4 h-4 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center cursor-help text-xs text-gray-500 dark:text-gray-400 hover:bg-gray-300 dark:hover:bg-gray-600">?</div>
							<div class="absolute right-0 top-6 w-48 p-2 bg-gray-900 dark:bg-gray-800 text-white text-xs rounded shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<span class="font-semibold">Fix Time</span><br/>
								<span class="text-gray-300">ResolvedAt - AcknowledgedAt</span><br/>
								<span class="text-gray-400 text-[10px]">Time spent fixing after acknowledgment</span>
							</div>
						</div>
						<div class="flex items-center">
							<div class="flex-shrink-0 bg-indigo-100 dark:bg-indigo-900/30 rounded-md p-3">
								<svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
								</svg>
							</div>
							<div class="ml-5 w-0 flex-1">
								<dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
									Avg Fix Time
								</dt>
								<dd class="flex items-baseline">
									<div class="text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatTimeOrNA(getOverallAvgFixTime())"></div>
								</dd>
							</div>
						</div>
					</div>

					<!-- Time Range Card -->
					<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6">
						<div class="flex items-center">
							<div class="flex-shrink-0 bg-purple-100 dark:bg-purple-900/30 rounded-md p-3">
								<svg class="h-6 w-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
							</div>
							<div class="ml-5 w-0 flex-1">
								<dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
									Time Range
								</dt>
								<dd class="text-sm text-gray-900 dark:text-white">
									<div x-text="formatDate(statsData?.time_range?.start)"></div>
									<div class="text-xs text-gray-500" x-text="'to ' + formatDate(statsData?.time_range?.end)"></div>
								</dd>
							</div>
						</div>
					</div>
				</div>

				<!-- Charts Section (hidden for period grouping - shows only Statistics by Time Period table instead) -->
				<div class="space-y-6 mb-6" x-show="appliedGroupBy !== 'period'">
					<!-- Alerts Over Time Chart - Always visible, spans full width when groupBy is set -->
					<div class="rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 border-l-4 transition-colors" :class="getGroupByStyle('border') + ' ' + getGroupByStyle('bg')">
						<div class="flex items-center justify-between mb-4">
							<div class="flex items-center space-x-2">
								<h3 class="text-lg font-medium text-gray-900 dark:text-white">Alerts Over Time</h3>
								<span x-show="appliedGroupBy" class="text-xs px-2 py-0.5 rounded-full" :class="getGroupByStyle('label') + ' bg-white/50 dark:bg-black/20'" x-text="'by ' + getGroupByLabel()"></span>
							</div>
							<div class="flex items-center space-x-4">
								<!-- Line visibility toggles (shown when groupBy is set) -->
								<div x-show="appliedGroupBy && Object.keys(chartVisibility).length > 0" class="flex flex-wrap gap-2">
									<template x-for="(visible, key) in chartVisibility" :key="key">
										<button
											@click="toggleChartVisibility(key)"
											class="px-2 py-1 text-xs rounded-full border transition-all"
											:class="visible ? getVisibilityButtonClass(key, true) : 'bg-gray-100 text-gray-400 dark:bg-gray-800 dark:text-gray-500 border-gray-200 dark:border-gray-700 opacity-50'"
											x-text="key"
										></button>
									</template>
								</div>
								<!-- View type toggle -->
								<div class="flex space-x-1 border-l pl-4 dark:border-gray-700" x-show="!appliedGroupBy">
									<button @click="timeSeriesView = 'fired'" :class="timeSeriesView === 'fired' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'" class="px-2 py-1 text-xs rounded">
										Fired
									</button>
									<button @click="timeSeriesView = 'resolved'" :class="timeSeriesView === 'resolved' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'" class="px-2 py-1 text-xs rounded">
										Resolved
									</button>
									<button @click="timeSeriesView = 'both'" :class="timeSeriesView === 'both' ? 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'" class="px-2 py-1 text-xs rounded">
										Both
									</button>
								</div>
								<!-- Fullscreen button -->
								<button @click="openFullscreenChart('alertsTime')" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" title="Fullscreen">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
									</svg>
								</button>
							</div>
						</div>
						<div class="h-72">
							<canvas id="alertsTimeChart" x-ref="alertsTimeChart"></canvas>
						</div>
					</div>

					<!-- Secondary Charts Row - Distribution + Top Items -->
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
						<!-- Distribution Chart (Donut) - shown when groupBy is set -->
						<div x-show="appliedGroupBy" class="rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 border-l-4 transition-colors" :class="getGroupByStyle('border') + ' ' + getGroupByStyle('bg')">
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center space-x-2">
									<h3 class="text-lg font-medium text-gray-900 dark:text-white" x-text="getGroupByLabel() + ' Distribution'"></h3>
								</div>
								<div class="flex items-center space-x-2">
									<span class="text-xs text-gray-500 dark:text-gray-400">Click to filter</span>
									<button @click="openFullscreenChart('distribution')" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" title="Fullscreen">
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
										</svg>
									</button>
								</div>
							</div>
							<div class="h-64 flex items-center justify-center">
								<div class="w-full max-w-xs">
									<canvas id="distributionChart" x-ref="distributionChart"></canvas>
								</div>
							</div>
						</div>

						<!-- Top Items Chart (Bar) -->
						<div class="rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 border-l-4 transition-colors" :class="getGroupByStyle('border') + ' ' + getGroupByStyle('bg')">
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center space-x-2">
									<h3 class="text-lg font-medium text-gray-900 dark:text-white" x-text="'Top 10 ' + (appliedGroupBy ? getGroupByLabel() : 'Alerts')"></h3>
								</div>
								<div class="flex items-center space-x-2">
									<span class="text-xs text-gray-500 dark:text-gray-400">Click to filter</span>
									<button @click="openFullscreenChart('topItems')" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" title="Fullscreen">
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
										</svg>
									</button>
								</div>
							</div>
							<div class="h-64">
								<canvas id="topItemsChart" x-ref="topItemsChart"></canvas>
							</div>
						</div>
					</div>

					<!-- Resolution Times Chart - Full Width -->
					<div x-show="appliedGroupBy && Object.keys(statsData?.statistics || {}).length > 0" class="rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle p-6 border-l-4 transition-colors" :class="getGroupByStyle('border') + ' ' + getGroupByStyle('bg')">
						<div class="flex items-center justify-between mb-4">
							<div class="flex items-center space-x-2">
								<h3 class="text-lg font-medium text-gray-900 dark:text-white">
									Resolution Times by <span x-text="getGroupByLabel()"></span>
								</h3>
							</div>
							<div class="flex items-center space-x-2">
								<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">MTTR</span>
								<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">MTTA</span>
								<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400">Fix Time</span>
								<button @click="openFullscreenChart('timeMetrics')" class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" title="Fullscreen">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
									</svg>
								</button>
							</div>
						</div>
						<div class="h-80">
							<canvas id="timeMetricsChart"></canvas>
						</div>
					</div>
				</div>

				<!-- Comparison Panel (shown when comparison mode is active) -->
				<div x-show="comparisonMode && comparisonData" x-collapse class="mb-6">
					<div class="bg-gradient-to-r from-indigo-50 to-purple-50 dark:from-indigo-900/20 dark:to-purple-900/20 rounded-lg shadow-sm border border-indigo-200 dark:border-indigo-800 p-6">
						<h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4 flex items-center">
							<svg class="w-5 h-5 mr-2 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
							</svg>
							Period Comparison
						</h3>
						<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
							<!-- Total Alerts Comparison -->
							<div class="bg-white dark:bg-dark-bg-secondary rounded-lg p-4">
								<div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Alerts</div>
								<div class="flex items-baseline space-x-2">
									<span class="text-xl font-bold text-gray-900 dark:text-white" x-text="formatNumber(statsData?.total_alerts || 0)"></span>
									<span class="text-sm" :class="getDeltaClass(comparisonData?.delta_alerts)" x-text="getDeltaText(comparisonData?.delta_alerts)"></span>
								</div>
								<div class="text-xs text-gray-400 dark:text-gray-500" x-text="'vs ' + formatNumber(comparisonData?.previous_total || 0) + ' previously'"></div>
							</div>
							<!-- Avg MTTR Comparison -->
							<div class="bg-white dark:bg-dark-bg-secondary rounded-lg p-4">
								<div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Avg MTTR</div>
								<div class="flex items-baseline space-x-2">
									<span class="text-xl font-bold text-gray-900 dark:text-white" x-text="formatDuration(getOverallAvgMTTR())"></span>
									<span class="text-sm" :class="getDeltaClass(comparisonData?.delta_mttr, true)" x-text="getDeltaText(comparisonData?.delta_mttr)"></span>
								</div>
							</div>
							<!-- Avg MTTA Comparison -->
							<div class="bg-white dark:bg-dark-bg-secondary rounded-lg p-4">
								<div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Avg MTTA</div>
								<div class="flex items-baseline space-x-2">
									<span class="text-xl font-bold text-gray-900 dark:text-white" x-text="formatTimeOrNA(getOverallAvgMTTA())"></span>
									<span class="text-sm" :class="getDeltaClass(comparisonData?.delta_mtta, true)" x-text="getDeltaText(comparisonData?.delta_mtta)"></span>
								</div>
							</div>
							<!-- Critical Alerts Comparison -->
							<div class="bg-white dark:bg-dark-bg-secondary rounded-lg p-4">
								<div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Critical Alerts</div>
								<div class="flex items-baseline space-x-2">
									<span class="text-xl font-bold text-red-600 dark:text-red-400" x-text="formatNumber(getCriticalCount())"></span>
									<span class="text-sm" :class="getDeltaClass(comparisonData?.delta_critical)" x-text="getDeltaText(comparisonData?.delta_critical)"></span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Breakdown Tables/Charts -->
				<div class="space-y-6">
					<!-- Statistics by Group (when groupBy is set and not using period grouping) -->
					<div x-show="appliedGroupBy && appliedGroupBy !== 'period' && Object.keys(statsData?.statistics || {}).length > 0">
						<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle overflow-hidden">
							<div class="px-6 py-4 border-b border-gray-200 dark:border-dark-border-subtle">
								<h3 class="text-lg font-medium text-gray-900 dark:text-white" x-text="getGroupByTitle()"></h3>
							</div>
							<div class="overflow-x-auto">
								<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
									<thead class="bg-gray-50 dark:bg-dark-bg-tertiary">
										<tr>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												<button @click="sortBy('name')" class="flex items-center space-x-1 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
													<span x-text="appliedGroupBy || 'Category'"></span>
													<span x-html="getSortIcon('name')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												<button @click="sortBy('count')" class="flex items-center space-x-1 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
													<span>Count</span>
													<span x-html="getSortIcon('count')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												Percentage
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												<button @click="sortBy('avg_mttr')" class="flex items-center space-x-1 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
													<span>Avg MTTR</span>
													<span x-html="getSortIcon('avg_mttr')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												<button @click="sortBy('total_mttr')" class="flex items-center space-x-1 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
													<span>Total MTTR</span>
													<span x-html="getSortIcon('total_mttr')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												<button @click="sortBy('avg_mtta')" class="flex items-center space-x-1 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
													<span>Avg MTTA</span>
													<span x-html="getSortIcon('avg_mtta')"></span>
												</button>
											</th>
											<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
												<button @click="sortBy('avg_fix_time')" class="flex items-center space-x-1 hover:text-gray-700 dark:hover:text-gray-200 transition-colors">
													<span>Avg Fix Time</span>
													<span x-html="getSortIcon('avg_fix_time')"></span>
												</button>
											</th>
										</tr>
									</thead>
									<tbody class="bg-white dark:bg-dark-bg-secondary divide-y divide-gray-200 dark:divide-gray-700">
										<template x-for="[key, stat] in getSortedStatistics()" :key="key">
											<tr
												class="hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary transition-colors"
												:class="appliedGroupBy === 'alert_name' ? 'cursor-pointer' : ''"
												@click="appliedGroupBy === 'alert_name' && openAlertDetailsModal(key)"
											>
												<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
													<div class="flex items-center">
														<span x-text="key" :class="getSeverityClass(key)"></span>
														<svg x-show="appliedGroupBy === 'alert_name'" class="ml-2 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
															<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
														</svg>
													</div>
												</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
													<div class="flex items-center space-x-2">
														<span x-text="formatNumber(stat.count)"></span>
														<div class="flex-1 min-w-[100px]">
															<div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
																<div class="h-full bg-blue-600 dark:bg-blue-500 rounded-full transition-all duration-300" :style="`width: ${(stat.count / getMaxCount() * 100)}%`"></div>
															</div>
														</div>
													</div>
												</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
													<span x-text="getPercentage(stat.count) + '%'"></span>
												</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="formatDuration(stat.avg_mttr_seconds)"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="formatDuration(stat.total_mttr_seconds)"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="formatTimeOrNA(stat.avg_mtta_seconds)"></td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="formatTimeOrNA(stat.avg_fix_time_seconds)"></td>
											</tr>
										</template>
									</tbody>
								</table>
							</div>
						</div>
					</div>

					<!-- Period Breakdown (when groupBy is "period") -->
					<div x-show="appliedGroupBy === 'period' && (statsData?.breakdown || []).length > 0">
						<div class="bg-white dark:bg-dark-bg-secondary rounded-lg shadow-sm border border-gray-200 dark:border-dark-border-subtle overflow-hidden">
							<div class="px-6 py-4 border-b border-gray-200 dark:border-dark-border-subtle">
								<h3 class="text-lg font-medium text-gray-900 dark:text-white">Statistics by Time Period</h3>
							</div>

							<!-- Simple Chart Visualization -->
							<div class="p-6">
								<div class="space-y-4">
									<template x-for="(item, index) in (statsData?.breakdown || [])" :key="index">
										<div class="border-l-4 pl-4 py-2" :class="'border-blue-500'">
											<div class="flex items-center justify-between mb-2">
												<div>
													<div class="text-sm font-medium text-gray-900 dark:text-white" x-text="item.period"></div>
													<div class="text-xs text-gray-500 dark:text-gray-400" x-text="formatDate(item.start_time) + ' - ' + formatDate(item.end_time)"></div>
												</div>
												<div class="text-right">
													<div class="text-lg font-semibold text-gray-900 dark:text-white" x-text="formatNumber(item.total_count)"></div>
													<div class="text-xs text-gray-500 dark:text-gray-400">alerts</div>
												</div>
											</div>

											<!-- Severity breakdown for this period -->
											<div x-show="item.statistics && Object.keys(item.statistics).length > 0" class="mt-2 flex flex-wrap gap-2">
												<template x-for="(stat, severity) in item.statistics" :key="severity">
													<span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium" :class="getSeverityBadgeClass(severity)">
														<span x-text="severity + ': ' + stat.count"></span>
													</span>
												</template>
											</div>
										</div>
									</template>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</div>

		<!-- Alert Details Modal -->
		<div
			x-show="showAlertDetailsModal"
			x-cloak
			class="fixed inset-0 z-50 overflow-y-auto"
			@keydown.escape.window="closeAlertDetailsModal()"
		>
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<!-- Background overlay -->
				<div
					x-show="showAlertDetailsModal"
					x-transition:enter="ease-out duration-300"
					x-transition:enter-start="opacity-0"
					x-transition:enter-end="opacity-100"
					x-transition:leave="ease-in duration-200"
					x-transition:leave-start="opacity-100"
					x-transition:leave-end="opacity-0"
					class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75"
					aria-hidden="true"
				></div>

				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>

				<!-- Modal panel -->
				<div
					x-show="showAlertDetailsModal"
					x-transition:enter="ease-out duration-300"
					x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
					x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
					x-transition:leave="ease-in duration-200"
					x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
					x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
					class="inline-block w-full max-w-5xl px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6 relative z-10"
					@click.stop
				>
					<!-- Header -->
					<div class="flex items-center justify-between mb-6">
						<div>
							<h3 class="text-lg font-medium text-gray-900 dark:text-white">Alert Occurrences</h3>
							<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
								<span x-text="selectedAlertName"></span>
								<span class="mx-2">•</span>
								<span x-text="alertDetailsData?.length || 0"></span> occurrences
							</p>
						</div>
						<button @click="closeAlertDetailsModal()" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300">
							<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
					</div>

					<!-- Loading State -->
					<div x-show="alertDetailsLoading" class="text-center py-12">
						<svg class="animate-spin h-8 w-8 text-blue-600 mx-auto" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Loading alert details...</p>
					</div>

					<!-- Alert List -->
					<div x-show="!alertDetailsLoading && alertDetailsData?.length > 0" class="max-h-[60vh] overflow-y-auto">
						<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
							<thead class="bg-gray-50 dark:bg-dark-bg-tertiary sticky top-0">
								<tr>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Severity</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Fired At</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Resolved At</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">MTTR</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">MTTA</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Fix Time</th>
									<th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Labels</th>
								</tr>
							</thead>
							<tbody class="bg-white dark:bg-dark-bg-secondary divide-y divide-gray-200 dark:divide-gray-700">
								<template x-for="alert in alertDetailsData" :key="alert.id">
									<tr class="hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary cursor-pointer transition-colors"
										@click.stop="openIndividualAlertDetails(alert)"
										title="Click to view full alert details">
										<td class="px-4 py-3 whitespace-nowrap">
											<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
												:class="{
													'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400': alert.severity === 'critical',
													'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400': alert.severity === 'warning',
													'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400': alert.severity === 'info'
												}"
												x-text="alert.severity">
											</span>
										</td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="formatDateTime(alert.fired_at)"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="alert.resolved_at ? formatDateTime(alert.resolved_at) : '—'"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="formatDuration(alert.mttr_seconds)"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="alert.mtta_seconds ? formatDuration(alert.mtta_seconds) : '—'"></td>
										<td class="px-4 py-3 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400" x-text="alert.fix_time_seconds ? formatDuration(alert.fix_time_seconds) : '—'"></td>
										<td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
											<div class="flex flex-wrap gap-1 max-w-xs">
												<template x-for="(value, key) in getAlertLabels(alert)" :key="key">
													<span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
														<span x-text="key + '=' + value"></span>
													</span>
												</template>
											</div>
										</td>
									</tr>
								</template>
							</tbody>
						</table>
					</div>

					<!-- Empty State -->
					<div x-show="!alertDetailsLoading && (!alertDetailsData || alertDetailsData.length === 0)" class="text-center py-12">
						<svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
						</svg>
						<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No alert occurrences found</p>
					</div>

					<!-- Footer -->
					<div class="mt-6 flex justify-end">
						<button
							@click="closeAlertDetailsModal()"
							class="px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-dark-bg-tertiary hover:bg-gray-50 dark:hover:bg-dark-bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
						>
							Close
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Save View Modal -->
		<div x-show="showSaveViewModal" class="fixed inset-0 z-50 overflow-y-auto" x-cloak>
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<!-- Background overlay -->
				<div x-show="showSaveViewModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75" @click="closeSaveViewModal()"></div>
				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
				<!-- Modal panel -->
				<div x-show="showSaveViewModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative z-10 inline-block w-full max-w-md px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6" @click.stop>
					<div class="mb-4">
						<h3 class="text-lg font-medium text-gray-900 dark:text-white" x-text="viewForm.isEditing ? 'Edit View' : 'Save Current View'"></h3>
						<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Save your current filter configuration for quick access later.</p>
					</div>
					<div class="space-y-4">
						<div>
							<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
							<input type="text" x-model="viewForm.name" placeholder="e.g., Weekly Critical Alerts" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"/>
						</div>
						<div>
							<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description (optional)</label>
							<textarea x-model="viewForm.description" rows="2" placeholder="Brief description of this view..." class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-tertiary dark:text-white text-sm"></textarea>
						</div>
					</div>
					<div class="mt-6 flex justify-end space-x-3">
						<button @click="closeSaveViewModal()" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-dark-bg-tertiary border border-gray-300 dark:border-gray-600 rounded-md shadow-sm hover:bg-gray-50 dark:hover:bg-dark-bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
							Cancel
						</button>
						<button @click="saveView()" type="button" :disabled="!viewForm.name.trim()" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed">
							<span x-text="viewForm.isEditing ? 'Update View' : 'Save View'"></span>
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Rules Management Modal -->
		<div x-show="showRulesModal" class="fixed inset-0 z-50 overflow-y-auto" x-cloak @keydown.escape.window="if(!showRuleFormModal && !showRuleTestModal) closeRulesModal()">
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<!-- Background overlay -->
				<div x-show="showRulesModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75" @click="if(!showRuleFormModal && !showRuleTestModal) closeRulesModal()"></div>
				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
				<!-- Modal panel -->
				<div x-show="showRulesModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative z-10 inline-block w-full max-w-4xl px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6" @click.stop>
					<!-- Header -->
					<div class="flex items-center justify-between mb-6">
						<div>
							<h3 class="text-lg font-medium text-gray-900 dark:text-white">On-Call Rules</h3>
							<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Define criteria to classify which alerts count as on-call alerts</p>
						</div>
						<div class="flex items-center space-x-3">
							<button @click="openRuleFormModal()" class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
								<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
								</svg>
								Create Rule
							</button>
							<button @click="closeRulesModal()" class="text-gray-400 hover:text-gray-500">
								<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
								</svg>
							</button>
						</div>
					</div>

					<!-- Loading State -->
					<div x-show="rulesLoading" class="text-center py-12">
						<svg class="animate-spin h-8 w-8 text-blue-600 mx-auto" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Loading rules...</p>
					</div>

					<!-- Rules List -->
					<div x-show="!rulesLoading" class="max-h-[60vh] overflow-y-auto">
						<!-- Empty State -->
						<div x-show="rules.length === 0" class="text-center py-12">
							<svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
							</svg>
							<h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No rules defined</h3>
							<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by creating your first on-call rule</p>
						</div>

						<!-- Rules Grid -->
						<div x-show="rules.length > 0" class="space-y-4">
							<template x-for="rule in rules" :key="rule.id">
								<div class="p-4 border border-gray-200 dark:border-dark-border-subtle rounded-lg bg-gray-50 dark:bg-dark-bg-tertiary">
									<div class="flex items-start justify-between">
										<div class="flex-1 min-w-0">
											<div class="flex items-center space-x-3">
												<h4 class="text-sm font-medium text-gray-900 dark:text-white truncate" x-text="rule.rule_name"></h4>
												<span x-show="rule.is_active" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">Active</span>
												<span x-show="!rule.is_active" class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400">Inactive</span>
											</div>
											<p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
												<span x-text="rule.rule_config.criteria.length"></span> criteria with <span class="uppercase" x-text="rule.rule_config.logic"></span> logic
											</p>
											<!-- Criteria Preview -->
											<div class="mt-2 flex flex-wrap gap-1">
												<template x-for="(criterion, idx) in rule.rule_config.criteria.slice(0, 3)" :key="idx">
													<span class="inline-flex items-center text-xs px-2 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400 rounded">
														<span x-text="criterion.type"></span>
														<span class="mx-1 text-blue-500">:</span>
														<span x-text="getRuleCriterionValue(criterion)"></span>
													</span>
												</template>
												<span x-show="rule.rule_config.criteria.length > 3" class="text-xs text-gray-500 dark:text-gray-400">+<span x-text="rule.rule_config.criteria.length - 3"></span> more</span>
											</div>
										</div>
										<!-- Actions -->
										<div class="ml-4 flex items-center space-x-1">
											<button @click="testRule(rule)" class="p-1.5 text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" title="Test rule">
												<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
												</svg>
											</button>
											<button @click="editRule(rule)" class="p-1.5 text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" title="Edit rule">
												<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
												</svg>
											</button>
											<button @click="toggleRuleActive(rule)" class="p-1.5 text-gray-400 hover:text-yellow-600 dark:hover:text-yellow-400" :title="rule.is_active ? 'Deactivate' : 'Activate'">
												<svg x-show="rule.is_active" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
												</svg>
												<svg x-show="!rule.is_active" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
												</svg>
											</button>
											<button @click="deleteRule(rule)" class="p-1.5 text-gray-400 hover:text-red-600 dark:hover:text-red-400" title="Delete rule">
												<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
												</svg>
											</button>
										</div>
									</div>
								</div>
							</template>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Rule Form Modal (nested) -->
		<div x-show="showRuleFormModal" class="fixed inset-0 z-[60] overflow-y-auto" x-cloak @keydown.escape.window="closeRuleFormModal()">
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<div x-show="showRuleFormModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75"></div>
				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
				<div x-show="showRuleFormModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative z-10 inline-block w-full max-w-3xl px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6" @click.stop>
					<div class="flex items-center justify-between mb-6">
						<h3 class="text-lg font-medium text-gray-900 dark:text-white" x-text="editingRule ? 'Edit Rule' : 'Create New Rule'"></h3>
						<button @click="closeRuleFormModal()" class="text-gray-400 hover:text-gray-500">
							<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
					</div>

					<form @submit.prevent="saveRule()" class="space-y-5">
						<!-- Rule Name -->
						<div>
							<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Rule Name <span class="text-red-500">*</span></label>
							<input x-model="ruleFormData.rule_name" type="text" required placeholder="e.g., Platform Team Critical Alerts" class="w-full px-3 py-2 border border-gray-300 dark:border-dark-border-subtle rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white text-sm"/>
						</div>

						<!-- Active Status -->
						<div class="flex items-center">
							<input x-model="ruleFormData.is_active" type="checkbox" id="rule-is-active" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"/>
							<label for="rule-is-active" class="ml-2 block text-sm text-gray-700 dark:text-gray-300">Rule is active</label>
						</div>

						<!-- Logic Operator -->
						<div>
							<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Match Logic <span class="text-red-500">*</span></label>
							<select x-model="ruleFormData.rule_config.logic" class="w-full px-3 py-2 border border-gray-300 dark:border-dark-border-subtle rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white text-sm">
								<option value="AND">AND - All criteria must match</option>
								<option value="OR">OR - At least one criterion must match</option>
							</select>
						</div>

						<!-- Criteria Builder -->
						<div>
							<div class="flex items-center justify-between mb-2">
								<label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Criteria <span class="text-red-500">*</span></label>
								<button @click.prevent="addRuleCriterion()" type="button" class="inline-flex items-center px-2 py-1 border border-gray-300 dark:border-dark-border-subtle text-xs font-medium rounded text-gray-700 dark:text-gray-300 bg-white dark:bg-dark-bg-primary hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary">
									<svg class="mr-1 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
									</svg>
									Add
								</button>
							</div>

							<div class="space-y-2 max-h-60 overflow-y-auto">
								<template x-for="(criterion, index) in ruleFormData.rule_config.criteria" :key="index">
									<div class="p-3 border border-gray-200 dark:border-dark-border-subtle rounded bg-gray-50 dark:bg-dark-bg-tertiary">
										<div class="grid grid-cols-12 gap-2 items-start">
											<!-- Type -->
											<div class="col-span-3">
												<select x-model="criterion.type" @change="onRuleCriterionTypeChange(index)" class="w-full px-2 py-1.5 border border-gray-300 dark:border-dark-border-subtle rounded text-xs focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white">
													<option value="severity">Severity</option>
													<option value="label">Label</option>
													<option value="alert_name">Alert Name</option>
												</select>
											</div>
											<!-- Operator -->
											<div class="col-span-3">
												<select x-model="criterion.operator" class="w-full px-2 py-1.5 border border-gray-300 dark:border-dark-border-subtle rounded text-xs focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white">
													<template x-if="criterion.type === 'severity'">
														<optgroup label="Severity">
															<option value="equals">Equals</option>
															<option value="in">In (multiple)</option>
															<option value="not_equals">Not Equals</option>
														</optgroup>
													</template>
													<template x-if="criterion.type === 'label'">
														<optgroup label="Label">
															<option value="equals">Equals</option>
															<option value="not_equals">Not Equals</option>
															<option value="contains">Contains</option>
															<option value="regex">Regex</option>
														</optgroup>
													</template>
													<template x-if="criterion.type === 'alert_name'">
														<optgroup label="Alert Name">
															<option value="equals">Equals</option>
															<option value="contains">Contains</option>
															<option value="starts_with">Starts With</option>
															<option value="ends_with">Ends With</option>
															<option value="regex">Regex</option>
														</optgroup>
													</template>
												</select>
											</div>
											<!-- Values -->
											<div class="col-span-5">
												<!-- Label Key -->
												<template x-if="criterion.type === 'label'">
													<input x-model="criterion.key" type="text" placeholder="Label key (e.g., team)" class="w-full mb-1 px-2 py-1.5 border border-gray-300 dark:border-dark-border-subtle rounded text-xs focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white"/>
												</template>
												<!-- Severity multi-select -->
												<template x-if="criterion.type === 'severity' && criterion.operator === 'in'">
													<div class="flex flex-wrap gap-2">
														<label class="flex items-center text-xs"><input type="checkbox" x-model="criterion.values" value="critical" class="mr-1"/> Critical</label>
														<label class="flex items-center text-xs"><input type="checkbox" x-model="criterion.values" value="warning" class="mr-1"/> Warning</label>
														<label class="flex items-center text-xs"><input type="checkbox" x-model="criterion.values" value="info" class="mr-1"/> Info</label>
													</div>
												</template>
												<!-- Severity single -->
												<template x-if="criterion.type === 'severity' && criterion.operator !== 'in'">
													<select x-model="criterion.value" class="w-full px-2 py-1.5 border border-gray-300 dark:border-dark-border-subtle rounded text-xs focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white">
														<option value="">Select...</option>
														<option value="critical">Critical</option>
														<option value="warning">Warning</option>
														<option value="info">Info</option>
													</select>
												</template>
												<!-- Label/Alert name text input -->
												<template x-if="criterion.type === 'label'">
													<input x-model="criterion.value" type="text" placeholder="Label value" class="w-full px-2 py-1.5 border border-gray-300 dark:border-dark-border-subtle rounded text-xs focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white"/>
												</template>
												<template x-if="criterion.type === 'alert_name'">
													<input x-model="criterion.pattern" type="text" placeholder="Alert name pattern" class="w-full px-2 py-1.5 border border-gray-300 dark:border-dark-border-subtle rounded text-xs focus:ring-blue-500 focus:border-blue-500 dark:bg-dark-bg-primary dark:text-white"/>
												</template>
											</div>
											<!-- Remove -->
											<div class="col-span-1 flex justify-end">
												<button @click.prevent="removeRuleCriterion(index)" type="button" class="p-1 text-gray-400 hover:text-red-600">
													<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
													</svg>
												</button>
											</div>
										</div>
									</div>
								</template>
								<div x-show="ruleFormData.rule_config.criteria.length === 0" class="text-center py-6 text-gray-500 dark:text-gray-400 text-xs">
									No criteria added. Click "Add" to get started.
								</div>
							</div>
						</div>

						<!-- Actions -->
						<div class="flex justify-between pt-4 border-t border-gray-200 dark:border-dark-border-subtle">
							<button @click.prevent="testCurrentRule()" type="button" :disabled="ruleFormData.rule_config.criteria.length === 0" class="px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-dark-bg-primary border border-gray-300 dark:border-dark-border-subtle rounded-md hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary disabled:opacity-50">
								Test Rule
							</button>
							<div class="flex space-x-3">
								<button type="button" @click="closeRuleFormModal()" class="px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-dark-bg-primary border border-gray-300 dark:border-dark-border-subtle rounded-md hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary">
									Cancel
								</button>
								<button type="submit" :disabled="ruleFormData.rule_config.criteria.length === 0" class="px-3 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 disabled:opacity-50">
									<span x-text="editingRule ? 'Update' : 'Create'"></span>
								</button>
							</div>
						</div>
					</form>
				</div>
			</div>
		</div>

		<!-- Rule Test Results Modal (nested) -->
		<div x-show="showRuleTestModal" class="fixed inset-0 z-[70] overflow-y-auto" x-cloak @keydown.escape.window="closeRuleTestModal()">
			<div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
				<div x-show="showRuleTestModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75"></div>
				<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
				<div x-show="showRuleTestModal" x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100" x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" class="relative z-10 inline-block w-full max-w-2xl px-4 pt-5 pb-4 overflow-hidden text-left align-bottom transition-all transform bg-white dark:bg-dark-bg-secondary rounded-lg shadow-xl sm:my-8 sm:align-middle sm:p-6" @click.stop>
					<div class="flex items-center justify-between mb-4">
						<h3 class="text-lg font-medium text-gray-900 dark:text-white">Rule Test Results</h3>
						<button @click="closeRuleTestModal()" class="text-gray-400 hover:text-gray-500">
							<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
							</svg>
						</button>
					</div>

					<div x-show="ruleTestLoading" x-cloak class="text-center py-8">
						<svg class="animate-spin h-8 w-8 text-blue-600 mx-auto" fill="none" viewBox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
						</svg>
						<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Testing rule...</p>
					</div>

					<div x-show="!ruleTestLoading && ruleTestResults" x-cloak>
						<!-- Summary -->
						<div class="mb-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg border border-blue-200 dark:border-blue-800">
							<p class="text-sm font-medium text-blue-900 dark:text-blue-300">
								<span class="font-bold" x-text="ruleTestResults?.total_matches || 0"></span> alerts match this rule
							</p>
							<p class="mt-1 text-xs text-blue-700 dark:text-blue-400">
								Showing sample of <span x-text="ruleTestResults?.sample_alerts?.length || 0"></span> alerts
							</p>
						</div>

						<!-- Sample Alerts -->
						<div x-show="ruleTestResults?.sample_alerts?.length > 0" class="space-y-2 max-h-64 overflow-y-auto">
							<template x-for="alert in (ruleTestResults?.sample_alerts || [])" :key="alert.id">
								<div class="p-2 bg-gray-50 dark:bg-dark-bg-tertiary rounded border border-gray-200 dark:border-dark-border-subtle">
									<p class="text-sm font-medium text-gray-900 dark:text-white" x-text="alert.alert_name"></p>
									<div class="mt-1 flex items-center space-x-2 text-xs text-gray-500 dark:text-gray-400">
										<span class="px-1.5 py-0.5 rounded font-medium"
											:class="{
												'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400': alert.severity === 'critical',
												'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400': alert.severity === 'warning',
												'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400': alert.severity === 'info'
											}"
											x-text="alert.severity">
										</span>
										<span x-text="new Date(alert.fired_at).toLocaleString()"></span>
									</div>
								</div>
							</template>
						</div>
						<div x-show="ruleTestResults?.sample_alerts?.length === 0" class="text-center py-6 text-gray-500 dark:text-gray-400 text-sm">
							No alerts match this rule
						</div>
					</div>

					<div class="mt-4 flex justify-end">
						<button @click="closeRuleTestModal()" class="px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-dark-bg-primary border border-gray-300 dark:border-dark-border-subtle rounded-md hover:bg-gray-50 dark:hover:bg-dark-bg-tertiary">
							Close
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Individual Alert Details Modal (using shared component) -->
		@components.AlertModalReadonly("showAlertModal", "individualAlertLoading", "individualAlertData", "individualAlertOccurrences", "closeAlertModal()", "z-[60]")

		<!-- Fullscreen Chart Modal -->
		<div
			x-show="fullscreenChart"
			x-cloak
			class="fixed inset-0 z-50 overflow-hidden"
			@keydown.escape.window="closeFullscreenChart()"
		>
			<!-- Backdrop with blur -->
			<div
				x-show="fullscreenChart"
				x-transition:enter="transition ease-out duration-200"
				x-transition:enter-start="opacity-0"
				x-transition:enter-end="opacity-100"
				x-transition:leave="transition ease-in duration-150"
				x-transition:leave-start="opacity-100"
				x-transition:leave-end="opacity-0"
				class="absolute inset-0 bg-gray-900/80 backdrop-blur-sm"
				@click="closeFullscreenChart()"
			></div>

			<!-- Modal Content -->
			<div
				x-show="fullscreenChart"
				x-transition:enter="transition ease-out duration-200"
				x-transition:enter-start="opacity-0 scale-95"
				x-transition:enter-end="opacity-100 scale-100"
				x-transition:leave="transition ease-in duration-150"
				x-transition:leave-start="opacity-100 scale-100"
				x-transition:leave-end="opacity-0 scale-95"
				class="relative h-full w-full flex flex-col"
			>
				<!-- Header -->
				<div class="flex items-center justify-between px-6 py-4 bg-white dark:bg-dark-bg-secondary border-b border-gray-200 dark:border-dark-border-subtle shadow-lg">
					<div class="flex items-center space-x-4">
						<h3 class="text-xl font-semibold text-gray-900 dark:text-white" x-text="getFullscreenChartTitle()"></h3>
						<!-- Legend badges for time metrics chart -->
						<template x-if="fullscreenChart === 'timeMetrics'">
							<div class="flex items-center space-x-2">
								<span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">MTTR</span>
								<span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">MTTA</span>
								<span class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400">Fix Time</span>
							</div>
						</template>
					</div>
					<button @click="closeFullscreenChart()" class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors rounded-lg hover:bg-gray-100 dark:hover:bg-dark-bg-tertiary" title="Close (Esc)">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
						</svg>
					</button>
				</div>
				<!-- Chart Container -->
				<div class="flex-1 p-8 bg-white dark:bg-dark-bg-secondary">
					<canvas id="fullscreenChartCanvas" class="w-full h-full"></canvas>
				</div>
			</div>
		</div>
	</div>

	<script>
		function statisticsDashboardPage() {
			return {
				loading: false,
				hasData: false,
				statsData: null,
				sortColumn: 'count',
				sortDirection: 'desc',

				// Chart instances
				alertsTimeChart: null,
				distributionChart: null,
				topItemsChart: null,
				timeMetricsChart: null,

				// Chart state
				timeSeriesView: 'fired',
				timeSeriesData: null,
				topItemsData: null,
				distributionData: null,

				// Chart visibility toggles (for multi-line filtering)
				chartVisibility: {},

				// Stable color mapping for keys (ensures same key = same color across all charts)
				keyColorMap: {},

				// Applied filters (updated only when query runs)
				appliedGroupBy: 'severity',

				// Comparison mode
				comparisonMode: false,
				comparisonData: null,

				// Fullscreen chart modal
				fullscreenChart: null,
				fullscreenChartInstance: null,

				// Alert details modal (by alert name)
				showAlertDetailsModal: false,
				alertDetailsLoading: false,
				alertDetailsData: null,
				selectedAlertName: '',

				// Individual alert details modal (simple modal)
				showAlertModal: false,
				individualAlertData: null,
				individualAlertLoading: false,
				individualAlertOccurrences: [],

				// Rules management modal
				showRulesModal: false,
				rulesLoading: false,
				rules: [],
				showRuleFormModal: false,
				editingRule: null,
				showRuleTestModal: false,
				ruleTestLoading: false,
				ruleTestResults: null,
				ruleFormData: {
					rule_name: '',
					is_active: true,
					rule_config: {
						criteria: [],
						logic: 'AND'
					}
				},

				filters: {
					startDate: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0], // Last 7 days
					endDate: new Date().toISOString().split('T')[0], // Today
					groupBy: 'severity',
					periodType: 'day',
					applyRules: false,
					limit: 20,
					filterByTimeOfDay: false,
					timeOfDayStart: '22:00',
					timeOfDayEnd: '06:00',
					includeWeekends: true,
					severities: [], // Multi-select: ['critical', 'warning', 'info']
					teams: []       // Multi-select: ['team1', 'team2', ...]
				},

				// Available teams (loaded dynamically)
				availableTeams: [],
				showSeverityDropdown: false,
				showTeamDropdown: false,

				// Group-by color coding for visual connection
				groupByColors: {
					'severity': { border: 'border-l-red-500', bg: 'bg-red-50/50 dark:bg-red-900/10', label: 'text-red-700 dark:text-red-400', ring: 'ring-red-500' },
					'team': { border: 'border-l-blue-500', bg: 'bg-blue-50/50 dark:bg-blue-900/10', label: 'text-blue-700 dark:text-blue-400', ring: 'ring-blue-500' },
					'alert_name': { border: 'border-l-green-500', bg: 'bg-green-50/50 dark:bg-green-900/10', label: 'text-green-700 dark:text-green-400', ring: 'ring-green-500' },
					'period': { border: 'border-l-purple-500', bg: 'bg-purple-50/50 dark:bg-purple-900/10', label: 'text-purple-700 dark:text-purple-400', ring: 'ring-purple-500' },
					'': { border: 'border-l-gray-300 dark:border-l-gray-600', bg: 'bg-white dark:bg-dark-bg-secondary', label: 'text-gray-700 dark:text-gray-300', ring: 'ring-gray-300' }
				},

				getGroupByStyle(part) {
					const colors = this.groupByColors[this.appliedGroupBy] || this.groupByColors[''];
					return colors[part] || '';
				},

				getGroupByLabel() {
					const labels = { 'severity': 'Severity', 'team': 'Team', 'alert_name': 'Alert Name', 'period': 'Time Period' };
					return labels[this.appliedGroupBy] || 'Overall';
				},

				init() {
					// Watch for timeSeriesView changes
					this.$watch('timeSeriesView', () => {
						if (this.timeSeriesData) {
							this.updateTimeSeriesChart();
						}
					});
					// Auto-query on page load
					this.queryStatistics();
				},

				async queryStatistics() {
					this.loading = true;

					try {
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							apply_rules: this.filters.applyRules,
							group_by: this.filters.groupBy,
							period_type: this.filters.periodType,
							limit: this.filters.groupBy === 'alert_name' ? this.filters.limit : 0,
							filter_by_time_of_day: this.filters.filterByTimeOfDay,
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							include_weekends: this.filters.includeWeekends,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: {
								'Content-Type': 'application/json'
							},
							body: JSON.stringify(payload)
						});

						if (!response.ok) {
							throw new Error('Failed to query statistics');
						}

						const data = await response.json();
						this.statsData = data.data;
						this.hasData = true;

						// Update applied groupBy (controls layout)
						this.appliedGroupBy = this.filters.groupBy;

						// Load additional chart data in parallel
						await Promise.all([
							this.loadTimeSeriesData(),
							this.loadTopItemsData(),
							this.loadDistributionData()
						]);

						// Build stable color mapping from all unique keys
						this.buildKeyColorMap();

						// Initialize chart visibility based on loaded data
						this.initChartVisibility();

						// Load comparison data if comparison mode is active
						if (this.comparisonMode) {
							await this.loadComparisonData();
						}
					} catch (error) {
						console.error('Error querying statistics:', error);
						alert('Failed to load statistics: ' + error.message);
						this.hasData = false;
					} finally {
						this.loading = false;
						// Update all charts after loading is complete and elements are visible
						// Use requestAnimationFrame to ensure DOM is ready for rendering
						if (this.hasData) {
							requestAnimationFrame(() => {
								requestAnimationFrame(() => {
									this.updateAllCharts();
								});
							});
						}
					}
				},

				setDateRange(preset) {
					const now = new Date();
					const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

					switch(preset) {
						case 'today':
							this.filters.startDate = today.toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'week':
							this.filters.startDate = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'month':
							this.filters.startDate = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'quarter':
							this.filters.startDate = new Date(today.getTime() - 90 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
							this.filters.endDate = today.toISOString().split('T')[0];
							break;
						case 'past_month':
							// Get first and last day of previous month
							const firstOfCurrentMonth = new Date(today.getFullYear(), today.getMonth(), 1);
							const lastOfPrevMonth = new Date(firstOfCurrentMonth.getTime() - 1);
							const firstOfPrevMonth = new Date(lastOfPrevMonth.getFullYear(), lastOfPrevMonth.getMonth(), 1);
							this.filters.startDate = firstOfPrevMonth.toISOString().split('T')[0];
							this.filters.endDate = lastOfPrevMonth.toISOString().split('T')[0];
							break;
					}
				},

				setTimePreset(preset) {
					switch(preset) {
						case 'night':
							this.filters.timeOfDayStart = '22:00';
							this.filters.timeOfDayEnd = '06:00';
							break;
						case 'business':
							this.filters.timeOfDayStart = '09:00';
							this.filters.timeOfDayEnd = '18:00';
							break;
						case 'morning':
							this.filters.timeOfDayStart = '06:00';
							this.filters.timeOfDayEnd = '12:00';
							break;
						case 'evening':
							this.filters.timeOfDayStart = '18:00';
							this.filters.timeOfDayEnd = '22:00';
							break;
					}
				},

				// On-Call Schedule helpers
				getOnCallSchedule() {
					const saved = localStorage.getItem('dashboardSettings');
					if (saved) {
						try {
							const settings = JSON.parse(saved);
							if (settings.onCallSchedule) {
								return {
									weekdayStart: settings.onCallSchedule.weekdayStart || '18:00',
									weekdayEnd: settings.onCallSchedule.weekdayEnd || '08:00',
									includeWeekends: settings.onCallSchedule.includeWeekends !== false
								};
							}
						} catch (e) {
							console.error('Error parsing on-call schedule:', e);
						}
					}
					// Default on-call schedule
					return { weekdayStart: '18:00', weekdayEnd: '08:00', includeWeekends: true };
				},

				applyOnCallFilter() {
					const schedule = this.getOnCallSchedule();
					this.filters.filterByTimeOfDay = true;
					this.filters.timeOfDayStart = schedule.weekdayStart;
					this.filters.timeOfDayEnd = schedule.weekdayEnd;
					// Note: Weekend inclusion would require backend support for day-of-week filtering
				},

				getOnCallDescription() {
					const schedule = this.getOnCallSchedule();
					let desc = `${schedule.weekdayStart} - ${schedule.weekdayEnd} weekdays`;
					if (schedule.includeWeekends) {
						desc += ' + full weekends';
					}
					return desc;
				},

				getGroupByTitle() {
					const titles = {
						'severity': 'Statistics by Severity',
						'team': 'Statistics by Team',
						'alert_name': 'Statistics by Alert Name',
						'': 'Overall Statistics'
					};
					return titles[this.appliedGroupBy] || 'Statistics';
				},

				getOverallAvgMTTR() {
					if (!this.statsData?.statistics) return 0;
					const stats = Object.values(this.statsData.statistics);
					if (stats.length === 0) return 0;
					const total = stats.reduce((sum, s) => sum + (s.avg_mttr_seconds || 0), 0);
					return total / stats.length;
				},

				getOverallAvgMTTA() {
					if (!this.statsData?.statistics) return 0;
					const stats = Object.values(this.statsData.statistics);
					if (stats.length === 0) return 0;
					const total = stats.reduce((sum, s) => sum + (s.avg_mtta_seconds || 0), 0);
					return total / stats.length;
				},

				getOverallAvgFixTime() {
					if (!this.statsData?.statistics) return 0;
					const stats = Object.values(this.statsData.statistics);
					if (stats.length === 0) return 0;
					const total = stats.reduce((sum, s) => sum + (s.avg_fix_time_seconds || 0), 0);
					return total / stats.length;
				},

				getSeverityClass(severity) {
					if (this.appliedGroupBy !== 'severity') return '';

					const classes = {
						'critical': 'px-2 py-1 rounded text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
						'warning': 'px-2 py-1 rounded text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
						'info': 'px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400'
					};
					return classes[severity.toLowerCase()] || '';
				},

				getSeverityBadgeClass(severity) {
					const classes = {
						'critical': 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
						'warning': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
						'info': 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400'
					};
					return classes[severity.toLowerCase()] || 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300';
				},

				sortBy(column) {
					if (this.sortColumn === column) {
						// Toggle direction if same column
						this.sortDirection = this.sortDirection === 'asc' ? 'desc' : 'asc';
					} else {
						// New column, default to descending for numeric columns, ascending for text
						this.sortColumn = column;
						this.sortDirection = column === 'name' ? 'asc' : 'desc';
					}
				},

				getSortedStatistics() {
					if (!this.statsData?.statistics) return [];

					const entries = Object.entries(this.statsData.statistics);

					return entries.sort((a, b) => {
						const [keyA, statA] = a;
						const [keyB, statB] = b;

						let valueA, valueB;

						switch(this.sortColumn) {
							case 'name':
								valueA = keyA.toLowerCase();
								valueB = keyB.toLowerCase();
								break;
							case 'count':
								valueA = statA.count || 0;
								valueB = statB.count || 0;
								break;
							case 'avg_mttr':
								valueA = statA.avg_mttr_seconds || 0;
								valueB = statB.avg_mttr_seconds || 0;
								break;
							case 'total_mttr':
								valueA = statA.total_mttr_seconds || 0;
								valueB = statB.total_mttr_seconds || 0;
								break;
							case 'avg_mtta':
								valueA = statA.avg_mtta_seconds || 0;
								valueB = statB.avg_mtta_seconds || 0;
								break;
							case 'avg_fix_time':
								valueA = statA.avg_fix_time_seconds || 0;
								valueB = statB.avg_fix_time_seconds || 0;
								break;
							default:
								valueA = statA.count || 0;
								valueB = statB.count || 0;
						}

						if (valueA < valueB) return this.sortDirection === 'asc' ? -1 : 1;
						if (valueA > valueB) return this.sortDirection === 'asc' ? 1 : -1;
						return 0;
					});
				},

				getSortIcon(column) {
					if (this.sortColumn !== column) {
						return '<svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>';
					}

					if (this.sortDirection === 'asc') {
						return '<svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>';
					}

					return '<svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>';
				},

				formatNumber(num) {
					return new Intl.NumberFormat().format(num || 0);
				},

				formatDuration(seconds) {
					if (!seconds || seconds === 0) return '0s';

					const hours = Math.floor(seconds / 3600);
					const minutes = Math.floor((seconds % 3600) / 60);
					const secs = Math.floor(seconds % 60);

					const parts = [];
					if (hours > 0) parts.push(`${hours}h`);
					if (minutes > 0) parts.push(`${minutes}m`);
					if (secs > 0 || parts.length === 0) parts.push(`${secs}s`);

					return parts.join(' ');
				},

				formatMTTR(seconds) {
					if (!seconds || seconds === 0) return 'N/A';
					return this.formatDuration(seconds);
				},

				formatTimeOrNA(seconds) {
					if (!seconds || seconds === 0) return 'N/A';
					return this.formatDuration(seconds);
				},

				getPercentage(count) {
					if (!this.statsData?.total_alerts || this.statsData.total_alerts === 0) return 0;
					return (count / this.statsData.total_alerts * 100).toFixed(1);
				},

				getMaxCount() {
					if (!this.statsData?.statistics) return 0;
					const counts = Object.values(this.statsData.statistics).map(s => s.count || 0);
					return Math.max(...counts, 1);
				},

				formatDate(dateStr) {
					if (!dateStr) return '';
					const date = new Date(dateStr);
					return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
				},

				// ==================== Chart Methods ====================

				// Color palettes for different groupings
				chartColors: {
					severity: {
						'critical': { bg: '#dc2626', border: '#b91c1c' },
						'warning': { bg: '#f59e0b', border: '#d97706' },
						'info': { bg: '#3b82f6', border: '#2563eb' }
					},
					team: [
						{ bg: '#8b5cf6', border: '#7c3aed' },
						{ bg: '#06b6d4', border: '#0891b2' },
						{ bg: '#10b981', border: '#059669' },
						{ bg: '#f59e0b', border: '#d97706' },
						{ bg: '#ef4444', border: '#dc2626' },
						{ bg: '#ec4899', border: '#db2777' },
						{ bg: '#6366f1', border: '#4f46e5' },
						{ bg: '#14b8a6', border: '#0d9488' },
						{ bg: '#f97316', border: '#ea580c' },
						{ bg: '#84cc16', border: '#65a30d' }
					],
					default: [
						{ bg: '#3b82f6', border: '#2563eb' },
						{ bg: '#10b981', border: '#059669' },
						{ bg: '#f59e0b', border: '#d97706' },
						{ bg: '#ef4444', border: '#dc2626' },
						{ bg: '#8b5cf6', border: '#7c3aed' },
						{ bg: '#06b6d4', border: '#0891b2' },
						{ bg: '#ec4899', border: '#db2777' },
						{ bg: '#14b8a6', border: '#0d9488' },
						{ bg: '#f97316', border: '#ea580c' },
						{ bg: '#84cc16', border: '#65a30d' }
					]
				},

				// Build a stable color map from all unique keys across data sources
				// This ensures the same key always gets the same color in all charts
				buildKeyColorMap() {
					const allKeys = new Set();

					// Collect keys from distribution data
					if (this.distributionData) {
						Object.keys(this.distributionData).forEach(k => allKeys.add(k));
					}

					// Collect keys from top items data
					if (this.topItemsData) {
						Object.keys(this.topItemsData).forEach(k => allKeys.add(k));
					}

					// Collect keys from time series data (within each period's statistics)
					if (this.timeSeriesData) {
						this.timeSeriesData.forEach(item => {
							if (item.statistics) {
								Object.keys(item.statistics).forEach(k => allKeys.add(k));
							}
						});
					}

					// Sort keys alphabetically for stable ordering
					const sortedKeys = Array.from(allKeys).sort();

					// Build the color map
					this.keyColorMap = {};
					sortedKeys.forEach((key, index) => {
						this.keyColorMap[key] = index;
					});
				},

				getColorForKey(key, fallbackIndex = 0) {
					// For severity, use fixed semantic colors
					if (this.appliedGroupBy === 'severity') {
						return this.chartColors.severity[key.toLowerCase()] || this.chartColors.default[fallbackIndex % 10];
					}

					// For team and alert_name, use the stable color map
					const colorIndex = this.keyColorMap.hasOwnProperty(key)
						? this.keyColorMap[key]
						: fallbackIndex;

					if (this.appliedGroupBy === 'team') {
						return this.chartColors.team[colorIndex % 10];
					}
					return this.chartColors.default[colorIndex % 10];
				},

				async loadTimeSeriesData() {
					try {
						// Load period-based data with current groupBy for multi-line support
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							apply_rules: this.filters.applyRules,
							group_by: 'period',
							secondary_group_by: this.filters.groupBy || 'severity', // Break down by severity/team/alert_name within each period
							period_type: this.determinePeriodType(),
							filter_by_time_of_day: this.filters.filterByTimeOfDay,
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							include_weekends: this.filters.includeWeekends,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.timeSeriesData = data.data?.breakdown || [];
						}
					} catch (error) {
						console.error('Failed to load time series data:', error);
					}
				},

				async loadTopItemsData() {
					try {
						// Load top items based on current groupBy (or alert_name if no groupBy)
						const groupBy = this.filters.groupBy || 'alert_name';
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							apply_rules: this.filters.applyRules,
							group_by: groupBy,
							limit: 10,
							filter_by_time_of_day: this.filters.filterByTimeOfDay,
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							include_weekends: this.filters.includeWeekends,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.topItemsData = data.data?.statistics || {};
						}
					} catch (error) {
						console.error('Failed to load top items data:', error);
					}
				},

				async loadDistributionData() {
					try {
						// Only load if groupBy is set
						if (!this.filters.groupBy) {
							this.distributionData = null;
							return;
						}

						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							apply_rules: this.filters.applyRules,
							group_by: this.filters.groupBy,
							filter_by_time_of_day: this.filters.filterByTimeOfDay,
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							include_weekends: this.filters.includeWeekends,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.distributionData = data.data?.statistics || {};
						}
					} catch (error) {
						console.error('Failed to load distribution data:', error);
					}
				},

				async loadAvailableTeams() {
					try {
						// Query team grouping to get list of available teams
						const payload = {
							start_date: new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString(), // Last 90 days
							end_date: new Date().toISOString(),
							group_by: 'team'
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							const teams = Object.keys(data.data?.statistics || {});
							this.availableTeams = teams.filter(t => t !== 'unknown').sort();
						}
					} catch (error) {
						console.error('Failed to load available teams:', error);
					}
				},

				determinePeriodType() {
					const start = new Date(this.filters.startDate);
					const end = new Date(this.filters.endDate);
					const days = (end - start) / (1000 * 60 * 60 * 24);

					if (days <= 1) return 'hour';
					if (days <= 14) return 'day';
					if (days <= 90) return 'week';
					return 'month';
				},

				// Initialize visibility toggles based on current data
				initChartVisibility() {
					if (!this.appliedGroupBy) {
						this.chartVisibility = {};
						return;
					}

					const data = this.distributionData || this.statsData?.statistics || {};
					const keys = Object.keys(data);
					this.chartVisibility = {};
					keys.forEach(key => {
						this.chartVisibility[key] = true;
					});
				},

				// Toggle visibility of a line in the chart
				toggleChartVisibility(key) {
					this.chartVisibility[key] = !this.chartVisibility[key];
					this.updateTimeSeriesChart();
				},

				// Get button class for visibility toggle
				getVisibilityButtonClass(key, active) {
					if (!active) return '';
					const index = Object.keys(this.chartVisibility).indexOf(key);
					const color = this.getColorForKey(key, index);
					return `border-2`;
				},

				updateAllCharts() {
					this.updateTimeSeriesChart();
					this.updateDistributionChart();
					this.updateTopItemsChart();
					this.updateTimeMetricsChart();
				},

				updateDistributionChart() {
					const canvas = document.getElementById('distributionChart');
					if (!canvas) return;

					const ctx = canvas.getContext('2d');
					if (!ctx) return;

					if (this.distributionChart) {
						this.distributionChart.destroy();
						this.distributionChart = null;
					}

					// Only show if groupBy is set
					if (!this.appliedGroupBy || !this.distributionData) return;

					const data = this.distributionData;
					const labels = Object.keys(data);
					const counts = labels.map(l => data[l]?.count || 0);
					const backgroundColors = labels.map((l, i) => this.getColorForKey(l, i).bg);

					const isDark = document.documentElement.classList.contains('dark');

					this.distributionChart = new Chart(canvas, {
						type: 'doughnut',
						data: {
							labels: labels.map(l => l.charAt(0).toUpperCase() + l.slice(1)),
							datasets: [{
								data: counts,
								backgroundColor: backgroundColors,
								borderColor: isDark ? '#1f2937' : '#ffffff',
								borderWidth: 2
							}]
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							plugins: {
								legend: {
									position: 'bottom',
									labels: {
										color: isDark ? '#e5e7eb' : '#374151',
										padding: 15
									},
									onClick: (e, legendItem, legend) => {
										const key = labels[legendItem.index];
										this.toggleChartVisibility(key);
									}
								}
							},
							onClick: (event, elements) => {
								if (elements.length > 0) {
									const index = elements[0].index;
									const key = labels[index];
									this.toggleChartVisibility(key);
								}
							}
						}
					});
				},

				updateTopItemsChart() {
					const canvas = document.getElementById('topItemsChart');
					if (!canvas) return;

					const ctx = canvas.getContext('2d');
					if (!ctx) return;

					if (this.topItemsChart) {
						this.topItemsChart.destroy();
						this.topItemsChart = null;
					}

					const itemData = this.topItemsData || {};
					const sortedItems = Object.entries(itemData)
						.sort((a, b) => (b[1]?.count || 0) - (a[1]?.count || 0))
						.slice(0, 10);

					const labels = sortedItems.map(([name]) => name.length > 25 ? name.substring(0, 25) + '...' : name);
					const fullNames = sortedItems.map(([name]) => name);
					const counts = sortedItems.map(([, stat]) => stat?.count || 0);
					const backgroundColors = sortedItems.map(([name], i) => this.getColorForKey(name, i).bg);

					const isDark = document.documentElement.classList.contains('dark');

					this.topItemsChart = new Chart(canvas, {
						type: 'bar',
						data: {
							labels: labels,
							datasets: [{
								label: 'Count',
								data: counts,
								backgroundColor: backgroundColors,
								borderRadius: 4
							}]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							plugins: {
								legend: { display: false },
								tooltip: {
									callbacks: {
										title: (items) => fullNames[items[0].dataIndex]
									}
								}
							},
							scales: {
								x: {
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
								},
								y: {
									grid: { display: false },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
								}
							},
							onClick: (event, elements) => {
								if (elements.length > 0) {
									const index = elements[0].index;
									const itemName = fullNames[index];
									// Toggle visibility in time series if grouped
									if (this.appliedGroupBy && this.chartVisibility.hasOwnProperty(itemName)) {
										this.toggleChartVisibility(itemName);
									} else if (this.appliedGroupBy === 'alert_name' || !this.appliedGroupBy) {
										// Open alert details modal
										this.openAlertDetailsModal(itemName);
									}
								}
							}
						}
					});
				},

				updateTimeMetricsChart() {
					const canvas = document.getElementById('timeMetricsChart');
					if (!canvas) return;

					if (this.timeMetricsChart) {
						this.timeMetricsChart.destroy();
						this.timeMetricsChart = null;
					}

					// Only show when groupBy is set and not period
					if (!this.appliedGroupBy || this.appliedGroupBy === 'period' || !this.statsData?.statistics) {
						return;
					}

					const stats = this.statsData.statistics;
					const entries = Object.entries(stats)
						.sort((a, b) => (b[1].count || 0) - (a[1].count || 0))
						.slice(0, 10);

					if (entries.length === 0) return;

					const labels = entries.map(([k]) => k.length > 20 ? k.substring(0, 17) + '...' : k);
					const fullLabels = entries.map(([k]) => k);

					const mttrData = entries.map(([, v]) => v.avg_mttr_seconds || 0);
					const mttaData = entries.map(([, v]) => v.avg_mtta_seconds || 0);
					const fixTimeData = entries.map(([, v]) => v.avg_fix_time_seconds || 0);

					const isDark = document.documentElement.classList.contains('dark');
					const self = this;

					this.timeMetricsChart = new Chart(canvas, {
						type: 'bar',
						data: {
							labels: labels,
							datasets: [
								{
									label: 'MTTR',
									data: mttrData,
									backgroundColor: 'rgba(234, 179, 8, 0.8)',
									borderColor: '#eab308',
									borderWidth: 1
								},
								{
									label: 'MTTA',
									data: mttaData,
									backgroundColor: 'rgba(34, 197, 94, 0.8)',
									borderColor: '#22c55e',
									borderWidth: 1
								},
								{
									label: 'Fix Time',
									data: fixTimeData,
									backgroundColor: 'rgba(99, 102, 241, 0.8)',
									borderColor: '#6366f1',
									borderWidth: 1
								}
							]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							plugins: {
								legend: {
									position: 'top',
									labels: { color: isDark ? '#d1d5db' : '#374151' }
								},
								tooltip: {
									callbacks: {
										title: function(items) {
											return fullLabels[items[0].dataIndex];
										},
										label: function(ctx) {
											return ctx.dataset.label + ': ' + self.formatDuration(ctx.raw);
										}
									}
								}
							},
							scales: {
								x: {
									title: {
										display: true,
										text: 'Time (seconds)',
										color: isDark ? '#9ca3af' : '#6b7280'
									},
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								},
								y: {
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								}
							}
						}
					});
				},

				updateTimeSeriesChart() {
					const canvas = document.getElementById('alertsTimeChart');
					if (!canvas) return;

					const ctx = canvas.getContext('2d');
					if (!ctx) return;

					if (this.alertsTimeChart) {
						this.alertsTimeChart.destroy();
						this.alertsTimeChart = null;
					}

					const timeData = this.timeSeriesData || [];
					const labels = timeData.map(item => this.formatPeriodLabel(item.period));
					const isDark = document.documentElement.classList.contains('dark');

					let datasets = [];

					if (this.appliedGroupBy && Object.keys(this.chartVisibility).length > 0) {
						// Multi-line mode: one line per groupBy value
						const keys = Object.keys(this.chartVisibility).filter(k => this.chartVisibility[k]);

						keys.forEach((key, index) => {
							const color = this.getColorForKey(key, Object.keys(this.chartVisibility).indexOf(key));
							datasets.push({
								label: key,
								data: timeData.map(item => {
									const stats = item.statistics || {};
									return stats[key]?.count || 0;
								}),
								borderColor: color.bg,
								backgroundColor: color.bg + '20',
								fill: false,
								tension: 0.3,
								borderWidth: 2,
								pointRadius: 3,
								pointHoverRadius: 5
							});
						});
					} else {
						// Single line mode (Overall)
						if (this.timeSeriesView === 'fired' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Fired',
								data: timeData.map(item => item.total_count),
								borderColor: '#3b82f6',
								backgroundColor: 'rgba(59, 130, 246, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2
							});
						}

						if (this.timeSeriesView === 'resolved' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Resolved',
								data: timeData.map(item => {
									const stats = item.statistics || {};
									return Object.values(stats).reduce((sum, s) => sum + (s.count || 0), 0);
								}),
								borderColor: '#10b981',
								backgroundColor: 'rgba(16, 185, 129, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2,
								borderDash: this.timeSeriesView === 'both' ? [5, 5] : []
							});
						}
					}

					this.alertsTimeChart = new Chart(canvas, {
						type: 'line',
						data: { labels, datasets },
						options: {
							responsive: true,
							maintainAspectRatio: false,
							animation: false,
							interaction: {
								intersect: false,
								mode: 'index'
							},
							plugins: {
								legend: {
									display: datasets.length > 1,
									position: 'top',
									labels: {
										color: isDark ? '#e5e7eb' : '#374151',
										usePointStyle: true,
										padding: 15
									},
									onClick: (e, legendItem, legend) => {
										if (this.appliedGroupBy) {
											const key = legendItem.text;
											this.toggleChartVisibility(key);
										} else {
											// Default Chart.js legend click behavior
											Chart.defaults.plugins.legend.onClick.call(this, e, legendItem, legend);
										}
									}
								},
								tooltip: {
									mode: 'index',
									intersect: false
								}
							},
							scales: {
								x: {
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									ticks: {
										color: isDark ? '#9ca3af' : '#6b7280',
										maxRotation: 45,
										minRotation: 0
									}
								},
								y: {
									beginAtZero: true,
									grid: { color: isDark ? '#374151' : '#e5e7eb' },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' }
								}
							}
						}
					});
				},

				formatPeriodLabel(period) {
					if (!period) return '';
					const date = new Date(period);
					const days = (new Date(this.filters.endDate) - new Date(this.filters.startDate)) / (1000 * 60 * 60 * 24);

					if (days <= 1) {
						return date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
					} else if (days <= 14) {
						return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
					} else {
						return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
					}
				},

				// ==================== Comparison Mode ====================

				async loadComparisonData() {
					if (!this.hasData) return;

					try {
						// Calculate previous period (same duration, shifted back)
						const start = new Date(this.filters.startDate);
						const end = new Date(this.filters.endDate);
						const duration = end - start;

						const prevEnd = new Date(start.getTime() - 1); // Day before current start
						const prevStart = new Date(prevEnd.getTime() - duration);

						const payload = {
							start_date: prevStart.toISOString(),
							end_date: prevEnd.toISOString(),
							apply_rules: this.filters.applyRules,
							group_by: 'severity',
							filter_by_time_of_day: this.filters.filterByTimeOfDay,
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							include_weekends: this.filters.includeWeekends,
							severities: this.filters.severities,
							teams: this.filters.teams
						};

						const response = await fetch('/api/v1/statistics/query', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							const prevData = data.data;

							// Calculate deltas
							const currentTotal = this.statsData?.total_alerts || 0;
							const prevTotal = prevData?.total_alerts || 0;

							const currentMTTR = this.getOverallAvgMTTR();
							const prevMTTR = this.calculateMTTRFromStats(prevData?.statistics);

							const currentMTTA = this.getOverallAvgMTTA();
							const prevMTTA = this.calculateMTTAFromStats(prevData?.statistics);

							const currentCritical = this.getCriticalCount();
							const prevCritical = prevData?.statistics?.critical?.count || 0;

							this.comparisonData = {
								previous_total: prevTotal,
								delta_alerts: prevTotal > 0 ? ((currentTotal - prevTotal) / prevTotal * 100).toFixed(1) : 0,
								delta_mttr: prevMTTR > 0 ? ((currentMTTR - prevMTTR) / prevMTTR * 100).toFixed(1) : 0,
								delta_mtta: prevMTTA > 0 ? ((currentMTTA - prevMTTA) / prevMTTA * 100).toFixed(1) : 0,
								delta_critical: prevCritical > 0 ? ((currentCritical - prevCritical) / prevCritical * 100).toFixed(1) : 0
							};
						}
					} catch (error) {
						console.error('Failed to load comparison data:', error);
					}
				},

				calculateMTTRFromStats(stats) {
					if (!stats) return 0;
					const values = Object.values(stats);
					if (values.length === 0) return 0;
					return values.reduce((sum, s) => sum + (s.avg_mttr_seconds || 0), 0) / values.length;
				},

				calculateMTTAFromStats(stats) {
					if (!stats) return 0;
					const values = Object.values(stats);
					if (values.length === 0) return 0;
					return values.reduce((sum, s) => sum + (s.avg_mtta_seconds || 0), 0) / values.length;
				},

				getCriticalCount() {
					return this.statsData?.statistics?.critical?.count || 0;
				},

				getDeltaClass(delta, inverted = false) {
					const numDelta = parseFloat(delta);
					if (isNaN(numDelta) || numDelta === 0) return 'text-gray-500';

					// For inverted metrics (like duration/mttr), decrease is good
					const isGood = inverted ? numDelta < 0 : numDelta < 0;

					if (isGood) return 'text-green-600 dark:text-green-400';
					return 'text-red-600 dark:text-red-400';
				},

				getDeltaText(delta) {
					const numDelta = parseFloat(delta);
					if (isNaN(numDelta) || numDelta === 0) return '—';
					const sign = numDelta > 0 ? '↑' : '↓';
					return `${sign} ${Math.abs(numDelta)}%`;
				},

				// ==================== Alert Details Modal ====================

				async openAlertDetailsModal(alertName) {
					this.selectedAlertName = alertName;
					this.showAlertDetailsModal = true;
					this.alertDetailsLoading = true;
					this.alertDetailsData = null;

					try {
						const payload = {
							start_date: this.filters.startDate + 'T00:00:00Z',
							end_date: this.filters.endDate + 'T23:59:59Z',
							alert_name: alertName,
							apply_rules: this.filters.applyRules,
							filter_by_time_of_day: this.filters.filterByTimeOfDay,
							time_of_day_start: this.filters.timeOfDayStart,
							time_of_day_end: this.filters.timeOfDayEnd,
							include_weekends: this.filters.includeWeekends,
							severities: this.filters.severities,
							teams: this.filters.teams,
							limit: 100
						};

						const response = await fetch('/api/v1/statistics/alerts-by-name', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload)
						});

						if (response.ok) {
							const data = await response.json();
							this.alertDetailsData = data.data?.alerts || [];
						} else {
							console.error('Failed to load alert details');
							this.alertDetailsData = [];
						}
					} catch (error) {
						console.error('Error loading alert details:', error);
						this.alertDetailsData = [];
					} finally {
						this.alertDetailsLoading = false;
					}
				},

				closeAlertDetailsModal() {
					this.showAlertDetailsModal = false;
					this.alertDetailsData = null;
					this.selectedAlertName = '';
				},

				// Fullscreen chart methods
				getFullscreenChartTitle() {
					const titles = {
						'alertsTime': 'Alerts Over Time' + (this.appliedGroupBy ? ' by ' + this.getGroupByLabel() : ''),
						'distribution': this.getGroupByLabel() + ' Distribution',
						'topItems': 'Top 10 ' + (this.appliedGroupBy ? this.getGroupByLabel() : 'Alerts'),
						'timeMetrics': 'Resolution Times by ' + this.getGroupByLabel()
					};
					return titles[this.fullscreenChart] || 'Chart';
				},

				openFullscreenChart(chartType) {
					this.fullscreenChart = chartType;
					// Wait for DOM to update, then render the chart
					this.$nextTick(() => {
						setTimeout(() => this.renderFullscreenChart(), 50);
					});
				},

				closeFullscreenChart() {
					if (this.fullscreenChartInstance) {
						this.fullscreenChartInstance.destroy();
						this.fullscreenChartInstance = null;
					}
					this.fullscreenChart = null;
				},

				renderFullscreenChart() {
					const canvas = document.getElementById('fullscreenChartCanvas');
					if (!canvas) return;

					if (this.fullscreenChartInstance) {
						this.fullscreenChartInstance.destroy();
					}

					const isDark = document.documentElement.classList.contains('dark');
					const self = this;

					switch (this.fullscreenChart) {
						case 'alertsTime':
							this.renderFullscreenTimeSeriesChart(canvas, isDark);
							break;
						case 'distribution':
							this.renderFullscreenDistributionChart(canvas, isDark);
							break;
						case 'topItems':
							this.renderFullscreenTopItemsChart(canvas, isDark);
							break;
						case 'timeMetrics':
							this.renderFullscreenTimeMetricsChart(canvas, isDark);
							break;
					}
				},

				renderFullscreenTimeSeriesChart(canvas, isDark) {
					const timeData = this.timeSeriesData || [];
					const labels = timeData.map(item => this.formatPeriodLabel(item.period));
					let datasets = [];

					if (this.appliedGroupBy && Object.keys(this.chartVisibility).length > 0) {
						const keys = Object.keys(this.chartVisibility).filter(k => this.chartVisibility[k]);
						keys.forEach((key, index) => {
							const color = this.getColorForKey(key, Object.keys(this.chartVisibility).indexOf(key));
							datasets.push({
								label: key,
								data: timeData.map(item => (item.statistics || {})[key]?.count || 0),
								borderColor: color.bg,
								backgroundColor: color.bg + '20',
								fill: false,
								tension: 0.3,
								borderWidth: 2
							});
						});
					} else {
						if (this.timeSeriesView === 'fired' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Fired',
								data: timeData.map(item => item.total_count),
								borderColor: '#3b82f6',
								backgroundColor: 'rgba(59, 130, 246, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2
							});
						}
						if (this.timeSeriesView === 'resolved' || this.timeSeriesView === 'both') {
							datasets.push({
								label: 'Alerts Resolved',
								data: timeData.map(item => item.resolved_count || 0),
								borderColor: '#22c55e',
								backgroundColor: 'rgba(34, 197, 94, 0.1)',
								fill: true,
								tension: 0.3,
								borderWidth: 2
							});
						}
					}

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'line',
						data: { labels, datasets },
						options: {
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { position: 'top', labels: { color: isDark ? '#d1d5db' : '#374151' } }
							},
							scales: {
								x: { ticks: { color: isDark ? '#9ca3af' : '#6b7280' }, grid: { color: isDark ? '#374151' : '#e5e7eb' } },
								y: { ticks: { color: isDark ? '#9ca3af' : '#6b7280' }, grid: { color: isDark ? '#374151' : '#e5e7eb' }, beginAtZero: true }
							}
						}
					});
				},

				renderFullscreenDistributionChart(canvas, isDark) {
					const stats = this.statsData?.statistics || {};
					const entries = Object.entries(stats).sort((a, b) => (b[1].count || 0) - (a[1].count || 0));
					const labels = entries.map(([k]) => k);
					const data = entries.map(([, v]) => v.count || 0);
					const colors = entries.map(([k], i) => this.getColorForKey(k, i));

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'doughnut',
						data: {
							labels,
							datasets: [{
								data,
								backgroundColor: colors.map(c => c.bg),
								borderColor: isDark ? '#1f2937' : '#ffffff',
								borderWidth: 2
							}]
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { position: 'right', labels: { color: isDark ? '#d1d5db' : '#374151' } }
							}
						}
					});
				},

				renderFullscreenTopItemsChart(canvas, isDark) {
					const stats = this.topItemsData || this.statsData?.statistics || {};
					const entries = Object.entries(stats).sort((a, b) => (b[1].count || 0) - (a[1].count || 0)).slice(0, 15);
					const labels = entries.map(([k]) => k);
					const data = entries.map(([, v]) => v.count || 0);
					const colors = entries.map(([k], i) => this.getColorForKey(k, i));

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'bar',
						data: {
							labels,
							datasets: [{
								label: 'Count',
								data,
								backgroundColor: colors.map(c => c.bg + 'cc'),
								borderColor: colors.map(c => c.border),
								borderWidth: 1
							}]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { display: false }
							},
							scales: {
								x: { ticks: { color: isDark ? '#9ca3af' : '#6b7280' }, grid: { color: isDark ? '#374151' : '#e5e7eb' } },
								y: { ticks: { color: isDark ? '#9ca3af' : '#6b7280' }, grid: { color: isDark ? '#374151' : '#e5e7eb' } }
							}
						}
					});
				},

				renderFullscreenTimeMetricsChart(canvas, isDark) {
					const stats = this.statsData?.statistics || {};
					const entries = Object.entries(stats).sort((a, b) => (b[1].count || 0) - (a[1].count || 0)).slice(0, 15);
					const labels = entries.map(([k]) => k);
					const self = this;

					this.fullscreenChartInstance = new Chart(canvas, {
						type: 'bar',
						data: {
							labels,
							datasets: [
								{
									label: 'MTTR',
									data: entries.map(([, v]) => v.avg_mttr_seconds || 0),
									backgroundColor: 'rgba(234, 179, 8, 0.8)',
									borderColor: '#eab308',
									borderWidth: 1
								},
								{
									label: 'MTTA',
									data: entries.map(([, v]) => v.avg_mtta_seconds || 0),
									backgroundColor: 'rgba(34, 197, 94, 0.8)',
									borderColor: '#22c55e',
									borderWidth: 1
								},
								{
									label: 'Fix Time',
									data: entries.map(([, v]) => v.avg_fix_time_seconds || 0),
									backgroundColor: 'rgba(99, 102, 241, 0.8)',
									borderColor: '#6366f1',
									borderWidth: 1
								}
							]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { position: 'top', labels: { color: isDark ? '#d1d5db' : '#374151' } },
								tooltip: {
									callbacks: {
										label: function(ctx) {
											return ctx.dataset.label + ': ' + self.formatDuration(ctx.raw);
										}
									}
								}
							},
							scales: {
								x: {
									title: { display: true, text: 'Time (seconds)', color: isDark ? '#9ca3af' : '#6b7280' },
									ticks: { color: isDark ? '#9ca3af' : '#6b7280' },
									grid: { color: isDark ? '#374151' : '#e5e7eb' }
								},
								y: { ticks: { color: isDark ? '#9ca3af' : '#6b7280' }, grid: { color: isDark ? '#374151' : '#e5e7eb' } }
							}
						}
					});
				},

				// Open individual alert details modal
				async openIndividualAlertDetails(alert) {
					console.log('Opening alert details for:', alert);
					this.individualAlertLoading = true;
					this.showAlertModal = true;
					this.individualAlertData = null;
					this.individualAlertOccurrences = [];

					const fingerprint = alert.fingerprint;

					try {
						// Fetch statistics data for this alert
						const response = await fetch(`/api/v1/statistics/alert/${fingerprint}`, {
							credentials: 'include'
						});

						const result = await response.json();

						if (result.success && result.data) {
							this.individualAlertData = result.data.details;
							this.individualAlertOccurrences = result.data.occurrences || [];
						} else {
							console.error('Failed to load alert details:', result.error || 'Unknown error');
							this.closeAlertModal();
						}
					} catch (error) {
						console.error('Error loading alert details:', error);
						this.closeAlertModal();
					} finally {
						this.individualAlertLoading = false;
					}
				},

				// Close individual alert details modal
				closeAlertModal() {
					this.showAlertModal = false;
					this.individualAlertData = null;
					this.individualAlertOccurrences = [];
				},

				// Format duration for display
				formatDuration(seconds) {
					if (!seconds || seconds <= 0) return '—';
					const hours = Math.floor(seconds / 3600);
					const minutes = Math.floor((seconds % 3600) / 60);
					const secs = Math.floor(seconds % 60);
					if (hours > 0) {
						return `${hours}h ${minutes}m`;
					} else if (minutes > 0) {
						return `${minutes}m ${secs}s`;
					}
					return `${secs}s`;
				},

				// Copy to clipboard
				copyToClipboard(text) {
					if (!text) return;
					navigator.clipboard.writeText(text).then(() => {
						// Success
					}).catch(err => {
						console.error('Failed to copy:', err);
					});
				},

				// Format alert date, handling Go zero dates
				formatAlertDate(dateStr) {
					if (!dateStr) return '—';
					const date = new Date(dateStr);
					// Check for Go zero time (0001-01-01T00:00:00Z) or invalid date
					if (isNaN(date.getTime()) || date.getFullYear() < 1970) {
						return '—';
					}
					return date.toLocaleString();
				},

				getAlertLabels(alert) {
					if (!alert.metadata) return {};
					try {
						const metadata = typeof alert.metadata === 'string' ? JSON.parse(alert.metadata) : alert.metadata;
						return metadata.labels || {};
					} catch (e) {
						return {};
					}
				},

				// ============ Rules Management Methods ============

				async openRulesModal() {
					this.showRulesModal = true;
					await this.loadRules();
				},

				closeRulesModal() {
					this.showRulesModal = false;
				},

				async loadRules() {
					this.rulesLoading = true;
					try {
						const response = await fetch('/api/v1/statistics/rules', { credentials: 'include' });
						const data = await response.json();
						if (data.success) {
							this.rules = data.data.rules || [];
						} else {
							console.error('Error loading rules:', data.message);
						}
					} catch (error) {
						console.error('Error loading rules:', error);
					} finally {
						this.rulesLoading = false;
					}
				},

				openRuleFormModal(rule = null) {
					this.editingRule = rule;
					if (rule) {
						this.ruleFormData = JSON.parse(JSON.stringify(rule));
					} else {
						this.ruleFormData = {
							rule_name: '',
							is_active: true,
							rule_config: {
								criteria: [],
								logic: 'AND'
							}
						};
					}
					this.showRuleFormModal = true;
				},

				closeRuleFormModal() {
					this.showRuleFormModal = false;
					this.editingRule = null;
				},

				editRule(rule) {
					this.openRuleFormModal(rule);
				},

				async saveRule() {
					try {
						const url = this.editingRule
							? `/api/v1/statistics/rules/${this.editingRule.id}`
							: '/api/v1/statistics/rules';
						const method = this.editingRule ? 'PUT' : 'POST';

						const response = await fetch(url, {
							method,
							credentials: 'include',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(this.ruleFormData)
						});

						const data = await response.json();
						if (data.success) {
							this.closeRuleFormModal();
							await this.loadRules();
						} else {
							alert('Error: ' + data.message);
						}
					} catch (error) {
						console.error('Error saving rule:', error);
						alert('Failed to save rule');
					}
				},

				async deleteRule(rule) {
					if (!confirm(`Are you sure you want to delete "${rule.rule_name}"?`)) {
						return;
					}

					try {
						const response = await fetch(`/api/v1/statistics/rules/${rule.id}`, {
							method: 'DELETE',
							credentials: 'include'
						});

						const data = await response.json();
						if (data.success) {
							await this.loadRules();
						} else {
							alert('Error: ' + data.message);
						}
					} catch (error) {
						console.error('Error deleting rule:', error);
						alert('Failed to delete rule');
					}
				},

				async toggleRuleActive(rule) {
					const updatedRule = { ...rule, is_active: !rule.is_active };

					try {
						const response = await fetch(`/api/v1/statistics/rules/${rule.id}`, {
							method: 'PUT',
							credentials: 'include',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(updatedRule)
						});

						const data = await response.json();
						if (data.success) {
							await this.loadRules();
						} else {
							alert('Error: ' + data.message);
						}
					} catch (error) {
						console.error('Error toggling rule:', error);
						alert('Failed to toggle rule');
					}
				},

				async testRule(rule) {
					this.ruleTestLoading = true;
					this.ruleTestResults = null;
					this.showRuleTestModal = true;

					try {
						const response = await fetch('/api/v1/statistics/rules/test', {
							method: 'POST',
							credentials: 'include',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({
								rule_config: rule.rule_config,
								sample_size: 10
							})
						});

						const data = await response.json();
						if (data.success) {
							this.ruleTestResults = data.data;
						} else {
							alert('Error: ' + data.message);
						}
					} catch (error) {
						console.error('Error testing rule:', error);
						alert('Failed to test rule');
					} finally {
						this.ruleTestLoading = false;
					}
				},

				async testCurrentRule() {
					if (this.ruleFormData.rule_config.criteria.length === 0) {
						alert('Please add at least one criterion');
						return;
					}

					this.ruleTestLoading = true;
					this.ruleTestResults = null;
					this.showRuleTestModal = true;

					try {
						const response = await fetch('/api/v1/statistics/rules/test', {
							method: 'POST',
							credentials: 'include',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({
								rule_config: this.ruleFormData.rule_config,
								sample_size: 10
							})
						});

						const data = await response.json();
						if (data.success) {
							this.ruleTestResults = data.data;
						} else {
							alert('Error: ' + data.message);
						}
					} catch (error) {
						console.error('Error testing rule:', error);
						alert('Failed to test rule');
					} finally {
						this.ruleTestLoading = false;
					}
				},

				closeRuleTestModal() {
					this.showRuleTestModal = false;
					this.ruleTestResults = null;
				},

				addRuleCriterion() {
					this.ruleFormData.rule_config.criteria.push({
						type: 'severity',
						operator: 'equals',
						value: '',
						values: [],
						key: '',
						pattern: ''
					});
				},

				removeRuleCriterion(index) {
					this.ruleFormData.rule_config.criteria.splice(index, 1);
				},

				onRuleCriterionTypeChange(index) {
					const criterion = this.ruleFormData.rule_config.criteria[index];
					criterion.operator = 'equals';
					criterion.value = '';
					criterion.values = [];
					criterion.key = '';
					criterion.pattern = '';
				},

				getRuleCriterionValue(criterion) {
					if (criterion.type === 'severity' && criterion.operator === 'in') {
						return criterion.values.join(', ');
					}
					if (criterion.type === 'label') {
						return `${criterion.key}=${criterion.value}`;
					}
					if (criterion.type === 'alert_name') {
						return criterion.pattern || criterion.value;
					}
					return criterion.value;
				},

				// ============ End Rules Management Methods ============

				formatDateTime(dateStr) {
					if (!dateStr) return '';
					const date = new Date(dateStr);
					return date.toLocaleString('en-US', {
						month: 'short',
						day: 'numeric',
						year: 'numeric',
						hour: '2-digit',
						minute: '2-digit'
					});
				},

				exportData() {
					if (!this.statsData) return;

					// Generate CSV
					let csv = '';

					if (this.appliedGroupBy === 'period') {
						// Export period breakdown
						csv = 'Period,Start Time,End Time,Total Count,Severities\n';
						this.statsData.breakdown.forEach(item => {
							const severities = Object.entries(item.statistics || {})
								.map(([sev, stat]) => `${sev}:${stat.count}`)
								.join(';');
							csv += `"${item.period}","${item.start_time}","${item.end_time}",${item.total_count},"${severities}"\n`;
						});
					} else {
						// Export grouped statistics
						csv = 'Category,Count,Avg MTTR (s),Total MTTR (s),Avg MTTA (s),Avg Fix Time (s)\n';
						Object.entries(this.statsData.statistics || {}).forEach(([key, stat]) => {
							csv += `"${key}",${stat.count},${stat.avg_mttr_seconds},${stat.total_mttr_seconds},${stat.avg_mtta_seconds},${stat.avg_fix_time_seconds}\n`;
						});
					}

					// Download CSV
					const blob = new Blob([csv], { type: 'text/csv' });
					const url = window.URL.createObjectURL(blob);
					const a = document.createElement('a');
					a.href = url;
					a.download = `alert-statistics-${this.filters.startDate}-to-${this.filters.endDate}.csv`;
					document.body.appendChild(a);
					a.click();
					document.body.removeChild(a);
					window.URL.revokeObjectURL(url);
				}
			};
		}
	</script>
}
